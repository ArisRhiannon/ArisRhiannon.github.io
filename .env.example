# misitio — Environment Variables
# Copy this to .env and fill in the values.

# Admin authentication (PBKDF2-SHA256)
# Generate with: bun -e '
#   const {randomBytes} = require("crypto");
#   const salt = randomBytes(16).toString("hex");
#   console.log("SALT:", salt);
# '
ADMIN_HASH=
ADMIN_SALT=
ADMIN_ITERATIONS=260000

# Admin session signing (HMAC-SHA256)
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=

# Chat endpoint (llama.cpp / Ollama)
CHAT_PASSWORD=

# llama.cpp completions URL (default: localhost:8080)
LLAMA_URL=http://host.docker.internal:8080/v1/chat/completions
