# ── Kavita Manga Reader ──
manga.aris-sama.duckdns.org {
  # Matcher: requests que YA traen un Bearer JWT (sesión activa de Kavita)
  @bearer header Authorization "Bearer *"

  # Requests con JWT → pasan directo con Bearer intacto (sin basic auth)
  handle @bearer {
    reverse_proxy kavita:5000
  }

  # Resto de requests → basic auth, luego strip del header Basic antes de Kavita
  handle {
    basicauth {
      aris $2b$14$TzNJ0C6FNc.ij6krXBgRieJPN0Nbbtiu.tcDcH1Ev1z7wdLX6fXOq
    }
    reverse_proxy kavita:5000 {
      header_up -Authorization
    }
  }

  encode gzip zstd
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

