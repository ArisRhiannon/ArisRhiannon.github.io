---
import Base from '../layouts/Base.astro';
import ChatBox from '../features/chat/ChatBox.astro';
---

<Base title="chat · aris">

  <section class="page-hero">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
    </div>
    <div class="page-hero-content">
      <div class="hero-chip">
        <span class="hero-bracket">[</span>chat<span class="hero-bracket">]</span>
        <span class="hero-chip-tag">gemma 4 · local · arm64</span>
      </div>
      <h1 class="hero-title">habla con aris</h1>
    </div>
  </section>

  <section class="chat-page">
    <ChatBox />
  </section>

</Base>

<style>
  .page-hero {
    position: relative;
    padding: var(--space-16) var(--space-8) var(--space-8);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    width: 300px; height: 300px;
    top: -80px; left: 40%;
    background: radial-gradient(circle, rgba(134,239,172,0.10) 0%, transparent 70%);
    filter: blur(40px);
  }

  .page-hero-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-sage);
    background: rgba(134,239,172,0.08);
    border: 1px solid rgba(134,239,172,0.20);
    padding: 4px 14px;
    border-radius: var(--radius-full);
  }

  .hero-bracket {
    color: var(--color-sage);
    opacity: 0.6;
  }

  .hero-chip-tag {
    font-size: 9px;
    color: var(--color-muted);
    border-left: 1px solid var(--color-border);
    padding-left: 8px;
  }

  .hero-title {
    font-family: var(--font-deco);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-ink);
  }

  .chat-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-20);
  }

  @media (max-width: 768px) {
    .page-hero { padding: var(--space-12) var(--space-4) var(--space-6); }
    .chat-page { padding: 0 var(--space-4) var(--space-12); }
  }
</style>
