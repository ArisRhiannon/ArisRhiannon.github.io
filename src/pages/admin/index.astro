const dropEl=document.getElementById('adm-drop');
const dropInner=document.getElementById('adm-drop-inner');
const uploadForm=document.getElementById('adm-upload-form');
const fileInput=document.getElementById('adm-file-input');
let selFile=null;

function showUploadForm(file) {
  selFile=file;
  document.getElementById('uf-title').value=file.name.replace(/\.[^.]+$/,'');
  dropInner.style.display='none';
  uploadForm.style.display='flex';
