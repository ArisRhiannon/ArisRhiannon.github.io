// ── Save JSON ─────────────────────────────────────────────────
async function saveJson(file, container, btn) {
  const wrap = container.querySelector('[data-collector]') ?? container;
  const collector = wrap?.dataset?.collector;
  let payload;
  try {
    if(collector==='now'){
      payload={
        updated:new Date().toISOString().split('T')[0],
        location:document.getElementById('now-location')?.value?.trim()??'',
        status:document.getElementById('now-status')?.value?.trim()??'',
        items:[...document.querySelectorAll('#now-items .adm-item')].map(c=>({
          icon:c.querySelector('.now-icon').value.trim(),
          category:c.querySelector('.now-category').value.trim(),
          text:c.querySelector('.now-text').value.trim(),
        }))
      };
    } else if(collector==='books'){
      payload=[...document.querySelectorAll('#books-list .adm-item')].map(c=>({
        title:c.querySelector('.book-title').value.trim(),
        author:c.querySelector('.book-author').value.trim(),
        status:c.querySelector('.book-status').value,
        cover:c.querySelector('.book-cover').value.trim()||undefined,
      }));
    } else if(collector==='homepage'){
      payload={
        title:document.getElementById('hp-title')?.value?.trim()??'',
        blocks:[...document.querySelectorAll('#hp-blocks .adm-item')].map(c=>{
          const obj={type:c.dataset.type??'custom'};
          c.querySelectorAll('.block-field').forEach(f=>{const v=f.value.trim();if(v)obj[f.dataset.key]=f.dataset.key==='limit'?Number(v):v;});
          return obj;
        })
      };
    } else if(collector==='gacha-cfg'){
      payload={games:[...document.querySelectorAll('#gacha-list .adm-item')].map(c=>({
        icon:c.querySelector('.gacha-icon').value.trim(),
        name:c.querySelector('.gacha-name').value.trim(),
        id:c.querySelector('.gacha-id').value.trim(),
        uid:c.querySelector('.gacha-uid').value.trim(),
      }))};
    } else if(collector==='nav'){
      payload={items:[...document.querySelectorAll('#nav-items .adm-item')].map(c=>({
        label:c.querySelector('.nav-label').value.trim(),
        href:c.querySelector('.nav-href').value.trim(),
      })).filter(i=>i.label)};
    } else {
      payload=JSON.parse(document.getElementById('generic-ta')?.value??'null');
    }
  } catch(e) { toast(`JSON inválido: ${e}`,'err'); return; }

  if(btn){ btn.disabled=true; btn.textContent='guardando...'; }
  const res=await fetch(`/api/admin/data?file=${file}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  if(btn){ btn.disabled=false; btn.textContent='guardar cambios ↑'; }
  if(res.ok){ jsonCache[file]=payload; toast(`✓ ${file} guardado — aplicado al instante`,'ok'); }
  else toast(`Error guardando ${file}: ${await res.text()}`,'err');
}

// ── Videos ───────────────────────────────────────────────────
let videosLoaded=false;
async function loadVideos() {
  const list=document.getElementById('adm-vlist');
  const countEl=document.getElementById('adm-vcount');
  if(videosLoaded) return;
  videosLoaded=true;
  list.innerHTML='<p class="adm-loading">cargando...</p>';
  try {
    const {videos}=await fetch('/api/videos').then(r=>r.json());
    if(countEl) countEl.textContent=videos.length;
    if(!videos.length){list.innerHTML='<p class="adm-loading">sin videos todavía.</p>';return;}
    list.innerHTML='';
    videos.forEach(v=>{
      let desc={}; try{desc=JSON.parse(v.descriptors??'{}')}catch{}
      const descStr=Object.entries(desc).map(([k,val])=>`${k}:${val}`).join(' · ');
      const card=el('div','adm-vcard'); card.dataset.id=v.id;
      card.innerHTML=`
        <div class="adm-vthumb">${v.thumbnail?`<img src="${v.thumbnail}" alt=""/>`:'▶'}</div>
        <div class="adm-vbody">
          <input class="adm-input" style="margin-bottom:4px" value="${esc(v.title)}" data-field="title"/>
          <div class="adm-vrow">
            <input class="adm-input-sm" value="${esc(v.category??'general')}" placeholder="categoría" data-field="category" style="flex:1"/>
            <input class="adm-input-sm" value="${esc(descStr)}" placeholder="key:val, ..." data-field="descriptors_raw" style="flex:3"/>
          </div>
          <div class="adm-vrow" style="margin-top:4px">
            <a href="/v/${v.id}" target="_blank" class="adm-btn adm-btn-ghost adm-btn-xs">↗ ver</a>
            <button class="adm-btn adm-btn-ghost adm-btn-xs va-save" data-id="${v.id}">guardar</button>
            <button class="adm-btn adm-btn-danger adm-btn-xs va-del" data-id="${v.id}">eliminar</button>
          </div>
          <div class="adm-vlink">/uploads/${esc(v.filename??'')}</div>
        </div>`;
      card.querySelector('.va-save').addEventListener('click', async()=>{
        const title=card.querySelector('[data-field="title"]').value;
        const category=card.querySelector('[data-field="category"]').value;
        const rawDesc=card.querySelector('[data-field="descriptors_raw"]').value;
        const descriptors={};
        rawDesc.split(',').forEach(part=>{const[k,...rest]=part.split(':');if(k?.trim())descriptors[k.trim()]=rest.join(':').trim();});
        const res=await fetch('/api/videos/update',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:v.id,title,category,descriptors})});
        const sb=card.querySelector('.va-save');
        if(res.ok){sb.textContent='✓';toast('Video actualizado','ok');}else{sb.textContent='❌';}
        setTimeout(()=>{sb.textContent='guardar';},2000);
      });
      card.querySelector('.va-del').addEventListener('click', async()=>{
        if(!confirm('¿Eliminar este video?'))return;
        await fetch(`/api/videos?id=${v.id}`,{method:'DELETE'});
        card.remove(); videosLoaded=false; loadVideos();
        toast('Video eliminado','inf');
      });
      list.appendChild(card);
    });
  } catch(e){list.innerHTML=`<p class="adm-loading" style="color:var(--adm-red)">${e}</p>`;}
}

