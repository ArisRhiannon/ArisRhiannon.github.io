---
import { Database } from 'bun:sqlite';
import { join } from 'path';
import { readdirSync, existsSync, statSync, readFileSync } from 'fs';

// ── Stats ──────────────────────────────────────────────────────
let videoCount = 0, charCount = 0, commentCount = 0, totalVideoSize = 0;
try {
  const db = new Database(join(process.cwd(), 'data', 'database.sqlite'), { readonly: true });
  videoCount   = (db.query('SELECT COUNT(*) as n FROM videos').get() as any)?.n ?? 0;
  charCount    = (db.query('SELECT COUNT(*) as n FROM characters').get() as any)?.n ?? 0;
  try { commentCount = (db.query('SELECT COUNT(*) as n FROM comments').get() as any)?.n ?? 0; } catch {}
  db.close();
} catch {}

const uploadsDir = join(process.cwd(), 'public', 'uploads');
if (existsSync(uploadsDir)) {
  readdirSync(uploadsDir).forEach(f => {
    try { totalVideoSize += statSync(join(uploadsDir, f)).size; } catch {}
  });
}
const sizeMB = (totalVideoSize / 1024 / 1024).toFixed(1);

// ── Auto-detección de módulos ──────────────────────────────────
const featuresDir = join(process.cwd(), 'src', 'features');
const pagesDir    = join(process.cwd(), 'src', 'pages');
const dataDir     = join(process.cwd(), 'data');

const featureModules = existsSync(featuresDir)
  ? readdirSync(featuresDir, { withFileTypes: true })
      .filter(d => d.isDirectory())
      .map(d => d.name)
  : [];

// Páginas top-level (excluye api/ y admin/)
const topPages = existsSync(pagesDir)
  ? readdirSync(pagesDir, { withFileTypes: true })
      .filter(d => !d.isDirectory() && d.name.endsWith('.astro'))
      .map(d => d.name.replace('.astro', ''))
      .filter(n => !['index','login','404'].includes(n))
  : [];

// Sub-páginas detectadas
const subPageDirs = existsSync(pagesDir)
  ? readdirSync(pagesDir, { withFileTypes: true })
      .filter(d => d.isDirectory() && !['api','admin'].includes(d.name))
      .map(d => d.name)
  : [];

const allJsons = existsSync(dataDir)
  ? readdirSync(dataDir).filter(f => f.endsWith('.json')).sort()
  : [];

// Leer nav.json si existe
let navItems: {label:string;href:string}[] = [];
const navPath = join(dataDir, 'nav.json');
if (existsSync(navPath)) {
  try { navItems = JSON.parse(readFileSync(navPath,'utf-8')).items ?? []; } catch {}
}

const ALLOWED_SAVE = ['now.json','books.json','homepage.json','gacha-config.json','nav.json'];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin · Stellar Terminal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Playfair+Display:wght@700&display=swap" />
  <link rel="stylesheet" href="/design-tokens.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --adm-bg:       #03030A;
      --adm-surface:  #080814;
      --adm-panel:    #EDE7DC;
      --adm-border:   rgba(255,107,157,0.1);
      --adm-border2:  rgba(255,107,157,0.2);
 --adm-acc: #D4A5A5;
      --adm-cyan:     #22D3EE;
      --adm-green:    #4ADE80;
      --adm-red:      #F87171;
      --adm-amber:    #FBBF24;
      --adm-ink:      #F1F5F9;
      --adm-muted:    #94A3B8;
      --adm-dimmed:   #475569;
      --adm-mono:     'JetBrains Mono', monospace;
    }
    html, body {
      background: var(--adm-bg);
      color: var(--adm-ink);
      font-family: var(--adm-mono);
      min-height: 100dvh;
      font-size: 13px;
      line-height: 1.5;
    }

    /* ── SHELL ─────────────────────────────────────────────── */
    .adm-shell {
      display: grid;
      grid-template-columns: 240px 1fr;
      grid-template-rows: 36px 1fr;
      min-height: 100dvh;
    }

    /* ── TITLEBAR ───────────────────────────────────────────── */
    .adm-titlebar {
      grid-column: 1 / -1;
      background: var(--adm-surface);
      border-bottom: 1px solid var(--adm-border);
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .adm-tb-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 0 16px;
      border-right: 1px solid var(--adm-border);
      height: 100%;
      min-width: 240px;
    }
    .adm-tb-logo-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--adm-acc);
      box-shadow: 0 0 8px rgba(255,107,157,.6);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%,100%{opacity:1;transform:scale(1)}
      50%{opacity:.5;transform:scale(.8)}
    }
    .adm-tb-title { font-size: 11px; font-weight: 500; color: var(--adm-ink); letter-spacing: .08em; }
    .adm-tb-sub   { font-size: 10px; color: var(--adm-dimmed); margin-left: 2px; }
    .adm-tb-menu  {
      display: flex;
      align-items: center;
      flex: 1;
      height: 100%;
      padding: 0 8px;
      gap: 2px;
    }
    .adm-tb-btn {
      font-family: var(--adm-mono);
      font-size: 10px;
      color: var(--adm-muted);
      background: none;
      border: none;
      padding: 0 10px;
      height: 100%;
      cursor: pointer;
      letter-spacing: .04em;
      transition: color .15s, background .15s;
      border-radius: 0;
    }
    .adm-tb-btn:hover { color: var(--adm-ink); background: rgba(255,255,255,.04); }
    .adm-tb-right {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 0 12px;
      border-left: 1px solid var(--adm-border);
      height: 100%;
    }
    .adm-tb-clock { font-size: 10px; color: var(--adm-dimmed); }
    .adm-tb-logout {
      font-family: var(--adm-mono);
      font-size: 10px;
      background: none;
      border: 1px solid rgba(248,113,113,.25);
      border-radius: 3px;
      padding: 2px 8px;
      color: rgba(248,113,113,.7);
      cursor: pointer;
      transition: all .15s;
    }
    .adm-tb-logout:hover { border-color: var(--adm-red); color: var(--adm-red); }

    /* ── SIDEBAR ────────────────────────────────────────────── */
    .adm-sidebar {
      background: var(--adm-surface);
      border-right: 1px solid var(--adm-border);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      overflow-x: hidden;
    }
    .adm-tree-section { padding: 12px 0 4px; }
    .adm-tree-label {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--adm-dimmed);
      padding: 0 12px 6px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .adm-tree-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--adm-border);
    }
    .adm-tree-item {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 5px 12px 5px 16px;
      cursor: pointer;
      color: var(--adm-muted);
      font-size: 11.5px;
      transition: color .12s, background .12s;
      border-left: 2px solid transparent;
      user-select: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      background: none;
      border-right: none;
      border-top: none;
      border-bottom: none;
      width: 100%;
      text-align: left;
      font-family: var(--adm-mono);
    }
    .adm-tree-item:hover { color: var(--adm-ink); background: rgba(255,255,255,.03); }
    .adm-tree-item.active {
      color: var(--adm-acc);
      border-left-color: var(--adm-acc);
      background: rgba(255,107,157,.07);
    }
    .adm-tree-icon {
      font-size: 11px;
      flex-shrink: 0;
      opacity: .7;
    }
    .adm-tree-item.active .adm-tree-icon { opacity: 1; }
    .adm-tree-badge {
      margin-left: auto;
      font-size: 9px;
      background: rgba(255,107,157,.15);
      border: 1px solid var(--adm-border2);
      border-radius: 3px;
      padding: 1px 5px;
      color: var(--adm-acc);
      flex-shrink: 0;
    }
    .adm-tree-badge.green { background: rgba(74,222,128,.12); border-color: rgba(74,222,128,.25); color: var(--adm-green); }
    .adm-tree-badge.amber { background: rgba(251,191,36,.12); border-color: rgba(251,191,36,.25); color: var(--adm-amber); }
    .adm-sb-footer {
      margin-top: auto;
      padding: 10px 12px;
      border-top: 1px solid var(--adm-border);
    }
    .adm-sb-version { font-size: 9px; color: var(--adm-dimmed); }

    /* ── WORKSPACE ──────────────────────────────────────────── */
    .adm-workspace {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Tab bar */
    .adm-tabs {
      display: flex;
      align-items: center;
      background: var(--adm-surface);
      border-bottom: 1px solid var(--adm-border);
      overflow-x: auto;
      scrollbar-width: none;
      min-height: 34px;
      flex-shrink: 0;
    }
    .adm-tabs::-webkit-scrollbar { display: none; }
    .adm-tab {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 14px;
      height: 34px;
      font-size: 11px;
      color: var(--adm-muted);
      cursor: pointer;
      border-right: 1px solid var(--adm-border);
      transition: color .15s, background .15s;
      white-space: nowrap;
      flex-shrink: 0;
      background: none;
      border-top: none;
      border-bottom: none;
      border-left: none;
      font-family: var(--adm-mono);
      position: relative;
    }
    .adm-tab:hover { color: var(--adm-ink); background: rgba(255,255,255,.03); }
    .adm-tab.active {
      color: var(--adm-ink);
      background: var(--adm-panel);
      border-bottom: 2px solid var(--adm-acc);
    }
    .adm-tab-close {
      font-size: 10px;
      opacity: 0;
      transition: opacity .15s;
      padding: 1px 2px;
      border-radius: 2px;
    }
    .adm-tab:hover .adm-tab-close,
    .adm-tab.active .adm-tab-close { opacity: .5; }
    .adm-tab-close:hover { opacity: 1 !important; background: rgba(255,255,255,.08); }
    .adm-tab-icon { font-size: 10px; }

    /* Content panels */
    .adm-panels {
      flex: 1;
      overflow-y: auto;
      background: var(--adm-panel);
      position: relative;
    }
    .adm-panel { display: none; height: 100%; }
    .adm-panel.active { display: flex; flex-direction: column; }
    .adm-panel-body {
      flex: 1;
      overflow-y: auto;
      padding: 24px 28px;
      max-width: 900px;
    }

    /* ── PANEL HEADER ───────────────────────────────────────── */
    .adm-ph {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--adm-border);
    }
    .adm-ph-icon {
      width: 40px; height: 40px;
      border-radius: 8px;
      background: rgba(255,107,157,.12);
      border: 1px solid var(--adm-border2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .adm-ph-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      color: var(--adm-ink);
      margin-bottom: 3px;
    }
    .adm-ph-text p { font-size: 11px; color: var(--adm-muted); }

    /* ── STATS GRID ─────────────────────────────────────────── */
    .adm-stats {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 10px;
      margin-bottom: 24px;
    }
    .adm-stat {
      background: rgba(255,255,255,.025);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
      padding: 14px;
      transition: border-color .15s;
    }
    .adm-stat:hover { border-color: var(--adm-border2); }
    .adm-stat-val {
      font-size: 26px;
      font-weight: 500;
      color: var(--adm-ink);
      line-height: 1;
      margin-bottom: 5px;
    }
    .adm-stat-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--adm-dimmed);
    }

    /* ── MODULE EXPLORER ────────────────────────────────────── */
    .adm-module-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px;
      margin-bottom: 24px;
    }
    .adm-mod-card {
      background: rgba(255,255,255,.02);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
      padding: 14px;
      cursor: pointer;
      transition: all .18s;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .adm-mod-card:hover {
      border-color: var(--adm-border2);
      background: rgba(255,107,157,.05);
      transform: translateY(-1px);
    }
    .adm-mod-top { display: flex; align-items: center; gap: 8px; }
    .adm-mod-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--adm-green); box-shadow: 0 0 6px rgba(74,222,128,.5); flex-shrink: 0; }
    .adm-mod-dot.new { background: var(--adm-amber); box-shadow: 0 0 6px rgba(251,191,36,.5); }
    .adm-mod-name { font-size: 12px; font-weight: 500; color: var(--adm-ink); }
    .adm-mod-path { font-size: 10px; color: var(--adm-dimmed); }
    .adm-mod-actions { display: flex; gap: 5px; flex-wrap: wrap; }
    .adm-mod-btn {
      font-size: 10px;
      font-family: var(--adm-mono);
      background: rgba(255,255,255,.04);
      border: 1px solid var(--adm-border);
      border-radius: 4px;
      padding: 2px 8px;
      color: var(--adm-muted);
      cursor: pointer;
      transition: all .12s;
      text-decoration: none;
    }
    .adm-mod-btn:hover { border-color: var(--adm-acc); color: var(--adm-acc); }

    /* ── SECTION TITLE ──────────────────────────────────────── */
    .adm-section {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--adm-dimmed);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .adm-section::after { content:''; flex:1; height:1px; background: var(--adm-border); }
    .adm-section-accent { color: var(--adm-acc); }

    /* ── UPLOAD ZONE ────────────────────────────────────────── */
    .adm-drop {
      border: 1.5px dashed rgba(255,107,157,.25);
      border-radius: 10px;
      transition: all .2s;
      margin-bottom: 16px;
    }
    .adm-drop.over { border-color: var(--adm-acc); background: rgba(255,107,157,.05); }
    .adm-drop-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 32px;
      cursor: pointer;
      text-align: center;
    }
    .adm-drop-icon { font-size: 28px; color: var(--adm-acc); opacity: .4; }
    .adm-drop-label { font-size: 13px; color: var(--adm-ink); }
    .adm-drop-hint { font-size: 10px; color: var(--adm-dimmed); }
    .adm-upload-form {
      padding: 20px;
      display: none;
      flex-direction: column;
      gap: 12px;
    }

    /* ── FIELD ──────────────────────────────────────────────── */
    .adm-field { display: flex; flex-direction: column; gap: 4px; }
    .adm-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--adm-dimmed);
    }
    .adm-input {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 6px;
      padding: 8px 12px;
      font-family: var(--adm-mono);
      font-size: 12px;
      color: var(--adm-ink);
      outline: none;
      transition: border-color .15s;
      width: 100%;
    }
    .adm-input:focus { border-color: var(--adm-acc); }
    .adm-input:disabled { opacity: .4; }
    .adm-input-sm {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 5px;
      padding: 5px 8px;
      font-family: var(--adm-mono);
      font-size: 11px;
      color: var(--adm-ink);
      outline: none;
      transition: border-color .15s;
    }
    .adm-input-sm:focus { border-color: var(--adm-acc); }
    .adm-input-sm:disabled { opacity: .4; }
    select.adm-input-sm { cursor: pointer; }
    .adm-textarea {
      background: rgba(0,0,0,.3);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 6px;
      padding: 12px;
      font-family: var(--adm-mono);
      font-size: 11.5px;
      color: var(--adm-ink);
      line-height: 1.6;
      outline: none;
      resize: vertical;
      width: 100%;
      tab-size: 2;
      min-height: 200px;
    }
    .adm-textarea:focus { border-color: rgba(255,107,157,.3); }

    /* ── BUTTONS ────────────────────────────────────────────── */
    .adm-btn {
      font-family: var(--adm-mono);
      font-size: 11px;
      border-radius: 6px;
      padding: 7px 14px;
      cursor: pointer;
      transition: all .15s;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      border: none;
      letter-spacing: .02em;
    }
    .adm-btn-primary { background: var(--adm-acc); color: #fff; }
    .adm-btn-primary:hover { opacity: .85; }
    .adm-btn-primary:disabled { opacity: .4; cursor: not-allowed; }
    .adm-btn-ghost { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); color: var(--adm-muted); }
    .adm-btn-ghost:hover { border-color: var(--adm-border2); color: var(--adm-acc); }
    .adm-btn-danger { background: rgba(248,113,113,.08); border: 1px solid rgba(248,113,113,.2); color: rgba(248,113,113,.7); }
    .adm-btn-danger:hover { border-color: var(--adm-red); color: var(--adm-red); }
    .adm-btn-xs {
      font-size: 10px;
      padding: 3px 8px;
      border-radius: 4px;
    }
    .adm-btn-row { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }

    /* ── PROGRESS ───────────────────────────────────────────── */
    .adm-prog-wrap { display: flex; align-items: center; gap: 10px; display: none; }
    .adm-prog-track { flex: 1; height: 2px; background: rgba(255,255,255,.06); border-radius: 2px; overflow: hidden; }
    .adm-prog-bar { height: 100%; background: var(--adm-acc); width: 0%; transition: width .1s; }
    .adm-prog-pct { font-size: 10px; color: var(--adm-muted); min-width: 30px; text-align: right; }

    /* ── VIDEO LIST ─────────────────────────────────────────── */
    .adm-vlist { display: flex; flex-direction: column; gap: 8px; }
    .adm-vcard {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: rgba(255,255,255,.02);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
      padding: 12px;
      transition: border-color .15s;
    }
    .adm-vcard:hover { border-color: var(--adm-border2); }
    .adm-vthumb {
      width: 110px;
      flex-shrink: 0;
      aspect-ratio: 16/9;
      border-radius: 6px;
      overflow: hidden;
      background: rgba(255,107,157,.06);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--adm-acc);
      font-size: 18px;
      opacity: .4;
    }
    .adm-vthumb img { width:100%; height:100%; object-fit:cover; display:block; opacity:1; }
    .adm-vbody { flex: 1; display: flex; flex-direction: column; gap: 7px; min-width: 0; }
    .adm-vrow { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
    .adm-vlink { font-size: 10px; color: var(--adm-dimmed); word-break: break-all; }

    /* ── JSON ITEM CARDS ────────────────────────────────────── */
    .adm-items { display: flex; flex-direction: column; gap: 6px; }
    .adm-item {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,.02);
      border: 1px solid var(--adm-border);
      border-radius: 7px;
      padding: 8px 10px;
      transition: border-color .15s;
    }
    .adm-item:hover { border-color: var(--adm-border2); }
    .adm-item.dragging { opacity: .35; border-style: dashed; }
    .adm-drag { color: var(--adm-dimmed); cursor: grab; flex-shrink: 0; font-size: 13px; user-select: none; }
    .adm-item-fields { display: flex; gap: 5px; flex: 1; align-items: center; flex-wrap: wrap; }
    .adm-badge {
      font-size: 10px;
      background: rgba(255,107,157,.1);
      border: 1px solid rgba(255,107,157,.2);
      border-radius: 4px;
      padding: 2px 6px;
      color: var(--adm-acc);
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* ── FORM GRID ──────────────────────────────────────────── */
    .adm-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @media(max-width:600px){ .adm-grid2 { grid-template-columns: 1fr; } }

    /* ── MODULE CREATOR ─────────────────────────────────────── */
    .adm-creator {
      background: rgba(255,255,255,.02);
      border: 1px solid var(--adm-border);
      border-radius: 10px;
      padding: 20px;
    }
    .adm-creator-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--adm-ink);
      margin-bottom: 16px;
    }
    .adm-file-tree {
      background: rgba(0,0,0,.2);
      border: 1px solid var(--adm-border);
      border-radius: 6px;
      padding: 12px;
      font-size: 11px;
      color: var(--adm-muted);
      line-height: 1.8;
      margin: 12px 0;
    }
    .adm-file-tree .dir  { color: var(--adm-cyan); }
    .adm-file-tree .file { color: var(--adm-green); }
    .adm-file-tree .new  { color: var(--adm-acc); }

    /* ── UNKNOWN JSON EDITOR ─────────────────────────────────── */
    .adm-kv-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
    .adm-kv-row {
      display: flex;
      gap: 6px;
      align-items: center;
      background: rgba(255,255,255,.02);
      border: 1px solid var(--adm-border);
      border-radius: 6px;
      padding: 6px 8px;
    }
    .adm-kv-key { flex: 1; min-width: 80px; }
    .adm-kv-val { flex: 3; }
    .adm-kv-type {
      font-size: 9px;
      color: var(--adm-dimmed);
      padding: 2px 6px;
      background: rgba(255,255,255,.04);
      border-radius: 3px;
      flex-shrink: 0;
    }

    /* ── TOAST ──────────────────────────────────────────────── */
    #adm-toasts {
      position: fixed;
      bottom: 16px;
      right: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      z-index: 9999;
    }
    .adm-toast {
      font-family: var(--adm-mono);
      font-size: 11px;
      padding: 8px 14px;
      border-radius: 6px;
      border: 1px solid;
      animation: toast-in .2s ease;
      max-width: 300px;
    }
    @keyframes toast-in { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    .adm-toast.ok  { background:#0a1f0e; border-color:rgba(74,222,128,.3); color:#86efac; }
    .adm-toast.err { background:#1f0a0a; border-color:rgba(248,113,113,.3); color:#fca5a5; }
    .adm-toast.inf { background:var(--color-surface); border-color:rgba(255,107,157,.3); color:var(--color-ink); }

    /* ── CMD PALETTE ────────────────────────────────────────── */
    #adm-palette-bg {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.7);
      z-index: 999;
      backdrop-filter: blur(4px);
    }
    #adm-palette-bg.open { display: flex; align-items: flex-start; justify-content: center; padding-top: 15vh; }
    #adm-palette {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border2);
      border-radius: 10px;
      width: 480px;
      max-width: 90vw;
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(0,0,0,.8);
    }
    #adm-palette-input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--adm-border);
      padding: 14px 16px;
      font-family: var(--adm-mono);
      font-size: 13px;
      color: var(--adm-ink);
      outline: none;
    }
    #adm-palette-input::placeholder { color: var(--adm-dimmed); }
    .adm-pal-items { max-height: 320px; overflow-y: auto; padding: 6px; }
    .adm-pal-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      border-radius: 6px;
      cursor: pointer;
      transition: background .1s;
      font-size: 12px;
      color: var(--adm-muted);
    }
    .adm-pal-item:hover, .adm-pal-item.sel { background: rgba(255,107,157,.1); color: var(--adm-ink); }
    .adm-pal-icon { font-size: 13px; width: 18px; text-align: center; }
    .adm-pal-label { flex: 1; }
    .adm-pal-kbd {
      font-size: 9px;
      background: rgba(255,255,255,.06);
      border-radius: 3px;
      padding: 1px 5px;
      color: var(--adm-dimmed);
    }
    .adm-pal-hint { font-size: 10px; padding: 8px 12px; color: var(--adm-dimmed); border-top: 1px solid var(--adm-border); }

    /* ── LOADING ─────────────────────────────────────────────── */
    .adm-loading { color: var(--adm-dimmed); font-size: 11px; padding: 20px 0; }

    /* ── GACHA CMDS ─────────────────────────────────────────── */
    .adm-cmd-list { display: flex; flex-direction: column; gap: 8px; }
    .adm-cmd {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      padding: 12px 14px;
      background: rgba(255,255,255,.02);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
    }
    .adm-cmd-name { font-size: 12px; font-weight: 500; color: var(--adm-ink); min-width: 120px; }
    .adm-cmd-code {
      font-size: 10px;
      color: var(--adm-muted);
      background: rgba(0,0,0,.25);
      padding: 4px 8px;
      border-radius: 4px;
      word-break: break-all;
      flex: 1;
    }

    /* ── SCROLLBAR ──────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,107,157,.2); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,107,157,.4); }

    /* ── RESPONSIVE ─────────────────────────────────────────── */
    @media(max-width:700px) {
      .adm-shell { grid-template-columns: 1fr; }
      .adm-sidebar { display: none; }
    }

    /* ── NAV EDITOR ─────────────────────────────────────────── */
    .adm-nav-preview {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      background: rgba(0,0,0,.2);
      border: 1px solid var(--adm-border);
      border-radius: 6px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
    .adm-nav-pill {
      font-size: 10px;
      padding: 2px 8px;
      border: 1px solid rgba(255,107,157,.2);
      border-radius: 100px;
      color: var(--adm-muted);
    }
    .adm-nav-pill.accent { border-color: var(--adm-acc); color: var(--adm-acc); }
  </style>
</head>
<body>
<div id="adm-toasts"></div>

<!-- ── CMD PALETTE ────────────────────────────────────── -->
