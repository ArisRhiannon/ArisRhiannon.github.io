// ── Command Palette ───────────────────────────────────────────
const paletteItems=[
  {icon:'⬡',label:'Overview',action:()=>openPanel('overview')},
  {icon:'▶',label:'Videos · subir y gestionar',action:()=>openPanel('videos','Videos','▶')},
  {icon:'+',label:'Nuevo módulo · generar estructura',action:()=>openPanel('new-module','Nuevo módulo','+')},
  {icon:'◈',label:'Gacha Sync · comandos',action:()=>openPanel('gacha','Gacha Sync','◈')},
  ...allJsons.map(f=>({icon:'✦',label:`JSON · ${f}`,action:()=>openPanel(`json-${f.replace('.json','')}`,f,'✦')})),
  ...[...featureModules,...subPageDirs.filter(d=>!featureModules.includes(d))].map(m=>({icon:'◈',label:`Módulo · ${m}`,action:()=>openPanel(`mod-${m}`,m,'◈')})),
];
let palSel=0;

function openPalette(){
  document.getElementById('adm-palette-bg').classList.add('open');
  document.getElementById('adm-palette-input').value='';
  renderPalette('');
  setTimeout(()=>document.getElementById('adm-palette-input').focus(),50);
}
function closePalette(){document.getElementById('adm-palette-bg').classList.remove('open');}
function renderPalette(q){
  palSel=0;
  const items=q?paletteItems.filter(i=>i.label.toLowerCase().includes(q.toLowerCase())):paletteItems;
  const container=document.getElementById('adm-pal-items');
  container.innerHTML=items.slice(0,10).map((i,idx)=>`
    <div class="adm-pal-item${idx===0?' sel':''}" data-idx="${idx}">
      <span class="adm-pal-icon">${i.icon}</span>
      <span class="adm-pal-label">${i.label}</span>
    </div>`).join('');
  container.querySelectorAll('.adm-pal-item').forEach((el,idx)=>{
    el.addEventListener('click',()=>{paletteItems.find(i=>i.label===el.querySelector('.adm-pal-label').textContent)?.action();closePalette();});
    el.addEventListener('mouseover',()=>{
      container.querySelectorAll('.adm-pal-item').forEach(e=>e.classList.remove('sel'));
      el.classList.add('sel'); palSel=idx;
    });
  });
}
document.getElementById('adm-palette-input').addEventListener('input',e=>renderPalette(e.target.value));
document.getElementById('adm-palette-input').addEventListener('keydown',e=>{
  const items=document.querySelectorAll('.adm-pal-item');
  if(e.key==='ArrowDown'){e.preventDefault();palSel=Math.min(palSel+1,items.length-1);}
  else if(e.key==='ArrowUp'){e.preventDefault();palSel=Math.max(palSel-1,0);}
  else if(e.key==='Enter'){items[palSel]?.click();closePalette();return;}
  else if(e.key==='Escape'){closePalette();return;}
  items.forEach((el,i)=>el.classList.toggle('sel',i===palSel));
  items[palSel]?.scrollIntoView({block:'nearest'});
});
document.getElementById('adm-palette-bg').addEventListener('click',e=>{if(e.target===e.currentTarget)closePalette();});
document.addEventListener('keydown',e=>{if((e.ctrlKey||e.metaKey)&&e.key==='k'){e.preventDefault();openPalette();}});
</script>
