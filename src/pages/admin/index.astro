<script define:vars={{ allJsons, featureModules, subPageDirs, topPages, navItems, ALLOWED_SAVE }}>
// ══════════════════════════════════════════════════════════════
// STELLAR TERMINAL ADMIN v2
// ══════════════════════════════════════════════════════════════

// ── Toasts ────────────────────────────────────────────────────
function toast(msg, type='inf', ms=3000) {
  const el = document.createElement('div');
  el.className = `adm-toast ${type}`;
  el.textContent = msg;
  document.getElementById('adm-toasts').appendChild(el);
  setTimeout(() => el.remove(), ms);
}

// ── Clock ─────────────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  document.getElementById('adm-clock').textContent =
    now.toLocaleTimeString('es-MX', {hour:'2-digit',minute:'2-digit'});
}
updateClock(); setInterval(updateClock, 10000);

// ── Logout ────────────────────────────────────────────────────
document.getElementById('adm-logout').addEventListener('click', async () => {
  await fetch('/api/auth/logout', { method:'POST' });
  location.href = '/admin/login';
});

// ── Tab / Panel system ────────────────────────────────────────
const openTabs = new Map(); // panelId → tab el

function openPanel(id, label=null, icon='✦') {
  ensurePanelExists(id, label, icon);
  // Activate tab
  document.querySelectorAll('.adm-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.adm-tree-item').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.adm-panel').forEach(p => p.classList.remove('active'));

  const tab = openTabs.get(id);
  if (tab) tab.classList.add('active');
  const treeItem = document.querySelector(`.adm-tree-item[data-panel="${id}"]`);
  if (treeItem) treeItem.classList.add('active');
  const panel = document.getElementById(`panel-${id}`);
  if (panel) panel.classList.add('active');

  // Side effects
  if (id === 'videos') loadVideos();
  if (id === 'gacha')  loadGachaSync();
  if (id.startsWith('json-')) loadJsonPanel(id.replace('json-','') + '.json');
  if (id.startsWith('mod-'))  renderModulePanel(id.replace('mod-',''));
}

function ensurePanelExists(id, label, icon) {
  if (openTabs.has(id)) return;
  // Create tab
  const tab = document.createElement('button');
  tab.className = 'adm-tab';
  tab.dataset.panel = id;
  tab.innerHTML = `<span class="adm-tab-icon">${icon}</span> ${label ?? humanize(id)} <span class="adm-tab-close" data-close="${id}">×</span>`;
  tab.addEventListener('click', (e) => {
    if (e.target.dataset.close) { closeTab(e.target.dataset.close); return; }
    openPanel(id, label, icon);
  });
  document.getElementById('adm-tabs').appendChild(tab);
  openTabs.set(id, tab);

  // Create panel if not in DOM
  if (!document.getElementById(`panel-${id}`)) {
    const panel = document.createElement('div');
    panel.className = 'adm-panel';
    panel.id = `panel-${id}`;
    document.getElementById('adm-panels').appendChild(panel);
  }
}

function closeTab(id) {
  if (id === 'overview') return; // can't close overview
  const tab = openTabs.get(id);
  if (tab) tab.remove();
  openTabs.delete(id);
  const panel = document.getElementById(`panel-${id}`);
  if (panel && !['overview','videos','gacha','new-module'].includes(id)) panel.remove();
  openPanel('overview');
}

function humanize(id) {
  return id.replace('json-','').replace('mod-','').replace(/-/g,' ');
}

// Wire sidebar tree items
document.querySelectorAll('.adm-tree-item').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = btn.dataset.panel;
    const label = btn.querySelector(':not(.adm-tree-icon):not(.adm-tree-badge)')?.textContent?.trim();
    openPanel(id, label);
  });
});

// Initialize overview tab
