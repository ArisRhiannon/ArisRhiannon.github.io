  selFile=null;dropInner.style.display='flex';uploadForm.style.display='none';fileInput.value='';
});
document.getElementById('adm-add-desc')?.addEventListener('click',()=>{
  const list=document.getElementById('adm-desc-list');
  const row=document.createElement('div');
  row.style.cssText='display:flex;gap:5px;align-items:center';
  row.innerHTML=`<input class="adm-input-sm desc-key" placeholder="clave" style="flex:1"/><input class="adm-input-sm desc-val" placeholder="valor" style="flex:2"/><button class="adm-btn adm-btn-danger adm-btn-xs" onclick="this.parentElement.remove()">✕</button>`;
  list.appendChild(row);
});
document.getElementById('adm-upload-submit')?.addEventListener('click',async()=>{
  if(!selFile)return;
  const title=document.getElementById('uf-title').value||selFile.name;
  const category=document.getElementById('uf-category').value||'general';
  const descriptors={};
  document.querySelectorAll('.desc-key').forEach((k,i)=>{
    const v=document.querySelectorAll('.desc-val')[i]?.value?.trim();
    if(k.value.trim()&&v)descriptors[k.value.trim()]=v;
  });
  const fd=new FormData();
  fd.append('video',selFile);fd.append('title',title);fd.append('category',category);fd.append('descriptors',JSON.stringify(descriptors));
  const prog=document.getElementById('adm-prog-wrap');
  const bar=document.getElementById('adm-prog-bar');
  const pct=document.getElementById('adm-prog-pct');
  prog.style.display='flex';
  const btn=document.getElementById('adm-upload-submit'); btn.disabled=true;
  const xhr=new XMLHttpRequest();
  xhr.upload.addEventListener('progress',e=>{
    if(e.lengthComputable){const p=Math.round(e.loaded/e.total*100);bar.style.width=p+'%';pct.textContent=p+'%';}
  });
  xhr.addEventListener('load',()=>{
    prog.style.display='none';btn.disabled=false;
    try{
      const res=JSON.parse(xhr.responseText);
      if(res.ok){
        toast(`✓ Video subido · /v/${res.id}`+(res.thumbnail?' · thumb generado':''),'ok',5000);
        dropInner.style.display='flex';uploadForm.style.display='none';selFile=null;fileInput.value='';
        videosLoaded=false; loadVideos();
      } else toast(`Error: ${res.error}`,'err');
    }catch{toast('Error inesperado','err');}
  });
  xhr.open('POST','/api/videos/upload');xhr.send(fd);
});

// ── Gacha Sync ────────────────────────────────────────────────
async function loadGachaSync() {
  const list=document.getElementById('adm-cmd-list');
  if(!jsonCache['gacha-config.json']){
    const res=await fetch('/api/admin/data?file=gacha-config.json');
    jsonCache['gacha-config.json']=res.ok?await res.json():null;
  }
  const data=jsonCache['gacha-config.json'];
  if(!data?.games?.length){list.innerHTML='<p class="adm-loading">Sin juegos en gacha-config.json</p>';return;}
  list.innerHTML=data.games.map(g=>`
    <div class="adm-cmd">
      <span class="adm-cmd-name">${g.icon??'◈'} ${g.name}</span>
      <code class="adm-cmd-code">docker exec web bun run scripts/sync-enka-${g.id}.ts</code>
      <button class="adm-btn adm-btn-ghost adm-btn-xs" onclick="navigator.clipboard?.writeText('docker exec web bun run scripts/sync-enka-${g.id}.ts');toast('Copiado','inf')">copiar</button>
    </div>`).join('');
}

// ── Nuevo módulo generator ────────────────────────────────────
document.getElementById('nm-preview-btn')?.addEventListener('click',()=>{
  const name=document.getElementById('nm-name').value.trim().toLowerCase().replace(/\s+/g,'-');
  const type=document.getElementById('nm-type').value;
  if(!name){toast('Escribe un nombre primero','err');return;}
  const preview=document.getElementById('nm-preview');
  preview.style.display='block';
  const files=[];
  if(type==='json'||type==='api'){
    files.push(`<span class="dir">data/</span>  <span class="new">${name}.json</span>  ← datos del módulo`);
  }
  files.push(`<span class="dir">src/features/${name}/</span>`);
  files.push(`  <span class="new">${capitalize(name)}Grid.astro</span>  ← componente principal`);
  files.push(`<span class="dir">src/pages/</span>  <span class="new">${name}.astro</span>  ← página /'+name`);
  if(type==='api'||type==='sqlite'){
    files.push(`<span class="dir">src/pages/api/</span>  <span class="new">${name}.ts</span>  ← endpoint GET`);
  }
  preview.innerHTML=files.join('\n');
  document.getElementById('nm-gen-btn').disabled=false;
});

document.getElementById('nm-gen-btn')?.addEventListener('click',()=>{
  const name=document.getElementById('nm-name').value.trim().toLowerCase().replace(/\s+/g,'-');
  const type=document.getElementById('nm-type').value;
  const desc=document.getElementById('nm-desc').value.trim();
  if(!name)return;
  const cap=capitalize(name);
  let script=`cat > ~/apply_${name}.py << 'HEREDOC_END'\nimport os\nBASE=os.path.expanduser('~/misitio')\ndef w(path,txt):\n    full=os.path.join(BASE,path)\n    os.makedirs(os.path.dirname(full),exist_ok=True)\n    open(full,'w',encoding='utf-8').write(txt)\n    print(f'# {full}')\n\n`;
  if(type==='json'||type==='api'){
    script+=`w('data/${name}.json', '[]')\n\n`;
  }
  script+=`w('src/features/${name}/${cap}Grid.astro', """---\n---\n<div id="${name}-root">\n  <p style="color:var(--color-muted-2);font-family:var(--font-mono);font-size:.8rem"><!-- ${cap} component here --></p>\n</div>\n<script>\ndocument.addEventListener('astro:page-load',()=>{\n  const root=document.getElementById('${name}-root');\n  if(!root)return;\n  // init logic here\n});\n<\/script>\n""")\n\n`;
  script+=`w('src/pages/${name}.astro', """---\nimport Base from '../layouts/Base.astro';\nimport ${cap}Grid from '../features/${name}/${cap}Grid.astro';\n---\n<Base title="${name} — aris">\n  <main style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem 5rem">\n    <header style="margin-bottom:2.5rem">\n      <h1 style="font-family:var(--font-display);font-size:clamp(2rem,5vw,4rem);color:var(--color-ink)">\n        <span style="color:var(--color-accent);opacity:.6">[</span>${name}<span style="color:var(--color-accent);opacity:.6">]</span>\n      </h1>\n      <p style="font-family:var(--font-body);font-size:.9rem;color:var(--color-muted-2);font-style:italic">${desc||'descripción del módulo'}</p>\n    </header>\n    <${cap}Grid />\n  </main>\n</Base>\n""")\n\n`;
  if(type==='api'){
    script+=`w('src/pages/api/${name}.ts', """import type { APIRoute } from 'astro';\nimport { readFileSync } from 'fs';\nimport { join } from 'path';\nexport const GET: APIRoute = () => {\n  const data = JSON.parse(readFileSync(join(process.cwd(),'data/${name}.json'),'utf-8'));\n  return new Response(JSON.stringify({items:data}),{\n    headers:{'Content-Type':'application/json'},\n  });\n};\n""")\n\n`;
  }
  script+=`print('# Listo. Editar nav.json para añadir /${name} al nav.')\nprint('cd ~/misitio && sudo docker compose up -d --build')\nHEREDOC_END\npython3 ~/apply_${name}.py`;
  document.getElementById('nm-output').style.display='block';
  document.getElementById('nm-script').value=script;
  toast(`Script para "${name}" generado — cópialo y pégalo en la VM`,'ok',5000);
});

function capitalize(s){return s.charAt(0).toUpperCase()+s.slice(1);}

