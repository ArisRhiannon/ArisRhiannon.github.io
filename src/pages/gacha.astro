---
import Base from "../layouts/Base.astro";
import GachaGrid from "../features/gacha/GachaGrid.astro";
import { readFileSync } from "fs";
import { join } from "path";

const config = JSON.parse(readFileSync(join(process.cwd(), "data", "gacha-config.json"), "utf-8"));
---

<Base title="Gacha · aris-sama">
  <main class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="font-mono text-2xl text-[var(--color-accent)]">GACHA ROSTER</h1>
      <p class="text-[var(--color-muted)] text-sm mt-1">
        Personajes desbloqueados — histórico completo
      </p>
    </header>

    <GachaGrid games={config.games} />
  </main>
</Base>