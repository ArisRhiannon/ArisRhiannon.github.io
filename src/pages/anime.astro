---
import Base from '../layouts/Base.astro';
import AnimeGrid from '../features/anime/AnimeGrid.astro';
---

<Base title="anime — aris" description="lista de anime de aris-sama">

  <section class="page-hero">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
    </div>
    <div class="page-hero-content">
      <div class="hero-chip">anilist · GoddamnBernkastel</div>
      <h1 class="hero-title">
        <span class="hero-bracket">[</span>anime<span class="hero-bracket">]</span>
      </h1>
      <p class="hero-sub">mi lista personal de anime.</p>
    </div>
  </section>

  <section class="anime-page">
    <AnimeGrid />
  </section>

</Base>

<style>
  .page-hero {
    position: relative;
    padding: var(--space-20) var(--space-8) var(--space-12);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    width: 400px; height: 400px;
    top: -100px; right: 10%;
    background: radial-gradient(circle, rgba(196,181,253,0.15) 0%, transparent 70%);
    filter: blur(40px);
  }

  .page-hero-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-chip {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.10em;
    color: var(--color-lavender);
    background: rgba(196,181,253,0.08);
    border: 1px solid rgba(196,181,253,0.20);
    padding: 4px 14px;
    border-radius: var(--radius-full);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-bracket {
    color: var(--color-lavender);
    opacity: 0.6;
    text-shadow: var(--glow-lavender);
  }

  .hero-sub {
    font-size: var(--text-sm);
    color: var(--color-muted);
    font-style: italic;
  }

  .anime-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-20);
  }

  @media (max-width: 768px) {
    .page-hero { padding: var(--space-12) var(--space-4) var(--space-8); }
    .hero-title { font-size: var(--text-4xl); }
    .anime-page { padding: 0 var(--space-4) var(--space-12); }
  }
</style>
