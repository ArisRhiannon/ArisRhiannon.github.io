---
import Base from '../layouts/Base.astro';
import AnimeGrid from '../features/anime/AnimeGrid.astro';
---
<Base title="anime — aris" description="lista de anime de aris-sama">
  <main style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem 5rem">
    <header style="margin-bottom:2.5rem">
      <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem">
        <span style="display:block;width:32px;height:1px;background:var(--color-accent);opacity:.7"></span>
        <span style="font-family:var(--font-mono);font-size:.65rem;letter-spacing:.15em;color:var(--color-muted);text-transform:uppercase">anilist · GoddamnBernkastel</span>
      </div>
      <h1 style="font-family:var(--font-display);font-size:clamp(2.5rem,6vw,4.5rem);color:var(--color-ink);font-weight:700;line-height:1;margin:0 0 .5rem">
        <span style="color:var(--color-accent);opacity:.6">[</span>anime<span style="color:var(--color-accent);opacity:.6">]</span>
      </h1>
      <p style="font-family:var(--font-body);font-size:.9rem;color:var(--color-muted-2);font-style:italic;margin:0">mi lista personal de anime.</p>
    </header>
    <AnimeGrid />
  </main>
</Base>
