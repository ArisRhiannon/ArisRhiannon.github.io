---
import Base from '../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

const homepage = JSON.parse(readFileSync(join(process.cwd(), 'data', 'homepage.json'), 'utf-8'));
const nowData  = JSON.parse(readFileSync(join(process.cwd(), 'data', 'now.json'), 'utf-8'));

const heroBlock  = homepage.blocks.find((b: any) => b.type === 'hero');
const nowPreview = homepage.blocks.find((b: any) => b.type === 'now_preview');
const nowItems   = nowPreview ? nowData.items.slice(0, nowPreview.limit ?? 4) : [];
---

<Base title="aris-sama" description={heroBlock?.subtitle}>

  <!-- ── BANNER ── -->
  <div class="page-banner" aria-hidden="true">
    <div class="banner-glow"></div>
    <div class="banner-content">
      <div class="banner-face">(◍•ᴗ•◍)</div>
      <div class="banner-title-wrap">
        <h1 class="banner-name">{heroBlock?.title ?? 'Aris'}</h1>
        <p class="banner-sub">{heroBlock?.subtitle ?? 'colecciono nitos'}</p>
      </div>
    </div>
    <div class="banner-shimmer"></div>
  </div>

  <!-- ── acción CTA ── -->
  {heroBlock?.cta && (
    <div class="hero-cta-wrap">
      <a href={heroBlock.cta.href} class="hero-cta">
        {heroBlock.cta.label}
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
      <span class="hero-sub-info">online · gdl.mx</span>
    </div>
  )}

  <!-- ── qué estoy haciendo ── -->
  {nowItems.length > 0 && (
    <section class="status-section">
      <div class="status-header">
        <h2 class="status-title">qué estoy haciendo</h2>
        <a href="/now" class="status-ver-todo">ver todo →</a>
      </div>
      <ul class="status-list" role="list">
        {nowItems.map(item => (
          <li class="status-item">
            <div class="status-item-icon" aria-hidden="true">{item.icon}</div>
            <div class="status-item-body">
              <span class="status-item-cat">{item.category}</span>
              <p class="status-item-text">{item.text}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

</Base>

<style>
  /* ── BANNER ── */
  .page-banner {
    position: relative;
    width: calc(100% + var(--space-8) * 2);
    margin: calc(-1 * var(--space-8)) calc(-1 * var(--space-8)) var(--space-8);
    height: 220px;
    background:
      linear-gradient(160deg,
        #F2B8C6 0%,
        #F5C4D0 35%,
        #F8D4DC 65%,
        #FCE6EC 100%
      );
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .banner-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 20% 40%, rgba(255,255,255,0.45) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 80% 60%, rgba(255,140,180,0.35) 0%, transparent 55%);
    pointer-events: none;
  }

  .banner-shimmer {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent 0px,
      transparent 28px,
      rgba(255,255,255,0.08) 28px,
      rgba(255,255,255,0.08) 30px
    );
    pointer-events: none;
  }

  .banner-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    gap: var(--space-5);
    padding: var(--space-6) var(--space-8);
  }

  .banner-face {
    font-family: var(--font-mono);
    font-size: 28px;
    color: rgba(255,255,255,0.9);
    line-height: 1;
    text-shadow: 0 2px 12px rgba(180,40,80,0.25);
    flex-shrink: 0;
    margin-bottom: 4px;
  }

  .banner-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .banner-name {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 20px rgba(180,40,80,0.3);
  }

  .banner-sub {
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.04em;
  }

  /* ── CTA ── */
  .hero-cta-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: #fff;
    background: var(--color-accent);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    text-decoration: none;
    box-shadow: var(--glow-sm);
    transition:
      background var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out);
  }

  .hero-cta:hover {
    background: var(--color-accent-2);
    box-shadow: var(--glow-md);
    transform: translateY(-1px);
  }

  .cta-arrow {
    font-size: 14px;
    transition: transform var(--duration) var(--ease-out);
  }

  .hero-cta:hover .cta-arrow { transform: translateX(3px); }

  .hero-sub-info {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* ── SECCIÓN STATUS ── */
  .status-section {
    margin-bottom: var(--space-12);
    max-width: 860px;   /* ancho cómodo pero arranca desde la izquierda */
  }

  .status-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .status-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .status-ver-todo {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: opacity var(--duration);
  }

  .status-ver-todo:hover { opacity: 0.7; }

  .status-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(8px);
    transition:
      background var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  .status-item:hover {
    background: var(--color-surface-2);
    border-color: rgba(212, 68, 122, 0.18);
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
  }

  .status-item-icon {
    font-size: var(--text-2xl);
    flex-shrink: 0;
    line-height: 1;
  }

  .status-item-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .status-item-cat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: lowercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    font-weight: 700;
  }

  .status-item-text {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.4;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 720px) {
    .page-banner {
      width: calc(100% + var(--space-4) * 2);
      margin: calc(-1 * var(--space-4)) calc(-1 * var(--space-4)) var(--space-6);
      height: 160px;
    }

    .banner-name { font-size: 2.2rem; }
    .banner-face { font-size: 20px; }
    .banner-content { padding: var(--space-4) var(--space-4); }
  }
</style>
