  .compose-publish {
    background: rgba(255,107,157,0.10);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    padding: 8px 24px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    cursor: pointer;
    letter-spacing: 0.08em;
    transition: all var(--duration) var(--ease-out);
  }

  .compose-publish:hover {
    background: rgba(255,107,157,0.15);
    box-shadow: var(--glow-sm);
  }

  .compose-publish:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ═══ PROFILE PANEL ═══ */
  .profile-panel {
    position: fixed;
    inset: 0;
    z-index: 9300;
    display: flex;
    justify-content: flex-end;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s var(--ease-out);
  }

  .profile-panel.active {
    opacity: 1;
    pointer-events: all;
  }

  .profile-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 21, 32, 0.80);
    backdrop-filter: blur(16px);
  }

  .profile-sidebar {
    position: relative;
    z-index: 1;
    width: min(300px, 85vw);
    height: 100%;
    background: var(--color-bg-2);
    border-left: 1px solid var(--color-border);
    padding: var(--space-6);
    transform: translateX(100%);
    transition: transform 0.35s var(--ease-out);
    display: flex;
    flex-direction: column;
  }

  .profile-panel.active .profile-sidebar {
    transform: translateX(0);
  }

  .profile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .profile-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .profile-close {
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 14px;
    cursor: pointer;
  }

  .profile-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .profile-pfp-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .profile-pfp {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--color-border-accent);
    box-shadow: var(--glow-sm);
    object-fit: cover;
  }

  .pfp-change {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 3px 10px;
    cursor: pointer;
    transition: all var(--duration) var(--ease-out);
  }

  .pfp-change:hover {
    border-color: var(--color-border-accent);
    color: var(--color-accent);
  }

  .profile-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .profile-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted-2);
  }

  .profile-input {
    background: rgba(255,245,250,0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink);
    outline: none;
    transition: border-color var(--duration);
  }

  .profile-input:focus {
    border-color: var(--color-accent);
  }

  .profile-save {
    background: rgba(255,107,157,0.10);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    padding: 8px 20px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    cursor: pointer;
    letter-spacing: 0.08em;
    transition: all var(--duration) var(--ease-out);
  }

  .profile-save:hover {
    background: rgba(255,107,157,0.15);
    box-shadow: var(--glow-sm);
  }

  .profile-footer {
    margin-top: auto;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .profile-logout {
    width: 100%;
    background: rgba(248,113,113,0.06);
    border: 1px solid rgba(248,113,113,0.15);
    border-radius: var(--radius-md);
    padding: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: rgba(248,113,113,0.6);
    cursor: pointer;
    transition: all var(--duration) var(--ease-out);
  }

  .profile-logout:hover {
    border-color: rgba(248,113,113,0.3);
    color: rgba(248,113,113,0.9);
  }

  /* ═══ MOBILE ═══ */
  @media (max-width: 768px) {
    .feed-page { padding: var(--space-12) var(--space-4) var(--space-8); }
    .hero-name { font-size: var(--text-5xl); }
    .hero-kaomoji { font-size: 36px; }
    .fab-group { bottom: var(--space-4); right: var(--space-4); }
    .login-trigger { bottom: var(--space-4); right: var(--space-4); }
  }
</style>

<script>
 // ── Feed Client Logic ──────────────────────────────────────
 let __feedInit = false;

 document.addEventListener('astro:after-swap', () => {
   __feedInit = false;
 });

 function initFeedClient() {
   if (__feedInit) return;
   __feedInit = true;

   // ── TAB SWITCHER ──
   const tabButtons = document.querySelectorAll('.home-tab-switcher .tab-btn');
   const tabContents = document.querySelectorAll('.tab-content');
   
   tabButtons.forEach(btn => {
     btn.addEventListener('click', () => {
       const targetTab = btn.getAttribute('data-tab');
       
       tabButtons.forEach(b => b.classList.remove('active'));
       btn.classList.add('active');
       
       tabContents.forEach(tc => {
         (tc as HTMLElement).style.display = 'none';
         tc.classList.remove('active');
       });
       
       const activeContent = document.getElementById(`tab-${targetTab}`);
       if (activeContent) {
         activeContent.style.display = 'block';
         activeContent.classList.add('active');
       }
     });
   });

    // ── LOGIN MODAL ──
    const loginTrigger = document.getElementById('login-trigger');
    const loginModal = document.getElementById('login-modal');
    const loginClose = document.getElementById('login-close');
    const loginSubmit = document.getElementById('login-submit');
    const loginPassword = document.getElementById('login-password') as HTMLInputElement;
    const loginError = document.getElementById('login-error');

    loginTrigger?.addEventListener('click', () => {
      loginModal?.classList.add('active');
      loginModal?.setAttribute('aria-hidden', 'false');
      setTimeout(() => loginPassword?.focus(), 100);
    });

    loginClose?.addEventListener('click', closeLoginModal);
    loginModal?.querySelector('.login-backdrop')?.addEventListener('click', closeLoginModal);

    function closeLoginModal() {
      loginModal?.classList.remove('active');
      loginModal?.setAttribute('aria-hidden', 'true');
      if (loginPassword) loginPassword.value = '';
      if (loginError) loginError.textContent = '';
    }

    loginSubmit?.addEventListener('click', async () => {
      const pwd = loginPassword?.value;
      if (!pwd) return;
      loginSubmit.textContent = '...';
      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: pwd }),
        });
        if (res.ok) {
          // Reload to show authenticated UI
          location.reload();
        } else {
          if (loginError) loginError.textContent = 'contraseña incorrecta';
          loginSubmit.textContent = 'entrar';
        }
      } catch {
        if (loginError) loginError.textContent = 'error de conexion';
        loginSubmit.textContent = 'entrar';
      }
    });

    loginPassword?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') loginSubmit?.click();
    });

    // ── COMPOSE DRAWER ──
    const fabCompose = document.getElementById('fab-compose');
    const composeDrawer = document.getElementById('compose-drawer');
    const composeClose = document.getElementById('compose-close');
    const composeText = document.getElementById('compose-text') as HTMLTextAreaElement;
    const composePublish = document.getElementById('compose-publish');
    const composePreviews = document.getElementById('compose-previews');
    const composePin = document.getElementById('compose-pin') as HTMLInputElement;
    const composeProgress = document.getElementById('compose-progress');
    const composeProgBar = document.getElementById('compose-prog-bar');
    const moodToggle = document.getElementById('mood-toggle');
    const moodPicker = document.getElementById('mood-picker');

    let pendingMedia: any[] = [];
    let selectedMood: string | null = null;

    fabCompose?.addEventListener('click', () => {
      composeDrawer?.classList.add('active');
      composeDrawer?.setAttribute('aria-hidden', 'false');
      setTimeout(() => composeText?.focus(), 200);
    });

    composeClose?.addEventListener('click', closeCompose);
    composeDrawer?.querySelector('.compose-backdrop')?.addEventListener('click', closeCompose);

    function closeCompose() {
      composeDrawer?.classList.remove('active');
      composeDrawer?.setAttribute('aria-hidden', 'true');
    }

    // Mood picker
    moodToggle?.addEventListener('click', () => {
      moodPicker?.classList.toggle('open');
    });

    moodPicker?.querySelectorAll('.mood-opt').forEach((btn) => {
      btn.addEventListener('click', () => {
        const mood = (btn as HTMLElement).dataset.mood ?? null;
        selectedMood = mood || null;
        if (moodToggle) moodToggle.textContent = mood || '✨';
        moodPicker?.classList.remove('open');
      });
    });

    // Upload buttons
    document.querySelectorAll('.compose-tool[data-upload]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const type = (btn as HTMLElement).dataset.upload;
        const input = document.createElement('input');
        input.type = 'file';
        if (type === 'image') input.accept = 'image/*';
        else if (type === 'video') input.accept = 'video/*';
        else input.accept = '.pdf,.doc,.docx,.xls,.xlsx,.txt,.csv';
        input.onchange = () => handleFileUpload(input.files?.[0]);
        input.click();
      });
    });

    async function handleFileUpload(file?: File) {
      if (!file) return;
      const fd = new FormData();
      fd.append('file', file);

      if (composeProgress) composeProgress.classList.add('active');
      if (composeProgBar) composeProgBar.style.width = '10%';

      try {
        const res = await fetch('/api/feed/upload', {
          method: 'POST',
          body: fd,
          credentials: 'same-origin',
        });

        if (composeProgress) composeProgress.classList.remove('active');

        // Leer como texto primero para debug
        const text = await res.text();
        let data: any;
        try {
          data = JSON.parse(text);
        } catch {
          showComposeError('respuesta inválida del servidor (HTTP ' + res.status + ')');
          return;
        }

        if (data.ok && data.media) {
          pendingMedia.push(data.media);
          renderPreviews();
        } else {
          showComposeError(data.error ?? 'error al subir (HTTP ' + res.status + ')');
        }
      } catch (err: any) {
        if (composeProgress) composeProgress.classList.remove('active');
        // Mostrar el tipo de error real
        const msg = err?.message || err?.toString() || 'error desconocido';
        showComposeError('error de red: ' + msg);
      }
    }

    function showComposeError(msg: string) {
      const el = document.getElementById('compose-error');
      if (el) {
        el.textContent = msg;
        el.style.display = 'block';
        setTimeout(() => { el.style.display = 'none'; }, 4000);
      }
    }

    function renderPreviews() {
      if (!composePreviews) return;
      composePreviews.innerHTML = pendingMedia.map((m, i) => {
        if (m.type === 'image') return `<div class="preview-thumb"><img src="${m.thumb ?? m.url}" /><button class="preview-remove" data-idx="${i}">✕</button></div>`;
        if (m.type === 'video') return `<div class="preview-thumb">${m.thumb ? `<img src="${m.thumb}" />` : '<span>🎬</span>'}<button class="preview-remove" data-idx="${i}">✕</button></div>`;
        return `<div class="preview-thumb"><span>📄</span><button class="preview-remove" data-idx="${i}">✕</button></div>`;
      }).join('');

      composePreviews.querySelectorAll('.preview-remove').forEach((btn) => {
        btn.addEventListener('click', () => {
          pendingMedia.splice(parseInt((btn as HTMLElement).dataset.idx ?? '0'), 1);
          renderPreviews();
        });
      });
    }

    // Publish
    composePublish?.addEventListener('click', async () => {
      const body = composeText?.value?.trim();
      if (!body && pendingMedia.length === 0) return;

      composePublish.textContent = '...';
      (composePublish as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch('/api/feed/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            body: body ?? '',
            media: pendingMedia,
            mood: selectedMood,
            pinned: composePin?.checked ?? false,
          }),
        });

        const data = await res.json();
        if (data.ok) {
          composePublish.textContent = '✓';
          setTimeout(() => location.reload(), 500);
        } else {
          composePublish.textContent = 'error';
          showComposeError(data.error ?? 'error al publicar');
          setTimeout(() => { composePublish.textContent = 'publicar →'; (composePublish as HTMLButtonElement).disabled = false; }, 2000);
        }
      } catch {
        composePublish.textContent = 'error';
        showComposeError('error de red');
        setTimeout(() => { composePublish.textContent = 'publicar →'; (composePublish as HTMLButtonElement).disabled = false; }, 2000);
      }
    });

    // ── PROFILE PANEL ──
    const fabProfile = document.getElementById('fab-profile');
    const profilePanel = document.getElementById('profile-panel');
    const profileClose = document.getElementById('profile-close');
    const profileSave = document.getElementById('profile-save');
    const pfpChange = document.getElementById('pfp-change');
    const pfpInput = document.getElementById('pfp-input') as HTMLInputElement;

    fabProfile?.addEventListener('click', () => {
      profilePanel?.classList.add('active');
      profilePanel?.setAttribute('aria-hidden', 'false');
    });

    profileClose?.addEventListener('click', closeProfilePanel);
    profilePanel?.querySelector('.profile-backdrop')?.addEventListener('click', closeProfilePanel);

    function closeProfilePanel() {
      profilePanel?.classList.remove('active');
      profilePanel?.setAttribute('aria-hidden', 'true');
    }

    pfpChange?.addEventListener('click', () => pfpInput?.click());

    pfpInput?.addEventListener('change', async () => {
      const file = pfpInput.files?.[0];
      if (!file) return;
      const fd = new FormData();
      fd.append('file', file);
      fd.append('purpose', 'pfp');
      try {
        const res = await fetch('/api/feed/upload', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.ok && data.pfpUrl) {
          const img = document.getElementById('profile-pfp-img') as HTMLImageElement;
          if (img) img.src = data.pfpUrl + '?t=' + Date.now();
          // Also update profile in DB
          await fetch('/api/feed/profile', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pfpUrl: data.pfpUrl }),
          });
        }
      } catch { /* */ }
    });

    profileSave?.addEventListener('click', async () => {
      const name = (document.getElementById('profile-name') as HTMLInputElement)?.value;
      const sub = (document.getElementById('profile-subtitle') as HTMLInputElement)?.value;
      try {
        const res = await fetch('/api/feed/profile', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ displayName: name, subtitle: sub }),
        });
        if (res.ok) {
          profileSave.textContent = '✓';
          setTimeout(() => { profileSave.textContent = 'guardar'; location.reload(); }, 800);
        }
      } catch { /* */ }
    });

    // ── POST ACTIONS (pin/delete) ──
    document.querySelectorAll('.post-action-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const action = (btn as HTMLElement).dataset.action;
        const card = btn.closest('.post-card') as HTMLElement;
        const postId = card?.dataset.postId;
        if (!postId || !action) return;

        if (action === 'delete') {
          if (!confirm('Eliminar este post?')) return;
          try {
            const res = await fetch('/api/feed/delete', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: parseInt(postId) }),
            });
            if (res.ok) card.style.opacity = '0';
            setTimeout(() => card.remove(), 300);
          } catch { /* */ }
        } else if (action === 'pin') {
          const isPinned = card.querySelector('.post-pin-badge') !== null;
          try {
            await fetch('/api/feed/pin', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: parseInt(postId), pinned: !isPinned }),
            });
            location.reload();
          } catch { /* */ }
        }
      });
    });

    // ── MEDIA VIEWER (click on media items) ──
    document.querySelectorAll('.media-image, .media-video').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = el.closest('.post-card') as HTMLElement;
        const postId = card?.dataset.postId;
        const idx = parseInt((el as HTMLElement).dataset.mediaIndex ?? '0');

        // Find the post data — we need to get media URL from the element
        const img = el.querySelector('img');
        const videoSrc = img?.src ?? '';

        // Get original URL (not thumbnail) — replace /thumbs/ with /uploads/
        const originalUrl = videoSrc.replace('/thumbs/feed/', '/uploads/feed/').replace(/\.webp$/, '.webp');

        const isVideo = el.classList.contains('media-video');
        (window as any).__openMediaViewer?.({
          url: originalUrl,
          type: isVideo ? 'video' : 'image',
        });
      });
    });

    // ── INFINITE SCROLL ──
    const sentinel = document.querySelector('.feed-sentinel') as HTMLElement;
    if (sentinel) {
      const cursor = sentinel.dataset.nextCursor;
      const observer = new IntersectionObserver(async (entries) => {
        if (!entries[0]?.isIntersecting) return;
        observer.disconnect();
        try {
          const res = await fetch(`/api/feed/?cursor=${cursor}&limit=20`);
          const data = await res.json();
          if (data.posts?.length) {
            const mosaic = document.querySelector('.feed-mosaic');
            if (mosaic) {
              // We need to do a full reload for now since Astro components can't be dynamically inserted
              // In the future, we could render post HTML on the server and inject it
              // For v1, we reload when reaching the bottom
              if (data.next_cursor) {
                location.href = `/?after=${data.next_cursor}`;
              }
            }
          }
        } catch { /* */ }
      }, { rootMargin: '200px' });
      observer.observe(sentinel);
    }
  }

  // ── REACTIONS ──
  async function fetchReactionsForCard(card: HTMLElement) {
    const postId = card.dataset.postId;
    if (!postId) return;
    try {
      const res = await fetch(`/api/feed/reactions?post_id=${postId}`);
      const data = await res.json();
      const counts: { emoji: string; count: number }[] = data.reactions || [];
      const userReaction: string | null = data.userReaction;

      // Update count spans
      counts.forEach(({ emoji, count }) => {
        const countEl = card.querySelector(`[data-reaction-count="${emoji}"]`);
        if (countEl) countEl.textContent = String(count);
      });

      // Highlight user's active reaction
      card.querySelectorAll('.reaction-btn').forEach((btn) => {
        const emoji = (btn as HTMLElement).dataset.reactionEmoji;
        if (emoji === userReaction) {
          btn.classList.add('is-active');
        } else {
          btn.classList.remove('is-active');
        }
      });
    } catch { /* */ }
  }

  // Fetch counts for all visible post cards
  document.querySelectorAll<HTMLElement>('.post-card').forEach((card) => {
    fetchReactionsForCard(card);
  });

  // Event delegation: click on any reaction button
  document.querySelector('.feed-mosaic')?.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLElement>('.reaction-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    const card = btn.closest<HTMLElement>('.post-card');
    const postId = card?.dataset.postId;
    const emoji = btn.dataset.reactionEmoji;
    if (!postId || !emoji) return;

    const isActive = btn.classList.contains('is-active');

    try {
      if (isActive) {
        // Clicking own reaction → remove it
        const res = await fetch('/api/feed/reactions', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ post_id: parseInt(postId) }),
        });
        const data = await res.json();
        if (data.ok) fetchReactionsForCard(card);
      } else {
        // Add or change reaction
        const res = await fetch('/api/feed/reactions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ post_id: parseInt(postId), emoji }),
        });
        const data = await res.json();
        if (data.ok) fetchReactionsForCard(card);
      }
    } catch { /* */ }
  });

  // ── GALAXY SIMULATOR ──
  let galaxyAnimFrame: number | null = null;
  let galaxyResizeHandler: (() => void) | null = null;

  function initGalaxySimulator() {
    if (galaxyAnimFrame) cancelAnimationFrame(galaxyAnimFrame);
    if (galaxyResizeHandler) window.removeEventListener('resize', galaxyResizeHandler);

    const canvas = document.getElementById('galaxy-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * window.devicePixelRatio;
      canvas.height = height * window.devicePixelRatio;
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    };

    resize();
    galaxyResizeHandler = resize;
    window.addEventListener('resize', galaxyResizeHandler);

    interface Particle {
      x: number;
      y: number;
      angle: number;
      radius: number;
      speed: number;
      radialSpeed: number;
      size: number;
      baseHue: number;
      hue: number;
      alpha: number;
      type: number;
      orbitOffset: number;
      speedMult: number;
    }

    const particles: Particle[] = [];
    const maxParticles = 380;

    function createParticle(randomize = false) {
      const type = Math.floor(Math.random() * 3);
      const angle = Math.random() * Math.PI * 2;
      const radius = randomize ? Math.random() * 130 + 5 : 5;
      
      const pClass = Math.random();
      let size, alpha, speedMult;
      if (pClass < 0.22) {
        // Class 1: Ethereal Dust (Large, very faint, slow)
        size = Math.random() * 2.2 + 1.6;
        alpha = Math.random() * 0.15 + 0.08;
        speedMult = 0.45;
      } else if (pClass < 0.65) {
        // Class 2: Standard Stars (Medium, glowing)
        size = Math.random() * 1.1 + 0.7;
        alpha = Math.random() * 0.4 + 0.3;
        speedMult = 1.0;
      } else {
        // Class 3: Quantum Sparks (Tiny, bright, fast)
        size = Math.random() * 0.6 + 0.3;
        alpha = Math.random() * 0.45 + 0.55;
        speedMult = 1.7;
      }

      // Iridescent base color themes: Gold, Cyan/Turquoise, Magenta/Pink, and rare deep Violet
      const hueOptions = [45, 195, 310, 260];
      const weight = Math.random();
      let baseHue;
      if (weight < 0.35) baseHue = 195; // Cyan dominant
      else if (weight < 0.70) baseHue = 310; // Magenta dominant
      else if (weight < 0.90) baseHue = 45; // Gold
      else baseHue = 260; // Deep Violet/Purple

      return {
        x: width / 2,
        y: height / 2,
        angle: angle,
        radius: radius,
        speed: (Math.random() * 0.009 + 0.003) * (Math.random() > 0.5 ? 1 : -1) * speedMult,
        radialSpeed: (Math.random() * 0.45 + 0.2) * speedMult,
        size: size,
        baseHue: baseHue,
        hue: baseHue,
        alpha: alpha,
        type: type,
        orbitOffset: Math.random() * Math.PI * 2,
        speedMult: speedMult,
      };
    }

    for (let i = 0; i < maxParticles; i++) {
      particles.push(createParticle(true));
    }

    let mouseX = -9999;
    let mouseY = -9999;

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    canvas.addEventListener('mouseleave', () => {
      mouseX = -9999;
      mouseY = -9999;
    });

    let time = 0;

    function draw() {
      time += 0.008; // slightly slower time step for smoother movements
      
      // Draw trails with a very dark background that lets the glowing colors blend
      ctx.fillStyle = 'rgba(26, 21, 32, 0.09)';
      ctx.fillRect(0, 0, width, height);

      const centerX = width / 2;
      const centerY = height / 2;

      // Draw a soft, glowing, iridescent galactic center
      const coreGrad = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, Math.min(width, height) * 0.45);
      const coreHue = (time * 8) % 360;
      coreGrad.addColorStop(0, `hsla(${coreHue}, 95%, 70%, 0.12)`);
      coreGrad.addColorStop(0.35, `hsla(${(coreHue + 80) % 360}, 90%, 65%, 0.05)`);
      coreGrad.addColorStop(0.7, `hsla(${(coreHue + 160) % 360}, 85%, 60%, 0.015)`);
      coreGrad.addColorStop(1, 'rgba(0, 0, 0, 0)');
      
      ctx.save();
      ctx.fillStyle = coreGrad;
      ctx.beginPath();
      ctx.arc(centerX, centerY, Math.min(width, height) * 0.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();

      // Start rotated canvas for stars
      ctx.save();
      ctx.translate(centerX, centerY);
      ctx.rotate(time * 0.025); // slow rotate
      ctx.translate(-centerX, -centerY);

      // Set blend mode to lighter for vivid neon blending
      ctx.globalCompositeOperation = 'lighter';

      particles.forEach((p) => {
        // Iridescent color shift: oscillating hue around the particle's base hue
        // We use a combination of time, radius, and angle to create iridescent ripples
        const colorWave = Math.sin(time * 1.5 + p.radius * 0.05 + p.angle) * 45;
        p.hue = (p.baseHue + colorWave + 360) % 360;

        if (p.type === 0) {
          // Density wave spiral arm
          p.angle += p.speed;
          const armRadius = p.radius + Math.sin(p.angle * 3.5 + time * 1.5) * 14;
          p.x = centerX + Math.cos(p.angle) * armRadius;
          p.y = centerY + Math.sin(p.angle) * armRadius;
        } else if (p.type === 1) {
          // Swirling expanding starfield
          p.radius += p.radialSpeed;
          p.angle += 0.008 + (p.radius * 0.00003); // spiral curl
          p.x = centerX + Math.cos(p.angle) * p.radius;
          p.y = centerY + Math.sin(p.angle) * p.radius;

          if (p.radius > Math.max(width, height) * 0.7) {
            Object.assign(p, createParticle(false));
          }
        } else {
          // Double elliptical tilted orbit (quantum dance)
          p.angle += p.speed * 1.3;
          const orbitRadius = p.radius * (0.8 + 0.2 * Math.sin(time * 2.0 + p.orbitOffset));
          p.x = centerX + Math.cos(p.angle) * orbitRadius;
          p.y = centerY + Math.sin(p.angle + p.orbitOffset) * orbitRadius * 0.5;
        }

        // Mouse interaction (un-rotate mouse coordinates back to matching space)
        let rotMouseX = -9999;
        let rotMouseY = -9999;
        if (mouseX !== -9999 && mouseY !== -9999) {
          const cos = Math.cos(-time * 0.025);
          const sin = Math.sin(-time * 0.025);
          const dx = mouseX - centerX;
          const dy = mouseY - centerY;
          rotMouseX = centerX + (dx * cos - dy * sin);
          rotMouseY = centerY + (dx * sin + dy * cos);
        }

        if (rotMouseX !== -9999 && rotMouseY !== -9999) {
          const dx = p.x - rotMouseX;
          const dy = p.y - rotMouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 65) {
            const force = (65 - dist) / 65;
            p.x += (dx / dist) * force * 4.5;
            p.y += (dy / dist) * force * 4.5;
          }
        }

        // Draw particle layers
        // 1. Soft ethereal halo (larger, very low opacity)
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * 6.5, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue}, 100%, 65%, ${p.alpha * 0.06})`;
        ctx.fill();

        // 2. Inner glow (medium, low opacity)
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * 3.0, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue}, 100%, 75%, ${p.alpha * 0.18})`;
        ctx.fill();

        // 3. Bright Core (white-ish / light neon center)
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue}, 100%, 88%, ${p.alpha})`;
        ctx.fill();
      });

      // Restore blend mode and context
      ctx.globalCompositeOperation = 'source-over';
      ctx.restore();
      
      galaxyAnimFrame = requestAnimationFrame(draw);
    }

    draw();
  }

  function initAll() {
    initFeedClient();
    initGalaxySimulator();
  }

  document.addEventListener('astro:page-load', initAll);
</script>

