---
import Base from '../layouts/Base.astro';
import FeedGrid from '../features/feed/FeedGrid.astro';
import MediaViewer from '../features/feed/MediaViewer.astro';
import RadioPlayer from '../features/radio/RadioPlayer.astro';
import TaglineTyper from '../features/deco/TaglineTyper.astro';
import { getPosts, getProfile } from '../lib/feed';
import { isAdmin } from '../lib/auth';
import { ADMIN_JWT_SECRET } from '../lib/env';
import YoukaiDashboard from '../features/youkai/YoukaiDashboard.astro';

const profile = getProfile();
const { posts, next_cursor } = getPosts(undefined, 20);
const authenticated = await isAdmin(Astro.request, ADMIN_JWT_SECRET());
---

<Base title="aris-sama" description={profile.subtitle}>
  <section class="feed-page">
    <!-- Celestial Decoration -->
    <div class="celestial-line" aria-hidden="true"></div>

 <div class="feed-content">
      <!-- ═══ HERO SECTION: TWO COLUMNS ON DESKTOP ═══ -->
      <header class="feed-hero-layout">
        <!-- Profile Header (Gothic Hero) - NO container card! -->
        <div class="hero-profile-wrap">
          <div class="herta-frame-container" aria-hidden="true">
            <div class="herta-gear herta-gear-outer"></div>
            <div class="herta-gear herta-gear-inner"></div>
            <div class="herta-ambient-glow"></div>
            <div class="herta-character-wrapper">
              <img src="/images/herta_portrait.webp" alt="The Herta" class="herta-character-img" />
            </div>
          </div>
          
          <div class="hero-text-block">
            <h1 class="hero-name-gothic">{profile.display_name}</h1>
            <TaglineTyper authenticated={authenticated} />

            <div class="celestial-separator" aria-hidden="true">
              <span class="sep-dot"></span><span class="sep-line"></span>
              <span class="sep-dot"></span><span class="sep-line"></span>
              <span class="sep-dot"></span>
            </div>

            <div class="hero-status-gothic">
              <span class="status-dot-gothic" aria-hidden="true"></span>
              <span>en línea · gdl.mx</span>
            </div>
          </div>
        </div>

        <!-- Card 2: Particle Galaxy Card -->
        <div class="hero-galaxy-card">
          <canvas id="galaxy-canvas"></canvas>
          <div class="galaxy-overlay">
            <span class="galaxy-title">Youkai Core</span>
          </div>
        </div>
      </header>

      <!-- ═══ TAB CONTROL ═══ -->
      <div class="home-tab-switcher">
        <button class="tab-btn active" data-tab="youkai">
          <span class="tab-icon">⛨</span> Youkai Core
        </button>
        <button class="tab-btn" data-tab="feed">
          <span class="tab-icon">✦</span> Diario
        </button>
      </div>

      <!-- ═══ TAB CONTENT: YOUKAI ═══ -->
      <div class="tab-content active" id="tab-youkai">
        <YoukaiDashboard />
      </div>

      <!-- ═══ TAB CONTENT: FEED ═══ -->
      <div class="tab-content" id="tab-feed" style="display: none;">
        <!-- ═══ FEED ═══ -->
        <section class="feed-body">
          <FeedGrid posts={posts} profile={profile} authenticated={authenticated} />
        </section>

        <!-- Infinite scroll sentinel -->
        {next_cursor && (
          <div class="feed-sentinel" data-next-cursor={next_cursor} aria-hidden="true"></div>
        )}
      </div>

      <!-- Page Ornament -->
      <div class="page-ornament" aria-hidden="true"></div>
 </div>

 </section>

 <!-- MediaViewer (lightbox) -->
 <MediaViewer />

  <!-- ═══ COMPOSE DRAWER (only when authenticated) ═══ -->
  {authenticated && (
    <div class="compose-drawer" id="compose-drawer" aria-hidden="true">
      <div class="compose-backdrop"></div>
      <div class="compose-panel">
        <div class="compose-header">
          <span class="compose-title">nuevo post</span>
          <button class="compose-close" id="compose-close">✕</button>
        </div>

          <div class="compose-body">
          <textarea class="compose-textarea" id="compose-text" placeholder="que estas pensando..." rows="3"></textarea>

          <span class="compose-error-msg" id="compose-error" style="display:none"></span>

          <div class="compose-toolbar">
            <div class="compose-uploads">
              <button class="compose-tool" data-upload="image" title="Imagen">📎</button>
              <button class="compose-tool" data-upload="video" title="Video">🎬</button>
              <button class="compose-tool" data-upload="document" title="Documento">📄</button>
            </div>
            <div class="compose-mood-wrap">
              <button class="compose-tool" id="mood-toggle" title="Mood">✨</button>
              <div class="mood-picker" id="mood-picker">
                <button class="mood-opt" data-mood="✨">✨</button>
                <button class="mood-opt" data-mood="💭">💭</button>
                <button class="mood-opt" data-mood="🎮">🎮</button>
                <button class="mood-opt" data-mood="😭">😭</button>
                <button class="mood-opt" data-mood="📖">📖</button>
                <button class="mood-opt" data-mood="♪">♪</button>
                <button class="mood-opt" data-mood="">✕</button>
              </div>
            </div>
            <label class="compose-pin-label">
              <input type="checkbox" id="compose-pin" /> fijar
            </label>
          </div>

          <!-- Media previews -->
          <div class="compose-previews" id="compose-previews"></div>

          <!-- Upload progress -->
          <div class="compose-progress" id="compose-progress">
            <div class="prog-track"><div class="prog-bar" id="compose-prog-bar"></div></div>
          </div>
        </div>

        <div class="compose-footer">
          <button class="compose-publish" id="compose-publish">publicar →</button>
        </div>
      </div>
    </div>
  )}

  <!-- ═══ PROFILE PANEL (only when authenticated) ═══ -->
  {authenticated && (
    <div class="profile-panel" id="profile-panel" aria-hidden="true">
      <div class="profile-backdrop"></div>
      <div class="profile-sidebar">
        <div class="profile-header">
          <span class="profile-title">perfil</span>
          <button class="profile-close" id="profile-close">✕</button>
        </div>

        <div class="profile-body">
          <div class="profile-pfp-wrap">
            <img class="profile-pfp" id="profile-pfp-img" src={profile.pfp_url} alt="" width="64" height="64" />
            <button class="pfp-change" id="pfp-change">cambiar foto</button>
            <input type="file" id="pfp-input" accept="image/*" hidden />
          </div>

          <div class="profile-field">
            <label class="profile-label">nombre</label>
            <input class="profile-input" id="profile-name" value={profile.display_name} />
          </div>

          <div class="profile-field">
            <label class="profile-label">subtitulo</label>
            <input class="profile-input" id="profile-subtitle" value={profile.subtitle} />
          </div>

          <button class="profile-save" id="profile-save">guardar</button>
        </div>

        <div class="profile-footer">
          <form action="/api/auth/logout" method="POST">
            <button class="profile-logout" type="submit">cerrar sesion</button>
          </form>
        </div>
      </div>
    </div>
  )}

  <!-- ═══ FAB BUTTONS (only when authenticated) ═══ -->
  {authenticated && (
    <div class="fab-group">
      <button class="fab fab-profile" id="fab-profile" title="Perfil">◇</button>
      <button class="fab fab-compose" id="fab-compose" title="Nuevo post">✦</button>
    </div>
  )}

  <!-- ═══ LOGIN TRIGGER (when not authenticated) ═══ -->
  {!authenticated && (
    <button class="login-trigger" id="login-trigger" title="Acceso">⛨</button>
  )}

  <!-- ═══ LOGIN MODAL ═══ -->
  <div class="login-modal" id="login-modal" aria-hidden="true">
    <div class="login-backdrop"></div>
    <div class="login-panel">
      <div class="login-header">
        <span class="login-title">acceso</span>
        <button class="login-close" id="login-close">✕</button>
      </div>
      <div class="login-body">
        <input class="login-input" id="login-password" type="password" placeholder="contraseña" autocomplete="current-password" />
        <button class="login-submit" id="login-submit">entrar</button>
        <p class="login-error" id="login-error"></p>
      </div>
 </div>
 </div>

 <!-- ═══ RADIO PLAYER ═══ -->
 <RadioPlayer />

 <!-- Auth flag for client scripts -->
 <span data-authenticated={String(authenticated)} style="display:none" aria-hidden="true"></span>
</Base>

<style>
  .feed-page {
    position: relative;
    min-height: 100vh;
    padding: var(--space-20) var(--space-6) var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .celestial-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(100%, 48rem);
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255,107,157,0.3), transparent);
    opacity: 0.3;
  }

  .feed-content {
    width: 100%;
    max-width: 56rem;
  }

  /* ═══ TAB CONTROL ═══ */
  .home-tab-switcher {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
    padding: 4px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }

  .tab-btn {
    background: transparent;
    border: 1px solid transparent;
    padding: var(--space-2) var(--space-6);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    border-radius: var(--radius-full);
    transition: all var(--duration) var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .tab-btn:hover {
    color: var(--color-ink);
    background: rgba(255, 255, 255, 0.03);
  }

  .tab-btn.active {
    color: var(--color-accent-hi);
    background: rgba(207, 162, 64, 0.12);
    border: 1px solid rgba(207, 162, 64, 0.2);
    box-shadow: var(--glow-sm);
  }

  .tab-icon {
    font-family: var(--font-mono);
  }

  .tab-content {
    width: 100%;
    animation: tab-appear 300ms var(--ease-out) both;
  }

  @keyframes tab-appear {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ HERO SECTION: TWO COLUMNS ON DESKTOP ═══ */
  .feed-hero-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
    width: 100%;
  }

  @media (min-width: 900px) {
    .feed-hero-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: var(--space-8);
    }
  }

  .hero-profile-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-profile-wrap {
      flex-direction: row;
      text-align: left;
      justify-content: flex-start;
      gap: var(--space-8);
      flex-shrink: 0;
    }
  }

  /* Particle Galaxy Card */
  .hero-galaxy-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 260px;
    overflow: hidden;
    padding: 0;
    background: var(--glass-bg);
    border: var(--glass-border);
    border-radius: var(--radius-lg);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--shadow-card);
    transition: border-color var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
  }

  .hero-galaxy-card:hover {
    border-color: var(--color-border-accent);
    box-shadow: var(--glow-sm);
  }

  #galaxy-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: auto;
  }

  .galaxy-overlay {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-5);
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .galaxy-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  .herta-frame-container {
    position: relative;
    width: 260px;
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .herta-ambient-glow {
    position: absolute;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    /* Degradado celestial violeta/oro que pulsa de fondo */
    background: radial-gradient(circle, rgba(140, 123, 181, 0.22) 0%, rgba(207, 162, 64, 0.08) 50%, transparent 75%);
    filter: blur(25px);
    z-index: 1;
    pointer-events: none;
    animation: herta-glow-pulse 8s ease-in-out infinite alternate;
  }

  .herta-character-wrapper {
    width: 220px;
    height: 220px;
    position: relative;
    z-index: 2;
    overflow: visible;
  }

  .herta-character-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 15px rgba(140, 123, 181, 0.2)) drop-shadow(0 0 35px rgba(207, 162, 64, 0.06));
    /* Degradado lineal que difumina el corte inferior de Herta */
    -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .herta-frame-container:hover .herta-character-img {
    transform: scale(1.05) translateY(-3px);
  }

  /* Engranajes astronómicos */
  .herta-gear {
    position: absolute;
    border: 1.5px dashed rgba(207, 162, 64, 0.25);
    border-radius: 50%;
    pointer-events: none;
  }

  .herta-gear-outer {
    width: 254px;
    height: 254px;
    animation: gear-spin-clockwise 50s linear infinite;
    z-index: 1;
  }

  .herta-gear-inner {
    width: 224px;
    height: 224px;
    border: 1px dotted rgba(140, 123, 181, 0.35);
    animation: gear-spin-counter 35s linear infinite;
    z-index: 1;
  }

  @keyframes gear-spin-clockwise {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes gear-spin-counter {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }

  @keyframes herta-glow-pulse {
    0% { transform: scale(0.9) rotate(0deg); opacity: 0.8; }
    100% { transform: scale(1.1) rotate(12deg); opacity: 1.2; }
  }

  .hero-text-block {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-text-block {
      align-items: flex-start;
    }
  }

  .hero-pretitle {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .hero-name-gothic {
    font-family: var(--font-deco);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.1;
    margin-bottom: var(--space-1);
    text-shadow: 0 4px 20px rgba(207,162,64,0.15);
  }

  .hero-status-gothic {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.08em;
    margin-top: var(--space-4);
  }

  .status-dot-gothic {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: var(--glow-sm);
    animation: dot-pulse 2.8s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  /* ═══ FEED BODY ═══ */
  .feed-body {
    margin-bottom: var(--space-10);
  }

  .feed-sentinel {
    height: 1px;
    width: 100%;
  }

  .page-ornament {
    width: 3rem;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-10) auto 0;
  }

  /* ═══ FAB BUTTONS ═══ */
  .fab-group {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    z-index: 900;
  }

  .fab {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--color-border-accent);
    background: rgba(26, 21, 32, 0.90);
    backdrop-filter: blur(20px);
    font-size: 18px;
    color: var(--color-accent);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glow-sm);
    transition: all var(--duration) var(--ease-out);
  }

  .fab:hover {
    background: rgba(255,107,157,0.10);
    box-shadow: var(--glow-md);
    transform: scale(1.08);
  }

  .fab-compose {
    background: rgba(255,107,157,0.08);
  }

  /* ═══ LOGIN TRIGGER ═══ */
  .login-trigger {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-8);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: rgba(26, 21, 32, 0.80);
    backdrop-filter: blur(12px);
    font-size: 14px;
    color: var(--color-muted);
    cursor: pointer;
    z-index: 900;
    transition: all var(--duration) var(--ease-out);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .login-trigger:hover {
    border-color: var(--color-border-accent);
    color: var(--color-accent);
  }

  /* ═══ LOGIN MODAL ═══ */
  .login-modal {
    position: fixed;
    inset: 0;
    z-index: 9500;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s var(--ease-out);
  }

  .login-modal.active {
    opacity: 1;
    pointer-events: all;
  }

  .login-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 21, 32, 0.85);
    backdrop-filter: blur(16px);
  }

  .login-panel {
    position: relative;
    z-index: 1;
    width: min(320px, 90vw);
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .login-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-5);
  }

  .login-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .login-close {
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 14px;
    cursor: pointer;
  }

  .login-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .login-input {
    background: rgba(255,245,250,0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-ink);
    outline: none;
    transition: border-color var(--duration);
  }

  .login-input:focus {
    border-color: var(--color-accent);
  }

  .login-submit {
    background: rgba(255,107,157,0.10);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    padding: 8px 20px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-accent);
    cursor: pointer;
    letter-spacing: 0.08em;
    transition: all var(--duration) var(--ease-out);
  }

  .login-submit:hover {
    background: rgba(255,107,157,0.15);
    box-shadow: var(--glow-sm);
  }

  .login-error {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent-hi);
    min-height: 14px;
  }

  /* ═══ COMPOSE DRAWER ═══ */
  .compose-drawer {
    position: fixed;
    inset: 0;
    z-index: 9200;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s var(--ease-out);
  }

  .compose-drawer.active {
    opacity: 1;
    pointer-events: all;
  }

  .compose-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 21, 32, 0.80);
    backdrop-filter: blur(16px);
  }

  .compose-panel {
    position: relative;
    z-index: 1;
    width: min(480px, 95vw);
    max-height: 80vh;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    padding: var(--space-5) var(--space-6);
    transform: translateY(100%);
    transition: transform 0.35s var(--ease-out);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }

  .compose-drawer.active .compose-panel {
    transform: translateY(0);
  }

  .compose-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .compose-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
