---
import { Database } from 'bun:sqlite';
import { join } from 'path';

const { id } = Astro.params;

let video: any = null;
try {
  const db = new Database(join(process.cwd(), 'data', 'database.sqlite'), { readonly: true });
  video = db.query('SELECT * FROM videos WHERE id = ?').get(id);
  db.close();
} catch {}

if (!video) return Astro.redirect('/videos');

const BASE = `https://aris-sama.duckdns.org`;
const videoUrl = `${BASE}${video.url}`;
const thumbUrl = video.thumbnail ? `${BASE}${video.thumbnail}` : `${BASE}/favicon.svg`;

let descriptors: Record<string, string> = {};
try { descriptors = JSON.parse(video.descriptors ?? '{}'); } catch {}

const descParts: string[] = [];
if (video.category) descParts.push(video.category);
const descEntries = Object.entries(descriptors).map(([k, v]) => `${k}=${v}`);
if (descEntries.length > 0) descParts.push(descEntries.join(' · '));
const ogDescription = descParts.length > 0 ? descParts.join(' · ') : 'video · aris-sama';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{video.title} · aris-sama</title>

  <!-- Open Graph — Discord embed -->
  <meta property="og:site_name"          content="aris-sama" />
  <meta property="og:type"              content="video.other" />
  <meta property="og:title"             content={video.title} />
  <meta property="og:description"       content={ogDescription} />
  <meta property="og:url"               content={`${BASE}/v/${id}`} />
  <meta property="og:image"             content={thumbUrl} />
  <meta property="og:video:url"         content={videoUrl} />
  <meta property="og:video:secure_url"  content={videoUrl} />
  <meta property="og:video:type"        content="video/mp4" />
  <meta property="og:video:width"       content={video.width ?? 1920} />
  <meta property="og:video:height"      content={video.height ?? 1080} />
  <meta property="theme-color" content="#ff6b9d" />

  <meta name="twitter:card"        content="player" />
  <meta name="twitter:title"       content={video.title} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image"       content={thumbUrl} />
  <meta name="twitter:player"      content={`${BASE}/v/${id}`} />
  <meta name="twitter:player:width"  content={video.width ?? 1920} />
  <meta name="twitter:player:height" content={video.height ?? 1080} />

  <link rel="stylesheet" href="/design-tokens.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--color-bg);
      color: var(--color-ink);
      font-family: var(--font-body);
      min-height: 100dvh;
      overflow-x: hidden;
    }

    /* ═══ BACKGROUND ORBS ═══ */
    .vv-bg {
      position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
    }
    .vv-orb {
      position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.12;
    }
    .vv-orb-a {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(103,232,249,0.4) 0%, transparent 70%);
      top: -150px; right: -100px;
      animation: vv-float 30s ease-in-out infinite alternate;
    }
    .vv-orb-b {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(196,181,253,0.35) 0%, transparent 70%);
      bottom: -100px; left: -80px;
      animation: vv-float 40s ease-in-out infinite alternate-reverse;
    }
    @keyframes vv-float {
      from { transform: translate(0,0) scale(1); }
      to { transform: translate(30px,20px) scale(1.1); }
    }

    .vv-page {
      position: relative; z-index: 1;
      max-width: 1000px; margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }

    /* ── Back link ── */
    .vv-back {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: var(--font-mono); font-size: 0.75rem;
      color: var(--color-muted); text-decoration: none;
      margin-bottom: 2rem; letter-spacing: 0.06em;
      padding: 6px 14px;
      border: 1px solid rgba(196,181,253,0.10);
      border-radius: var(--radius-full);
      background: rgba(26,21,32,0.5);
      backdrop-filter: blur(8px);
      transition: all 0.2s var(--ease-out);
    }
    .vv-back:hover {
      border-color: var(--color-border-accent);
      color: var(--color-cyan);
      box-shadow: var(--glow-cyan);
    }

    /* ── Player ── */
    .vv-player-wrap {
      width: 100%;
      border-radius: var(--radius-xl);
      overflow: hidden;
      background: #000;
      box-shadow: 0 8px 60px rgba(0,0,0,0.6), 0 0 80px rgba(103,232,249,0.06);
      margin-bottom: 2rem;
    }
    .vv-player-wrap video {
      width: 100%; display: block;
      max-height: 70vh; object-fit: contain;
    }

    /* ── Info ── */
    .vv-info {
      background: rgba(26,21,32,0.5);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(196,181,253,0.08);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      margin-bottom: 2rem;
    }
    .vv-category {
      font-family: var(--font-mono); font-size: 0.68rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--color-cyan); margin-bottom: 0.75rem;
      display: inline-block;
      background: rgba(103,232,249,0.08);
      border: 1px solid rgba(103,232,249,0.15);
      padding: 3px 10px;
      border-radius: var(--radius-full);
    }
    .vv-title {
      font-family: var(--font-display); font-size: 2rem;
      color: var(--color-ink); line-height: 1.15; margin-bottom: 1rem;
      font-weight: 700;
    }
    .vv-descriptors {
      display: flex; flex-wrap: wrap; gap: 0.5rem;
      margin-bottom: 1.25rem;
    }
    .vv-desc-tag {
      background: rgba(103,232,249,0.06);
      border: 1px solid rgba(103,232,249,0.12);
      border-radius: 6px; padding: 0.3rem 0.65rem;
      font-family: var(--font-mono); font-size: 0.72rem;
      color: var(--color-muted);
    }
    .vv-desc-tag strong { color: var(--color-cyan); margin-right: 4px; }

    /* ── Share ── */
    .vv-share-row {
      display: flex; align-items: center; gap: 0.75rem;
    }
    .vv-share-url {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; padding: 0.6rem 0.85rem;
      font-family: var(--font-mono); font-size: 0.72rem;
      color: var(--color-muted-2); white-space: nowrap;
      overflow: hidden; text-overflow: ellipsis;
    }
    .vv-copy-btn {
      background: rgba(103,232,249,0.10);
      color: var(--color-cyan);
      border: 1px solid rgba(103,232,249,0.25);
      border-radius: var(--radius-full); padding: 0.55rem 1.1rem;
      font-family: var(--font-mono); font-size: 0.72rem;
      cursor: pointer; white-space: nowrap; letter-spacing: 0.04em;
      transition: all 0.2s var(--ease-out);
    }
    .vv-copy-btn:hover {
      background: rgba(103,232,249,0.18);
      box-shadow: var(--glow-cyan);
    }

    /* ── Comments Section ── */
    .vv-comments {
      background: rgba(26,21,32,0.4);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(196,181,253,0.06);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
    }
    .vv-comments-title {
      font-family: var(--font-mono); font-size: 0.68rem;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--color-lavender); margin-bottom: 1.5rem;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .vv-comments-title::before {
      content: '◇'; font-size: 10px; color: var(--color-lavender); opacity: 0.5;
    }

    .vv-comment-form {
      display: flex; flex-direction: column; gap: 0.65rem;
      margin-bottom: 2rem;
    }
    .vv-comment-form input,
    .vv-comment-form textarea {
      background: rgba(255,245,250,0.04);
      border: 1px solid rgba(196,181,253,0.10);
      border-radius: var(--radius-md); padding: 0.65rem 0.9rem;
      color: var(--color-ink); font-family: var(--font-body);
      font-size: 0.88rem; outline: none;
      transition: border-color 0.2s var(--ease-out);
    }
    .vv-comment-form input:focus,
    .vv-comment-form textarea:focus {
      border-color: var(--color-lavender);
      box-shadow: var(--glow-lavender);
    }
    .vv-comment-form textarea { min-height: 80px; resize: vertical; }
    .vv-comment-submit {
      align-self: flex-end;
      background: rgba(196,181,253,0.10);
      color: var(--color-lavender);
      border: 1px solid rgba(196,181,253,0.20);
      border-radius: var(--radius-full); padding: 0.5rem 1.2rem;
      font-family: var(--font-mono); font-size: 0.72rem;
      cursor: pointer; letter-spacing: 0.04em;
      transition: all 0.2s var(--ease-out);
    }
    .vv-comment-submit:hover {
      background: rgba(196,181,253,0.18);
      box-shadow: var(--glow-lavender);
    }
    .vv-comment-submit:disabled { opacity: 0.4; cursor: not-allowed; }
    .vv-comment-error {
      font-family: var(--font-mono); font-size: 0.72rem;
      color: var(--color-accent-hi); display: none;
    }

    .vv-comments-list { display: flex; flex-direction: column; gap: 0.85rem; }
    .vv-comment-empty {
      font-family: var(--font-mono); font-size: 0.78rem;
      color: var(--color-muted-2); text-align: center; padding: var(--space-4);
    }
    .vv-comment-card {
      background: rgba(255,245,250,0.025);
      border: 1px solid rgba(196,181,253,0.06);
      border-radius: var(--radius-md); padding: 0.9rem 1.05rem;
      transition: border-color 0.2s var(--ease-out);
      animation: vv-fade-up 0.35s var(--ease-out) both;
    }
    .vv-comment-card:hover { border-color: rgba(196,181,253,0.12); }
    @keyframes vv-fade-up {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .vv-comment-header {
      display: flex; align-items: baseline; gap: 0.6rem;
      margin-bottom: 0.45rem;
    }
    .vv-comment-alias {
      font-family: var(--font-mono); font-size: 0.8rem;
      color: var(--color-lavender); font-weight: 600;
    }
    .vv-comment-date {
      font-family: var(--font-mono); font-size: 0.65rem;
      color: var(--color-muted-2);
    }
    .vv-comment-body {
      font-size: 0.9rem; color: var(--color-ink-soft);
      line-height: 1.6; white-space: pre-wrap; word-break: break-word;
    }

    @media (max-width: 640px) {
      .vv-page { padding: 1rem 0.75rem 3rem; }
      .vv-title { font-size: 1.5rem; }
      .vv-info, .vv-comments { padding: var(--space-4); }
    }
  </style>
</head>
<body>
  <div class="vv-bg" aria-hidden="true">
    <div class="vv-orb vv-orb-a"></div>
    <div class="vv-orb vv-orb-b"></div>
  </div>

  <div class="vv-page">
    <a href="/videos" class="vv-back">← volver a galeria</a>

    <div class="vv-player-wrap">
      <video
        src={video.url}
        controls
        preload="metadata"
        poster={video.thumbnail ?? undefined}
      ></video>
    </div>

    <div class="vv-info">
      <div class="vv-category">{video.category ?? 'general'}</div>
      <h1 class="vv-title">{video.title}</h1>

      {Object.keys(descriptors).length > 0 && (
        <div class="vv-descriptors">
          {Object.entries(descriptors).map(([k, v]) => (
            <span class="vv-desc-tag"><strong>{k}</strong>{v}</span>
          ))}
        </div>
      )}

      <div class="vv-share-row">
        <div class="vv-share-url" id="share-url">{BASE}/v/{id}</div>
        <button class="vv-copy-btn" id="copy-btn">copiar link</button>
      </div>
    </div>

    <section class="vv-comments">
      <div class="vv-comments-title">comentarios</div>

      <form class="vv-comment-form" id="comment-form">
        <input
          type="text" id="alias-input"
          placeholder="tu nombre o alias"
          maxlength="32" autocomplete="nickname"
        />
        <textarea
          id="body-input"
          placeholder="deja un comentario..."
          maxlength="500"
        ></textarea>
        <span class="vv-comment-error" id="comment-error"></span>
        <button type="submit" class="vv-comment-submit" id="comment-submit">enviar →</button>
      </form>

      <div class="vv-comments-list" id="comments-list">
        <span class="vv-comment-empty">cargando comentarios...</span>
      </div>
    </section>
  </div>

  <script define:vars={{ videoId: id }}>
    const btn = document.getElementById('copy-btn');
    const urlEl = document.getElementById('share-url');
    btn?.addEventListener('click', () => {
      navigator.clipboard.writeText(urlEl?.textContent?.trim() ?? '').then(() => {
        if (btn) { btn.textContent = '✓ copiado'; setTimeout(() => { btn.textContent = 'copiar link'; }, 2000); }
      });
    });

    const list = document.getElementById('comments-list');
    const form = document.getElementById('comment-form');
    const aliasInput = document.getElementById('alias-input');
    const bodyInput = document.getElementById('body-input');
    const submitBtn = document.getElementById('comment-submit');
    const errorEl = document.getElementById('comment-error');

    function formatDate(str: string) {
      try {
        return new Date(str + 'Z').toLocaleString('es-MX', {
          day: '2-digit', month: 'short', year: 'numeric',
          hour: '2-digit', minute: '2-digit'
        });
      } catch { return str; }
    }

function escHtml(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function renderComments(comments: any[]) {
      if (!list) return;
      if (!comments.length) {
        list.innerHTML = '<span class="vv-comment-empty">sin comentarios todavía. sé el primero ✨</span>';
        return;
      }
      list.innerHTML = comments.map((c, i) => `
        <div class="vv-comment-card" style="animation-delay:${i * 50}ms">
          <div class="vv-comment-header">
            <span class="vv-comment-alias">${escHtml(c.alias ?? '')}</span>
            <span class="vv-comment-date">${formatDate(c.created_at)}</span>
          </div>
          <div class="vv-comment-body">${escHtml(c.body ?? '')}</div>
        </div>
      `).join('');
    }

    async function loadComments() {
      try {
        const res = await fetch(`/api/videos/comments?id=${videoId}`);
        const data = await res.json();
        renderComments(Array.isArray(data) ? data : []);
      } catch {
        if (list) list.innerHTML = '<span class="vv-comment-empty">error al cargar comentarios.</span>';
      }
    }

    const savedAlias = localStorage.getItem('aris_comment_alias') ?? '';
    if (aliasInput && savedAlias) aliasInput.value = savedAlias;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const alias = aliasInput?.value?.trim();
      const body  = bodyInput?.value?.trim();
      if (errorEl) errorEl.style.display = 'none';
      if (!alias || !body) {
        if (errorEl) { errorEl.textContent = 'nombre y comentario son requeridos'; errorEl.style.display = 'block'; }
        return;
      }
      if (submitBtn) submitBtn.disabled = true;
      try {
        const res = await fetch(`/api/videos/comments?id=${videoId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ alias, body })
        });
        const data = await res.json();
        if (data.ok) {
          localStorage.setItem('aris_comment_alias', alias);
          if (bodyInput) bodyInput.value = '';
          await loadComments();
          list?.lastElementChild?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          if (errorEl) { errorEl.textContent = data.error ?? 'error al enviar'; errorEl.style.display = 'block'; }
        }
      } catch {
        if (errorEl) { errorEl.textContent = 'error de red'; errorEl.style.display = 'block'; }
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

    loadComments();
  </script>
</body>
</html>
