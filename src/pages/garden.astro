---
import Base from '../layouts/Base.astro';

// Digital garden — things that grow over time
const plants = [
{
 id: 'kavita',
 title: '🥇 Kavita · Manga Reader',
 description: 'Lector de manga y libros. EPUB, PDF, CBZ. Todo local.',
 icon: '📖',
 color: 'gold',
 href: '/manga',
 tags: ['manga', 'CBZ', 'EPUB', 'PDF', 'OPDS', 'self-hosted'],
},
{
 id: 'gacha-tracker',
 title: 'Gacha Tracker',
 description: 'Personajes de Genshin, HSR, ZZZ. Lo que he conseguido.',
 icon: '✦',
 color: 'gold',
 href: '/gacha',
 tags: ['gacha', 'api', 'enka'],
},
{
 id: 'anime-log',
 title: 'Anime Log',
 description: 'Anime que veo, vi, o quiero ver. Desde AniList.',
 icon: '◈',
 color: 'lavender',
 href: '/anime',
 tags: ['anime', 'anilist', 'watching'],
},
{
 id: 'video-clip',
 title: 'Video Clips',
 description: 'Videos que subo. Lo que quiero guardar.',
 icon: '▶',
 color: 'cyan',
 href: '/videos',
 tags: ['videos', 'discord', 'uploads'],
},
{
 id: 'nicole-lore',
 title: 'Nicole: Clamor Within',
 description: 'La historia del ángel sin voz y la pequeña maga.',
 icon: '☽',
 color: 'lavender',
 href: '/nicole',
 tags: ['genshin', 'lore', 'hexenzirkel'],
},
{
 id: 'chat-aris',
 title: 'Chat con Aris',
 description: 'Gemma 4 en local. Mi chatbot personal.',
 icon: '◉',
 color: 'sage',
 href: '/chat',
 tags: ['llm', 'gemma', 'local'],
},
{
 id: 'now-page',
 title: 'Ahora',
 description: 'Qué estoy haciendo ahora.',
 icon: '●',
 color: 'accent',
 href: '/now',
 tags: ['now', 'status', 'personal'],
},
{
 id: 'radio-fm',
 title: 'Aris FM',
 description: 'Radio lo-fi. Tiene canción local cuando hay.',
 icon: '♪',
 color: 'cyan',
 href: '#',
 tags: ['radio', 'audio', 'lofi'],
},
{
 id: 'spells',
 title: 'Sigila',
 description: 'Shaders GLSL. Generación con IA + visualización en tiempo real.',
 icon: '◈',
 color: 'lavender',
 href: '/garden/spells',
 tags: ['webgl2', 'glsl', 'sigils', 'shader'],
},

];

const colorMap: Record<string, { accent: string; bg: string; border: string; glow: string }> = {
  gold:     { accent: '#fbbf24', bg: 'rgba(251,191,36,0.08)',  border: 'rgba(251,191,36,0.20)',  glow: '0 0 12px rgba(251,191,36,0.25)' },
  lavender: { accent: '#c4b5fd', bg: 'rgba(196,181,253,0.08)', border: 'rgba(196,181,253,0.20)', glow: '0 0 12px rgba(196,181,253,0.25)' },
  cyan:     { accent: '#67e8f9', bg: 'rgba(103,232,249,0.08)', border: 'rgba(103,232,249,0.20)', glow: '0 0 12px rgba(103,232,249,0.25)' },
  accent:   { accent: '#ff6b9d', bg: 'rgba(255,107,157,0.08)', border: 'rgba(255,107,157,0.20)', glow: '0 0 12px rgba(255,107,157,0.25)' },
  sage:     { accent: '#86efac', bg: 'rgba(134,239,172,0.08)', border: 'rgba(134,239,172,0.20)', glow: '0 0 12px rgba(134,239,172,0.25)' },
};
---

<Base title="jardin · aris" description="Jardin digital — cosas que crecen con el tiempo">

  <section class="page-hero">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-glow-2"></div>
    </div>
    <div class="page-hero-content">
      <div class="hero-chip">
        <span class="hero-chip-seed" aria-hidden="true">❋</span>
        jardin digital
      </div>
      <h1 class="hero-title">cosas que crecen</h1>
      <p class="hero-sub">proyectos, intereses y notas que florecen con el tiempo.</p>
    </div>
  </section>

  <section class="garden-page">
    <div class="garden-grid">
      {plants.map(plant => {
        const c = colorMap[plant.color] ?? colorMap.accent;
        return (
          <a href={plant.href} class="garden-plant" style={`--plant-accent: ${c.accent}; --plant-bg: ${c.bg}; --plant-border: ${c.border}; --plant-glow: ${c.glow};`}>
            <div class="plant-icon" aria-hidden="true">{plant.icon}</div>
            <div class="plant-body">
              <h3 class="plant-title">{plant.title}</h3>
              <p class="plant-desc">{plant.description}</p>
              <div class="plant-tags">
                {plant.tags.map(tag => (
                  <span class="plant-tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

</Base>

<style>
  .page-hero {
    position: relative;
    padding: var(--space-20) var(--space-8) var(--space-12);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    width: 500px; height: 500px;
    top: -150px; left: 20%;
    background: radial-gradient(circle, rgba(255,107,157,0.12) 0%, transparent 70%);
    filter: blur(50px);
  }

  .hero-glow-2 {
    position: absolute;
    width: 300px; height: 300px;
    top: -50px; right: 15%;
    background: radial-gradient(circle, rgba(134,239,172,0.10) 0%, transparent 70%);
    filter: blur(40px);
  }

  .page-hero-content {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.10em;
    color: var(--color-accent);
    background: rgba(255,107,157,0.08);
    border: 1px solid rgba(255,107,157,0.20);
    padding: 4px 14px;
    border-radius: var(--radius-full);
  }

  .hero-chip-seed {
    color: var(--color-sage);
  }

  .hero-title {
    font-family: var(--font-deco);
    font-size: var(--text-5xl);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 30px rgba(255,107,157,0.2);
  }

  .hero-sub {
    font-size: var(--text-sm);
    color: var(--color-muted);
    max-width: 500px;
  }

  /* ═══ GARDEN GRID ═══ */
  .garden-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-20);
  }

  .garden-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }

  .garden-plant {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--plant-bg);
    border: 1px solid var(--plant-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    backdrop-filter: blur(8px);
    transition:
      background var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  .garden-plant:hover {
    transform: translateY(-2px);
    box-shadow: var(--plant-glow);
    border-color: var(--plant-accent);
    background: linear-gradient(
      145deg,
      var(--plant-bg, var(--color-bg-2)) 0%,
      color-mix(in srgb, var(--plant-bg, var(--color-bg-2)), var(--plant-accent, var(--color-accent)) 8%) 100%
    );
  }

  .plant-icon {
    font-size: 28px;
    color: var(--plant-accent);
    text-shadow: var(--plant-glow);
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .plant-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .plant-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .plant-desc {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    line-height: 1.5;
    font-weight: 500;
  }

  .plant-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-1);
  }

  .plant-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--plant-accent);
    background: var(--plant-bg);
    border: 1px solid var(--plant-border);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  @media (max-width: 768px) {
    .page-hero { padding: var(--space-12) var(--space-4) var(--space-8); }
    .hero-title { font-size: var(--text-4xl); }
    .garden-page { padding: 0 var(--space-4) var(--space-12); }
    .garden-grid { grid-template-columns: 1fr; }
  }
</style>
