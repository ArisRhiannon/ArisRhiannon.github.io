---
import Base from '../layouts/Base.astro';
import { getNowItems } from '../lib/now';
import { getProfile } from '../lib/feed';
import { isAdmin } from '../lib/auth';
import { ADMIN_JWT_SECRET } from '../lib/env';

const items = getNowItems();
const profile = getProfile();
const authenticated = await isAdmin(Astro.request, ADMIN_JWT_SECRET());

const location = profile?.location ?? '';
const fecha = new Date().toLocaleDateString('es-MX', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<Base title="ahora · aris" description="Que estoy haciendo en este momento">
 <section class="now-page">
 <div class="celestial-line" aria-hidden="true"></div>

 <div class="now-content">
 <header class="now-header">
 <div class="now-badge">Archivo Personal</div>
 <h1 class="now-title">ahora</h1>
 <p class="now-subtitle">que estoy haciendo</p>
 <p class="now-location">{location}</p>
 <p class="now-updated">actualizado el {fecha}</p>
 </header>

 <div class="celestial-separator" aria-hidden="true">
 <span class="sep-dot"></span><span class="sep-line"></span>
 <span class="sep-dot"></span><span class="sep-line"></span>
 <span class="sep-dot"></span>
 </div>

 <!-- Items — from DB -->
 <ul class="now-journal" role="list" id="now-journal">
 {items.map((item) => (
 <li class="journal-entry" data-now-id={item.id}>
 <span class="entry-icon" aria-hidden="true">{item.icon}</span>
 <div class="entry-body">
 <span class="entry-cat">{item.category}</span>
 <p class="entry-text">{item.text}</p>
 </div>
 {authenticated && (
 <div class="entry-admin">
 <button class="entry-edit-btn" data-action="edit" data-id={item.id} title="Editar">&#9998;</button>
 <button class="entry-del-btn" data-action="delete" data-id={item.id} title="Eliminar">&#10005;</button>
 </div>
 )}
 </li>
 ))}
 </ul>

 <!-- Empty state -->
 {items.length === 0 && (
 <p class="now-empty">sin entradas todavia...</p>
 )}

 <div class="celestial-separator" aria-hidden="true">
 <span class="sep-dot"></span><span class="sep-line"></span>
 <span class="sep-dot"></span><span class="sep-line"></span>
 <span class="sep-dot"></span>
 </div>

 <!-- Admin: Add new entry -->
 {authenticated && (
 <div class="now-admin" id="now-admin">
 <div class="now-admin-head">nueva entrada</div>
 <form class="now-form" id="now-form">
 <div class="now-form-row">
 <input type="text" class="now-input now-icon-input" name="icon" placeholder="💭" maxlength="4" value="💭" />
 <input type="text" class="now-input now-cat-input" name="category" placeholder="categoria" maxlength="40" required />
 </div>
 <textarea class="now-input now-text-input" name="text" placeholder="que estas haciendo..." maxlength="200" required></textarea>
 <button type="submit" class="now-submit">agregar</button>
 </form>
 </div>
 )}

 <!-- Edit modal -->
 {authenticated && (
 <div class="now-edit-modal" id="now-edit-modal" aria-hidden="true">
 <div class="now-edit-backdrop" id="now-edit-backdrop"></div>
 <div class="now-edit-panel">
 <div class="now-edit-head">editar entrada</div>
 <form class="now-form" id="now-edit-form">
 <input type="hidden" name="id" />
 <div class="now-form-row">
 <input type="text" class="now-input now-icon-input" name="icon" placeholder="💭" maxlength="4" />
 <input type="text" class="now-input now-cat-input" name="category" placeholder="categoria" maxlength="40" required />
 </div>
 <textarea class="now-input now-text-input" name="text" placeholder="que estas haciendo..." maxlength="200" required></textarea>
 <div class="now-edit-actions">
 <button type="submit" class="now-submit">guardar</button>
 <button type="button" class="now-cancel" id="now-edit-cancel">cancelar</button>
 </div>
 </form>
 </div>
 </div>
 )}

 <div class="page-ornament" aria-hidden="true"></div>
 </div>
 </section>
</Base>

<script>
function getCookie(name: string): string | undefined {
 return document.cookie
 .split('; ')
 .find(row => row.startsWith(name + '='))
 ?.split('=')[1];
}

async function apiNow(method: string, body?: any) {
 const token = getCookie('admin_token');
 const res = await fetch('/api/now', {
 method,
 headers: {
 'Content-Type': 'application/json',
 ...(token ? { 'Authorization': 'Bearer ' + token } : {}),
 },
 body: body ? JSON.stringify(body) : undefined,
 });
 return res.json();
}

function initNowAdmin() {
 const form = document.getElementById('now-form') as HTMLFormElement | null;
 const editForm = document.getElementById('now-edit-form') as HTMLFormElement | null;
 const editModal = document.getElementById('now-edit-modal') as HTMLElement | null;
 const editBackdrop = document.getElementById('now-edit-backdrop') as HTMLElement | null;
 const editCancel = document.getElementById('now-edit-cancel') as HTMLButtonElement | null;

 // Add new entry
 form?.addEventListener('submit', async (e) => {
 e.preventDefault();
 const fd = new FormData(form);
 const data = {
 icon: fd.get('icon') || '💭',
 category: fd.get('category'),
 text: fd.get('text'),
 };
 if (!data.category || !data.text) return;

 await apiNow('POST', data);
 form.reset();
 (form.querySelector('[name="icon"]') as HTMLInputElement)?.setAttribute('value', '💭');
 location.reload();
 });

 // Delete entry
 document.querySelectorAll('[data-action="delete"]').forEach(btn => {
 btn.addEventListener('click', async () => {
 const id = (btn as HTMLElement).dataset.id;
 if (!id || !confirm('eliminar esta entrada?')) return;
 await apiNow('DELETE', { id: Number(id) });
 location.reload();
 });
 });

 // Edit entry — open modal
 document.querySelectorAll('[data-action="edit"]').forEach(btn => {
 btn.addEventListener('click', () => {
 const entry = (btn as HTMLElement).closest('.journal-entry') as HTMLElement;
 if (!entry || !editForm || !editModal) return;

 const id = entry.dataset.nowId;
 const icon = entry.querySelector('.entry-icon')?.textContent?.trim() || '💭';
 const cat = entry.querySelector('.entry-cat')?.textContent?.trim() || '';
 const text = entry.querySelector('.entry-text')?.textContent?.trim() || '';

 editForm.querySelector('[name="id"]')?.setAttribute('value', id || '');
 (editForm.querySelector('[name="icon"]') as HTMLInputElement)?.setAttribute('value', icon);
 (editForm.querySelector('[name="category"]') as HTMLInputElement)?.setAttribute('value', cat);
 (editForm.querySelector('[name="text"]') as HTMLTextAreaElement)?.setAttribute('value', text);

 editModal.setAttribute('aria-hidden', 'false');
 });
 });

 // Close modal
 const closeModal = () => editModal?.setAttribute('aria-hidden', 'true');
 editBackdrop?.addEventListener('click', closeModal);
 editCancel?.addEventListener('click', closeModal);

 // Save edit
 editForm?.addEventListener('submit', async (e) => {
 e.preventDefault();
 const fd = new FormData(editForm);
 const data = {
 id: Number(fd.get('id')),
 icon: fd.get('icon') || '💭',
 category: fd.get('category'),
 text: fd.get('text'),
 };
 await apiNow('PUT', data);
 closeModal();
 location.reload();
 });
}

initNowAdmin();
document.addEventListener('astro:page-load', initNowAdmin);
</script>

<style>
 .now-page {
 position: relative;
 min-height: 100vh;
 padding: var(--space-12) var(--space-6);
 display: flex;
 flex-direction: column;
 align-items: center;
 }

 .celestial-line {
 position: absolute;
 top: 0;
 left: 50%;
 transform: translateX(-50%);
 width: min(100%, 48rem);
 height: 1px;
 background: linear-gradient(to right, transparent, rgba(255,107,157,0.3), transparent);
 opacity: 0.3;
 }

 .now-content {
 width: 100%;
 max-width: 42rem;
 }

 /* ═══ Header ═══ */
 .now-header {
 text-align: center;
 margin-bottom: var(--space-12);
 }

 .now-badge {
 display: inline-block;
 padding: 4px 12px;
 border-radius: var(--radius-full);
 background: rgba(255,107,157,0.10);
 border: 1px solid rgba(255,107,157,0.20);
 font-family: var(--font-mono);
 font-size: 9px;
 font-weight: 700;
 letter-spacing: 0.2em;
 text-transform: uppercase;
 color: var(--color-accent);
 text-shadow: var(--glow-sm);
 animation: pulse-badge 3s ease-in-out infinite;
 margin-bottom: var(--space-4);
 }

 @keyframes pulse-badge {
 0%, 100% { opacity: 1; }
 50% { opacity: 0.6; }
 }

 .now-title {
 font-family: var(--font-deco);
 font-size: var(--text-5xl);
 font-weight: 700;
 color: var(--color-ink);
 line-height: 1.1;
 margin-bottom: var(--space-2);
 text-shadow: 0 2px 30px rgba(255,107,157,0.15);
 }

 .now-subtitle {
 font-family: var(--font-mono);
 font-size: var(--text-sm);
 color: var(--color-muted);
 letter-spacing: 0.12em;
 text-transform: uppercase;
 margin-bottom: var(--space-6);
 }

 .now-location {
 font-family: var(--font-mono);
 font-size: var(--text-xs);
 font-weight: 600;
 color: var(--color-muted);
 letter-spacing: 0.06em;
 }

 .now-updated {
 font-family: var(--font-mono);
 font-size: var(--text-xs);
 color: var(--color-muted-2);
 letter-spacing: 0.04em;
 margin-top: var(--space-1);
 }

 /* ═══ Separator ═══ */
 .celestial-separator {
 display: flex;
 align-items: center;
 justify-content: center;
 gap: var(--space-3);
 margin: var(--space-10) 0;
 }

 .sep-dot {
 width: 3px; height: 3px;
 border-radius: 50%;
 background: var(--color-accent);
 opacity: 0.4;
 flex-shrink: 0;
 }

 .sep-line {
 width: 40px; height: 1px;
 background: linear-gradient(to right, transparent, var(--color-border-accent), transparent);
 flex-shrink: 0;
 }

 /* ═══ Journal Entries ═══ */
 .now-journal {
 list-style: none;
 display: flex;
 flex-direction: column;
 gap: var(--space-8);
 }

 .journal-entry {
 display: flex;
 align-items: flex-start;
 gap: var(--space-5);
 transition: opacity var(--duration-slow) var(--ease-out);
 }

 .journal-entry:hover .entry-cat {
 color: var(--color-accent-hi);
 text-shadow: var(--glow-sm);
 }

 .journal-entry:hover .entry-text {
 color: var(--color-ink);
 }

 .entry-icon {
 font-size: 36px;
 line-height: 1;
 flex-shrink: 0;
 margin-top: 2px;
 filter: drop-shadow(0 0 6px rgba(255,107,157,0.15));
 }

 .entry-body {
 display: flex;
 flex-direction: column;
 gap: var(--space-1);
 padding-top: var(--space-1);
 flex: 1;
 }

 .entry-cat {
 font-family: var(--font-mono);
 font-size: var(--text-xs);
 text-transform: uppercase;
 letter-spacing: 0.14em;
 color: var(--color-accent);
 font-weight: 700;
 transition: color var(--duration), text-shadow var(--duration);
 }

 .entry-text {
 font-family: var(--font-body);
 font-size: var(--text-lg);
 color: var(--color-ink-soft);
 line-height: 1.6;
 font-weight: 500;
 transition: color var(--duration);
 }

 /* ═══ Entry Admin Buttons ═══ */
 .entry-admin {
 display: flex;
 gap: var(--space-1);
 opacity: 0;
 transition: opacity var(--duration);
 flex-shrink: 0;
 }

 .journal-entry:hover .entry-admin {
 opacity: 1;
 }

 .entry-edit-btn, .entry-del-btn {
 background: none;
 border: 1px solid var(--color-border);
 border-radius: var(--radius-sm);
 color: var(--color-muted-2);
 font-size: 12px;
 cursor: pointer;
 padding: 3px 6px;
 transition: all var(--duration);
 }

 .entry-edit-btn:hover {
 color: var(--color-accent);
 border-color: var(--color-border-accent);
 background: rgba(255,107,157,0.06);
 }

 .entry-del-btn:hover {
 color: #e74c3c;
 border-color: rgba(231,76,60,0.3);
 background: rgba(231,76,60,0.06);
 }

 /* ═══ Empty State ═══ */
 .now-empty {
 text-align: center;
 font-family: var(--font-mono);
 font-size: var(--text-sm);
 color: var(--color-muted-2);
 letter-spacing: 0.06em;
 padding: var(--space-8) 0;
 }

 /* ═══ Admin Form ═══ */
 .now-admin {
 border: 1px dashed var(--color-border);
 border-radius: var(--radius-lg);
 padding: var(--space-5);
 margin-top: var(--space-4);
 background: rgba(255,107,157,0.02);
 }

 .now-admin-head {
 font-family: var(--font-mono);
 font-size: 9px;
 font-weight: 700;
 letter-spacing: 0.14em;
 text-transform: uppercase;
 color: var(--color-muted-2);
 margin-bottom: var(--space-3);
 }

 .now-form {
 display: flex;
 flex-direction: column;
 gap: var(--space-3);
 }

 .now-form-row {
 display: flex;
 gap: var(--space-2);
 }

 .now-input {
 font-family: var(--font-mono);
 font-size: var(--text-xs);
 color: var(--color-ink);
 background: var(--color-surface);
 border: 1px solid var(--color-border);
 border-radius: var(--radius-sm);
 padding: var(--space-2) var(--space-3);
 outline: none;
 transition: border-color var(--duration), box-shadow var(--duration);
 }

 .now-input:focus {
 border-color: var(--color-border-accent);
 box-shadow: var(--glow-sm);
 }

 .now-icon-input { width: 3.5rem; text-align: center; }
 .now-cat-input { flex: 1; }
 .now-text-input {
 width: 100%;
 min-height: 3rem;
 resize: vertical;
 }

 .now-submit {
 font-family: var(--font-mono);
 font-size: var(--text-xs);
 font-weight: 700;
 letter-spacing: 0.08em;
 color: var(--color-accent);
 background: rgba(255,107,157,0.08);
 border: 1px solid var(--color-border-accent);
 border-radius: var(--radius-sm);
 padding: var(--space-2) var(--space-5);
 cursor: pointer;
 transition: all var(--duration);
 }

 .now-submit:hover {
 background: rgba(255,107,157,0.15);
 box-shadow: var(--glow-sm);
 }

 .now-cancel {
 font-family: var(--font-mono);
 font-size: var(--text-xs);
 color: var(--color-muted-2);
 background: none;
 border: 1px solid var(--color-border);
 border-radius: var(--radius-sm);
 padding: var(--space-2) var(--space-5);
 cursor: pointer;
 transition: all var(--duration);
 }

 .now-cancel:hover {
 border-color: var(--color-muted-2);
 color: var(--color-muted);
 }

 /* ═══ Edit Modal ═══ */
 .now-edit-modal {
 position: fixed;
 inset: 0;
 z-index: 60;
 display: flex;
 align-items: center;
 justify-content: center;
 pointer-events: none;
 opacity: 0;
 transition: opacity 0.2s;
 }

 .now-edit-modal[aria-hidden="false"] {
 pointer-events: all;
 opacity: 1;
 }

 .now-edit-backdrop {
 position: absolute;
 inset: 0;
 background: rgba(0,0,0,0.5);
 backdrop-filter: blur(4px);
 }

 .now-edit-panel {
 position: relative;
 width: min(90vw, 28rem);
 background: var(--color-surface);
 border: 1px solid var(--color-border);
 border-radius: var(--radius-xl);
 padding: var(--space-6);
 }

 .now-edit-head {
 font-family: var(--font-mono);
 font-size: 9px;
 font-weight: 700;
 letter-spacing: 0.14em;
 text-transform: uppercase;
 color: var(--color-muted-2);
 margin-bottom: var(--space-4);
 }

 .now-edit-actions {
 display: flex;
 gap: var(--space-3);
 }

 /* ═══ Page Ornament ═══ */
 .page-ornament {
 width: 3rem;
 height: 1px;
 background: var(--color-border);
 margin: var(--space-16) auto 0;
 }

 /* ═══ MOBILE ═══ */
 @media (max-width: 768px) {
 .now-page { padding: var(--space-8) var(--space-4); }
 .now-title { font-size: var(--text-4xl); }
 .now-journal { gap: var(--space-6); }
 .entry-icon { font-size: 28px; }
 .entry-text { font-size: var(--text-base); }
 .celestial-separator { margin: var(--space-6) 0; }
 .sep-line { width: 24px; }
 .entry-admin { opacity: 1; }
 }
</style>
