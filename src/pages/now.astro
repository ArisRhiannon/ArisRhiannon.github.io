---
import Base from '../layouts/Base.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

const nowData = JSON.parse(readFileSync(join(process.cwd(), 'data', 'now.json'), 'utf-8'));
const { updated, location, items } = nowData;

const fecha = new Date(updated).toLocaleDateString('es-MX', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Base title="ahora · aris" description="Qué estoy haciendo en este momento">

  <!-- ── BANNER ── -->
  <div class="page-banner" aria-hidden="true">
    <div class="banner-glow"></div>
    <div class="banner-shimmer"></div>
    <div class="banner-content">
      <div class="banner-meta">
        <span class="banner-chip">ahora</span>
        <span class="banner-sep">·</span>
        <span class="banner-loc">{location}</span>
      </div>
      <h1 class="banner-title">qué estoy haciendo</h1>
    </div>
  </div>

  <!-- ── CONTENIDO ── -->
  <div class="now-page">
    <p class="now-updated">actualizado el {fecha}</p>

    <ul class="now-grid" role="list">
      {items.map((item) => (
        <li class="now-card">
          <div class="now-card-icon" aria-hidden="true">{item.icon}</div>
          <div class="now-card-body">
            <span class="now-card-cat">{item.category}</span>
            <p class="now-card-text">{item.text}</p>
          </div>
        </li>
      ))}
    </ul>

    <p class="now-credit">
      inspirado por <a href="https://nownownow.com" target="_blank" rel="noopener">nownownow.com</a>
    </p>
  </div>

</Base>

<style>
  /* ── BANNER ── */
  .page-banner {
    position: relative;
    width: calc(100% + var(--space-8) * 2);
    margin: calc(-1 * var(--space-8)) calc(-1 * var(--space-8)) var(--space-8);
    height: 180px;
    background: linear-gradient(160deg,
      #F0B4C4 0%,
      #F4C0CE 40%,
      #F8D0DA 70%,
      #FCE6EC 100%
    );
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .banner-glow {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 15% 50%, rgba(255,255,255,0.4) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 85% 50%, rgba(255,130,170,0.3) 0%, transparent 55%);
    pointer-events: none;
  }

  .banner-shimmer {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent 0px, transparent 28px,
      rgba(255,255,255,0.07) 28px, rgba(255,255,255,0.07) 30px
    );
    pointer-events: none;
  }

  .banner-content {
    position: relative; z-index: 1;
    padding: var(--space-5) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .banner-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .banner-chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(255, 255, 255, 0.65);
    padding: 2px 10px;
    border-radius: var(--radius-full);
  }

  .banner-sep {
    color: rgba(255,255,255,0.6);
    font-size: var(--text-sm);
  }

  .banner-loc {
    font-size: var(--text-sm);
    font-weight: 600;
    color: rgba(255,255,255,0.8);
  }

  .banner-title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 20px rgba(180,40,80,0.28);
  }

  /* ── CONTENIDO ── */
  .now-page {
    max-width: 800px;
    /* sin margin: auto — arranca desde la izquierda */
  }

  .now-updated {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-6);
  }

  .now-grid {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .now-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(10px);
    transition:
      background var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  .now-card:hover {
    background: var(--color-surface-2);
    border-color: rgba(212, 68, 122, 0.18);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .now-card-icon {
    font-size: var(--text-2xl);
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .now-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .now-card-cat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--color-accent);
    font-weight: 700;
  }

  .now-card-text {
    font-size: var(--text-base);
    color: var(--color-ink);
    line-height: 1.5;
    font-weight: 600;
  }

  .now-credit {
    font-size: var(--text-xs);
    color: var(--color-muted);
    font-weight: 600;
  }

  .now-credit a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--duration);
  }

  .now-credit a:hover { border-color: var(--color-accent); }

  @media (max-width: 720px) {
    .page-banner {
      width: calc(100% + var(--space-4) * 2);
      margin: calc(-1 * var(--space-4)) calc(-1 * var(--space-4)) var(--space-5);
      height: 140px;
    }

    .banner-title { font-size: 1.8rem; }
    .banner-content { padding: var(--space-4); }
    .now-page { padding: 0; }
  }
</style>
