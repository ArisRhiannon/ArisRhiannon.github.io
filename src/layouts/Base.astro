---
import { ClientRouter } from 'astro:transitions';
import BgCanvas from '../features/background/BgCanvas.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'aris-sama',
  description = 'colecciono nitos · gdl.mx',
} = Astro.props;

const navItems = [
  { label: 'jardin', href: '/garden' },
  { label: 'videos', href: '/videos' },
  { label: 'gacha', href: '/gacha' },
  { label: 'anime', href: '/anime' },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Kaisei+Decol:wght@400;700&family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">
 <link rel="stylesheet" href="/design-tokens.css" />
 <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
 <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
 <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
 <link rel="icon" sizes="180x180" href="/favicon-180.png" />
 <link rel="shortcut icon" href="/favicon.ico" />
 <ClientRouter />
</head>
<body>

  <BgCanvas />

  <!-- ── Fondo atmosferico ── -->
  <div class="bg-layer" aria-hidden="true">
    <div class="bg-orb bg-orb-a"></div>
    <div class="bg-orb bg-orb-b"></div>
    <div class="bg-orb bg-orb-c"></div>
  </div>

  <!-- ── Overlay de transicion ── -->
  <!-- Using View Transitions API for temporal dissolve effect -->

  <!-- ── HEADER FLOTANTE ── -->
  <header class="site-header" id="site-header">
    <div class="header-inner">
      <a href="/" class="header-logo" aria-label="Inicio">
        <span class="logo-kaomoji">(o-ᴗ-)</span>
        <span class="logo-name">aris</span>
      </a>

      <nav class="header-nav" role="navigation" aria-label="Paginas">
        {navItems.map(item => (
          <a href={item.href} class="nav-pill" data-nav-href={item.href}>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="header-actions">
        <span class="header-status">
          <span class="status-dot" aria-hidden="true"></span>
          online
        </span>
      </div>
    </div>

    <!-- Mobile menu toggle -->
    <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu" aria-expanded="false">
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </header>

  <!-- Mobile overlay menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav">
      {navItems.map(item => (
        <a href={item.href} class="mobile-nav-link" data-nav-href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- ── MAIN CONTENT ── -->
  <main class="site-main">
    <slot />
  </main>

  <!-- ── FOOTER ── -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-kaomoji">( - -)</span>
      <span class="footer-text">guadalajara mx · oracle arm · astro</span>
      <span class="footer-kaomoji">( - -)</span>
    </div>
  </footer>

<!-- Micro-interactions: 3D tilt, magnetic buttons, clip-path reveals -->
<script src="../scripts/micro-interactions.ts"></script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    color-scheme: only dark;
    height: 100%;
  }

  body {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-ink);
    min-height: 100dvh;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* Scrollbar personalizada */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--color-bg); }
  ::-webkit-scrollbar-thumb {
    background: var(--color-muted-2);
    border-radius: var(--radius-full);
  }
  ::-webkit-scrollbar-thumb:hover { background: var(--color-muted); }

  /* Selección de texto con tinte rosa */
  ::selection {
    background: rgba(232, 64, 96, 0.15);
    color: var(--color-ink);
  }

  /* Focus visible unificado */
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* Links base */
  a {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration) var(--ease-out);
  }

  /* ═══ FONDO ATMOSFERICO ═══ */
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .bg-orb-a {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(140, 123, 181, 0.22) 0%, transparent 70%);
    top: -200px; left: -150px;
    animation: orb-drift 25s ease-in-out infinite alternate;
  }

  .bg-orb-b {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(207, 162, 64, 0.15) 0%, transparent 70%);
    bottom: -150px; right: -100px;
    animation: orb-drift 35s ease-in-out infinite alternate-reverse;
  }

  .bg-orb-c {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(163, 148, 204, 0.12) 0%, transparent 70%);
    top: 40%; left: 50%;
    transform: translate(-50%, -50%);
    animation: orb-drift 45s ease-in-out infinite alternate;
  }

  @keyframes orb-drift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(40px, 30px) scale(1.1); }
  }

 /* ═══ VIEW TRANSITIONS — Temporal Dissolve ═══ */
/* Old page: sinks down with blur — like diving into water */
::view-transition-old(root) {
  animation: dissolve-out 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
}
::view-transition-new(root) {
  animation: dissolve-in 0.45s 0.05s cubic-bezier(0.4, 0, 0.2, 1) both;
}

@keyframes dissolve-out {
  from { opacity: 1; transform: translateY(0); filter: blur(0); }
  to   { opacity: 0; transform: translateY(8px); filter: blur(4px); }
}

@keyframes dissolve-in {
  from { opacity: 0; transform: translateY(-8px); filter: blur(4px); }
  to   { opacity: 1; transform: translateY(0); filter: blur(0); }
}

/* Reduce motion for accessibility */
@media (prefers-reduced-motion: reduce) {
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
  }
  ::view-transition-old(root) { opacity: 0; }
  ::view-transition-new(root) { opacity: 1; }
}

 /* ═══ HEADER FLOTANTE ═══ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--color-topbar);
    backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid var(--color-border);
    transition: transform 0.3s var(--ease-out), opacity 0.3s;
  }

  .site-header.header-hidden {
    transform: translateY(-100%);
    opacity: 0;
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-8);
    height: 56px;
    gap: var(--space-6);
  }

  /* Logo */
  .header-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-kaomoji {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--color-accent);
    text-shadow: 0 0 10px rgba(255,107,157,0.4);
    line-height: 1;
  }

  .logo-name {
    font-family: var(--font-deco);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: 0.01em;
  }

  /* Nav pills */
  .header-nav {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-pill {
    position: relative;
    padding: 6px 16px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    transition:
      color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      background var(--duration) var(--ease-out),
      box-shadow var(--duration) var(--ease-out);
  }

  .nav-pill:hover {
    color: var(--color-accent);
    border-color: var(--color-border-accent);
    background: rgba(255,107,157,0.06);
    box-shadow: var(--glow-sm);
  }

  .nav-pill.active {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgba(255,107,157,0.08);
    box-shadow: var(--glow-sm);
  }

  /* Status */
  .header-actions {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-sage);
    box-shadow: 0 0 8px rgba(134,239,172,0.5);
    animation: dot-pulse 2.8s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: none;
    position: fixed;
    top: 14px;
    right: 16px;
    z-index: 1001;
    width: 36px;
    height: 36px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    cursor: pointer;
    backdrop-filter: blur(12px);
  }

  .menu-bar {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--color-accent);
    border-radius: 2px;
    transition: transform 0.3s var(--ease-out), opacity 0.2s;
  }

  .mobile-menu-btn[aria-expanded="true"] .menu-bar:nth-child(1) {
    transform: rotate(45deg) translate(2.5px, 2.5px);
  }
  .mobile-menu-btn[aria-expanded="true"] .menu-bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-btn[aria-expanded="true"] .menu-bar:nth-child(3) {
    transform: rotate(-45deg) translate(2.5px, -2.5px);
  }

  /* Mobile menu overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(26, 21, 32, 0.97);
    backdrop-filter: blur(30px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s var(--ease-out);
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .mobile-nav-link {
    font-family: var(--font-deco);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color var(--duration), text-shadow var(--duration);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-accent);
    text-shadow: var(--glow-md);
  }

  /* ═══ MAIN ═══ */
  .site-main {
    position: relative;
    z-index: 1;
    min-height: 100dvh;
    padding-top: 56px; /* header height */
  }

  /* ═══ FOOTER ═══ */
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    padding: var(--space-6) var(--space-8);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
  }

  .footer-kaomoji {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent);
    opacity: 0.4;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }

  /* ═══ ANIMACIONES DE ENTRADA ═══ */
  .yume-init {
    opacity: 0;
    transform: translateY(16px);
  }

  .yume-init.booted {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══ MOBILE ═══ */
  @media (max-width: 768px) {
    .header-inner {
      padding: 0 var(--space-4);
    }

    .header-nav {
      display: none;
    }

    .header-actions {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .site-main {
      padding-top: 56px;
    }

    .bg-orb-c { display: none; }
    .bg-orb-a { width: 300px; height: 300px; filter: blur(60px); }
    .bg-orb-b { width: 250px; height: 250px; filter: blur(60px); }

    .footer-inner { flex-wrap: wrap; justify-content: center; text-align: center; }
  }
</style>

<script>
// ── TRANSICION — Radial wipe from click position ──
function runTransition(cb?: () => void) {
 const overlay = document.getElementById('page-overlay');
 if (!overlay) { cb?.(); return; }
 overlay.classList.add('active');
 setTimeout(() => {
 overlay.classList.remove('active');
 setTimeout(() => cb?.(), 100);
 }, 450);
}

// Capture click position for radial origin
document.addEventListener('click', (e) => {
 const overlay = document.getElementById('page-overlay');
 if (!overlay) return;
 const x = ((e.clientX / window.innerWidth) * 100).toFixed(1) + '%';
 const y = ((e.clientY / window.innerHeight) * 100).toFixed(1) + '%';
 overlay.style.setProperty('--tx', x);
 overlay.style.setProperty('--ty', y);
});

// ── HEADER HIDE ON SCROLL ──
(function initHeaderScroll() {
  let lastScroll = 0;
  const header = document.getElementById('site-header');
  if (!header) return;

  window.addEventListener('scroll', () => {
    const current = window.scrollY;
    if (current > 120 && current > lastScroll) {
      header.classList.add('header-hidden');
    } else {
      header.classList.remove('header-hidden');
    }
    lastScroll = current;
  }, { passive: true });
})();

// ── MOBILE MENU ──
(function initMobileMenu() {
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (!btn || !menu) return;

  btn.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    menu.classList.toggle('open', !isOpen);
    menu.setAttribute('aria-hidden', String(isOpen));
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      btn.setAttribute('aria-expanded', 'false');
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
})();

// ── ANIMACIONES DE ENTRADA ──
function staggerItems() {
 document.querySelectorAll<HTMLElement>(
 '.now-list .now-item, .now-grid .now-card, .video-grid .video-card, ' +
 '.items-list .item-card, .stat-grid .stat-card, .now-preview .now-item, ' +
 '.garden-plant, .gacha-card, .journal-entry'
 ).forEach((el, i) => { el.dataset.yumeDelay = String(i * 70); });
}

function initItems() {
 const targets = document.querySelectorAll<HTMLElement>(
 'article, .video-card, .now-item, .now-card, li.now-card, .stat, ' +
 '.stat-card, .module-card, .va-card, .item-card, .gacha-card, .garden-plant, ' +
 '.journal-entry, .now-header, .now-badge, .home-hero, .page-ornament, [data-yume]'
 );
 if (!targets.length) return;
 const obs = new IntersectionObserver(entries => {
 entries.forEach(entry => {
 if (!entry.isIntersecting) return;
 obs.unobserve(entry.target);
 const el = entry.target as HTMLElement;
 const delay = parseFloat(el.dataset.yumeDelay ?? '0');
 setTimeout(() => {
 el.style.transition = 'opacity .5s var(--ease-out)';
 el.classList.add('booted');
 }, delay);
 });
 }, { threshold: 0.04, rootMargin: '0px 0px -16px 0px' });
 targets.forEach(el => { el.classList.add('yume-init'); obs.observe(el); });
}

// ── NAV ACTIVA ──
function markActiveNav() {
  const path = location.pathname;
  document.querySelectorAll<HTMLElement>('.nav-pill, .mobile-nav-link').forEach(a => {
    const href = a.getAttribute('href') ?? a.dataset.navHref ?? '';
    const isActive = href === '/' ? path === '/' : path.startsWith(href);
    a.classList.toggle('active', isActive);
  });
}

// ── HOOKS ──
function onPageLoad() { markActiveNav(); staggerItems(); initItems(); }

document.addEventListener('astro:before-preparation', () => runTransition());
document.addEventListener('astro:page-load', onPageLoad);
document.addEventListener('DOMContentLoaded', () => {
  onPageLoad();
  const overlay = document.getElementById('page-overlay');
  if (!overlay) return;
 overlay.classList.add('active');
 setTimeout(() => overlay.classList.remove('active'), 400);
});
</script>
