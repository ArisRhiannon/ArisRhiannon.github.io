<div id="synth-drop" style="position:fixed;top:3.5rem;left:1.25rem;z-index:9999;display:flex;align-items:center;gap:0.5rem;padding:0.4rem 0.75rem;background:rgba(10,10,18,0.82);backdrop-filter:blur(16px);border:1px dashed rgba(168,85,247,0.4);border-radius:2rem;font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:#A78BFA;cursor:pointer;transition:border-color 0.2s,box-shadow 0.2s;">
  <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M4 4l3-3 3 3M2 10v2a1 1 0 001 1h8a1 1 0 001-1v-2" stroke="#A855F7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  <span id="synth-label">soltar audio aquí</span>
</div>
<input type="file" id="synth-file" accept="audio/*,video/mp4,video/webm,.mp3,.mp4,.ogg,.opus,.flac,.wav,.aac,.m4a" style="display:none"/>
<canvas id="danmaku"></canvas>

<script>
document.addEventListener('astro:page-load', () => {

// ── Drag & drop audio ─────────────────────────────────────────
const drop  = document.getElementById('synth-drop');
const input = document.getElementById('synth-file');
window.__radioSynth = window.__radioSynth || {active:false,bass:0,mid:0,high:0,energy:0,beat:false};
let audioCtx=null,analyser=null,sourceNode=null,audioEl=null,objURL=null,synthRaf=null;

function ensureAudioCtx() {
  if(audioCtx) return;
  audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  analyser=audioCtx.createAnalyser();
  analyser.fftSize=2048;
  analyser.smoothingTimeConstant=0.75;
}
function startAudioLoop() {
  if(synthRaf) return;
  const freqData=new Uint8Array(analyser.frequencyBinCount);
  const NYQ=audioCtx.sampleRate/2,BINS=analyser.frequencyBinCount;
  const fb=hz=>Math.round(hz/NYQ*BINS);
  const BLO=fb(20),BHI=fb(250),MHI=fb(4000),HHI=fb(18000);
  let prevBass=0,beatCD=0;
  function tick(){
    synthRaf=requestAnimationFrame(tick);
    analyser.getByteFrequencyData(freqData);
    let bs=0,ms=0,hs=0,ts=0;
    for(let i=BLO;i<BHI;i++)bs+=freqData[i];
    for(let i=BHI;i<MHI;i++)ms+=freqData[i];
    for(let i=MHI;i<HHI;i++)hs+=freqData[i];
    for(let i=0;i<BINS;i++)ts+=freqData[i];
    const bn=bs/((BHI-BLO)*255),mn=ms/((MHI-BHI)*255),
          hn=hs/((HHI-MHI)*255),en=ts/(BINS*255);
    let beat=false;
    if(beatCD<=0&&bn-prevBass>0.18&&bn>0.35){beat=true;beatCD=12;}
    if(beatCD>0)beatCD--;
    prevBass=bn*0.6+prevBass*0.4;
    window.__radioSynth={active:true,bass:bn,mid:mn,high:hn,energy:en,beat};
  }
  tick();
}
function loadFile(file){
  if(audioCtx){try{audioCtx.close();}catch(e){}}
  audioCtx=null;analyser=null;sourceNode=null;synthRaf=null;
  if(objURL)URL.revokeObjectURL(objURL);
  objURL=URL.createObjectURL(file);
  if(!audioEl){audioEl=new Audio();audioEl.loop=true;}
  audioEl.pause();audioEl.src=objURL;audioEl.loop=true;
  ensureAudioCtx();
  audioEl.play().then(()=>{
    sourceNode=audioCtx.createMediaElementSource(audioEl);
    sourceNode.connect(analyser);
    analyser.connect(audioCtx.destination);
    startAudioLoop();
  }).catch(e=>{
    try{sourceNode=audioCtx.createMediaElementSource(audioEl);}catch(e2){}
    if(sourceNode){sourceNode.connect(analyser);analyser.connect(audioCtx.destination);}
    startAudioLoop();
    audioEl.play().catch(()=>{});
  });
  const name=file.name.replace(/\.[^.]+$/,'');
  document.getElementById('synth-label').textContent='♫ '+name.slice(0,22)+(name.length>22?'…':'');
  drop.style.borderColor='rgba(34,211,238,0.6)';
  drop.style.boxShadow='0 0 16px rgba(34,211,238,0.2)';
}
if(drop&&input){
  drop.addEventListener('click',()=>input.click());
  input.addEventListener('change',()=>{if(input.files&&input.files[0])loadFile(input.files[0]);input.value='';});
  document.addEventListener('dragover',e=>{e.preventDefault();drop.style.borderColor='rgba(168,85,247,0.9)';});
  document.addEventListener('dragleave',e=>{if(e.relatedTarget===null)drop.style.borderColor='rgba(168,85,247,0.4)';});
  document.addEventListener('drop',e=>{
    e.preventDefault();drop.style.borderColor='rgba(168,85,247,0.4)';
    const file=e.dataTransfer.files&&e.dataTransfer.files[0];
    if(file&&file.type.match(/(audio|video)/))loadFile(file);
  });
}

// ── Canvas setup ──────────────────────────────────────────────
const canvas = document.getElementById("danmaku");
if (!canvas) return;
const ctx = canvas.getContext("2d", { alpha:false, desynchronized:true });
document.addEventListener("visibilitychange", () => { if (!document.hidden && !raf) loop(); });
let raf, t = 0;
function resize() { canvas.width=innerWidth; canvas.height=innerHeight; }
resize();
const onResize = () => resize();
window.addEventListener("resize", onResize);
let CX=canvas.width*0.5, CY=canvas.height*0.5, CMAX=Math.max(canvas.width,canvas.height);
window.addEventListener("resize", () => { CX=canvas.width*0.5;CY=canvas.height*0.5;CMAX=Math.max(canvas.width,canvas.height); });
const TWO_PI = Math.PI*2;

// ── Synthesia bus ─────────────────────────────────────────────
const SY = {
  get active()  { return !!(window.__radioSynth&&window.__radioSynth.active); },
  get bass()    { return window.__radioSynth?window.__radioSynth.bass:0; },
  get mid()     { return window.__radioSynth?window.__radioSynth.mid:0; },
  get high()    { return window.__radioSynth?window.__radioSynth.high:0; },
  get energy()  { return window.__radioSynth?window.__radioSynth.energy:0; },
  get beat()    { return window.__radioSynth?window.__radioSynth.beat:false; },
};
let sBass=0,sMid=0,sHigh=0,sEnergy=0;
function updateSynth() {
  if(!SY.active){sBass*=0.92;sMid*=0.92;sHigh*=0.92;sEnergy*=0.92;return;}
  sBass  +=(SY.bass  -sBass)  *0.12;
  sMid   +=(SY.mid   -sMid)   *0.12;
  sHigh  +=(SY.high  -sHigh)  *0.12;
  sEnergy+=(SY.energy-sEnergy)*0.12;
}

// ── Helpers ───────────────────────────────────────────────────
function timeField(x,y) {
  const dx=x-CX,dy=y-CY,r=Math.sqrt(dx*dx+dy*dy);
  return t+Math.sin(r*0.02-t*0.03)*40+Math.cos(dx*0.01+t*0.02)*20;
}
function warp(x,y,lt) {
  const dx=x-CX,dy=y-CY,r=Math.sqrt(dx*dx+dy*dy),a=Math.atan2(dy,dx);
  const wa=a+Math.sin(r*0.01+lt*0.02)*0.9+Math.cos(a*3+lt*0.015)*0.6;
  const wr=r*(1+Math.sin(a*2+lt*0.02)*0.2);
  return [CX+Math.cos(wa)*wr,CY+Math.sin(wa)*wr];
}

// ════════════════════════════════════════════════════════════════
// CAPA 0 — Órbitas
// ════════════════════════════════════════════════════════════════
const offOrbit=document.createElement("canvas");
offOrbit.width=canvas.width;offOrbit.height=canvas.height;
const octx=offOrbit.getContext("2d",{alpha:true});
const ORBIT_FAMILIES=[
  [CMAX*0.28,CMAX*0.07,0.0008, 0.55,0,  22],
  [CMAX*0.45,CMAX*0.09,0.00055,0.70,40, 18],
  [CMAX*0.62,CMAX*0.10,0.00040,0.85,80, 16],
  [CMAX*0.75,CMAX*0.08,0.00030,0.65,140,14],
  [CMAX*0.88,CMAX*0.06,0.00022,0.50,200,10],
];
let orbitSeeds=[];
function buildOrbitSeeds() {
  orbitSeeds=[];
  for(const fam of ORBIT_FAMILIES){
    const [,,,,hueOff,lineCount]=fam;
    for(let i=0;i<lineCount;i++){
      orbitSeeds.push({fam,phase0:(i/lineCount)*TWO_PI+Math.random()*0.4,phaseMod:0.5+Math.random()*1.5,wobbleMod:0.4+Math.random()*0.8,hue:(hueOff+i*(360/lineCount)*0.6+Math.random()*30)%360,bright:30+Math.random()*35,sat:40+Math.random()*50});
    }
  }
}
buildOrbitSeeds();
let orbitGlints=[],lastOrbitT=-9999;
function rebuildOrbits(tt) {
  lastOrbitT=tt;offOrbit.width=canvas.width;offOrbit.height=canvas.height;
  octx.clearRect(0,0,offOrbit.width,offOrbit.height);orbitGlints=[];
  const bassExpand=1+sBass*0.18,highCompress=1-sHigh*0.08;
  for(const seed of orbitSeeds){
    const{fam,phase0,phaseMod,wobbleMod,hue,bright,sat}=seed;
    const[rBase,rAmp,phaseSpd,angleWobble]=fam;
    const famIdx=ORBIT_FAMILIES.indexOf(fam);
    const synthScale=famIdx<2?bassExpand:highCompress;
    const r0=rBase*synthScale+rAmp*Math.sin(tt*phaseSpd*0.7+phase0*phaseMod);
    const tilt=Math.sin(tt*phaseSpd*1.3+phase0)*angleWobble*wobbleMod;
    const midWobble=sMid*0.35;
    const STEPS=200;octx.beginPath();let glintsForLine=[];
    for(let s=0;s<=STEPS;s++){
      const theta=(s/STEPS)*TWO_PI;
      const rm=r0+rAmp*0.4*Math.sin(theta*2+tt*phaseSpd*2+phase0)+rAmp*0.25*Math.sin(theta*3-tt*phaseSpd*1.5+phase0*1.3)+rAmp*0.15*Math.sin(theta*5+tt*phaseSpd*0.8+phase0*0.7)+rAmp*midWobble*Math.sin(theta*7+tt*0.05+phase0*2.1);
      const tw=theta+tilt*Math.sin(theta*1.5+tt*phaseSpd*0.5);
      const x=CX+Math.cos(tw)*rm,y=CY+Math.sin(tw)*rm*(0.85+0.15*Math.cos(theta+tilt));
      if(s===0)octx.moveTo(x,y);else octx.lineTo(x,y);
      if(s>0&&s<STEPS&&(s%Math.floor(STEPS/3))===0)glintsForLine.push({x,y,hue,bright:bright+30+sBass*25,sat:sat+20+sEnergy*30});
    }
    octx.closePath();
    const synthHue=(hue+sMid*60+sHigh*30)%360;
    octx.strokeStyle=`hsl(${synthHue|0},${(sat+sBass*30)|0}%,${(bright+sEnergy*20)|0}%)`;
    octx.globalAlpha=0.12+Math.random()*0.06+sEnergy*0.18;
    octx.lineWidth=0.4+Math.random()*0.35+sBass*1.2;
    octx.stroke();orbitGlints.push(...glintsForLine);
  }
}
function drawOrbits() {
  if(t-lastOrbitT>=90)rebuildOrbits(t);
  ctx.globalCompositeOperation="screen";ctx.globalAlpha=0.55+sEnergy*0.35;ctx.drawImage(offOrbit,0,0);
  ctx.globalCompositeOperation="lighter";
  for(const g of orbitGlints){
    const pulse=0.4+0.6*Math.abs(Math.sin(t*0.04+g.x*0.005));
    const beatBoost=SY.beat?0.5:0;
    ctx.globalAlpha=(pulse*0.7+beatBoost)*(1+sEnergy*0.6);
    ctx.fillStyle=`hsl(${g.hue|0},${g.sat|0}%,${g.bright|0}%)`;
    const sz=(1.0+pulse*1.8)*(1+sBass*0.8);
    ctx.beginPath();ctx.arc(g.x,g.y,sz,0,TWO_PI);ctx.fill();
    ctx.globalAlpha=(pulse*0.15+beatBoost*0.3);
    ctx.beginPath();ctx.arc(g.x,g.y,sz*4,0,TWO_PI);ctx.fill();
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 1 — Bullets
// ════════════════════════════════════════════════════════════════
const N=2400;
const bR=new Float32Array(N),bAngle=new Float32Array(N),bSpin=new Float32Array(N);
const bSpeed=new Float32Array(N),bPhase=new Float32Array(N),bX=new Float32Array(N),bY=new Float32Array(N);
for(let i=0;i<N;i++){bR[i]=Math.random()*30;bAngle[i]=Math.random()*TWO_PI;bSpin[i]=(Math.random()-0.5)*0.03;bSpeed[i]=1+Math.random()*1.5;bPhase[i]=Math.random()*10;bX[i]=CX;bY[i]=CY;}
function resetBullet(i){bR[i]=Math.random()*30;bAngle[i]=Math.random()*TWO_PI;bSpin[i]=(Math.random()-0.5)*0.03;bSpeed[i]=1+Math.random()*1.5;bPhase[i]=Math.random()*10;}
function updateBullets() {
  const speedMult=1+sBass*1.4+(SY.beat?1.8:0),spinMult=1+sMid*0.6;
  for(let i=0;i<N;i++){
    const r=bR[i],angle=bAngle[i];
    const px=CX+Math.cos(angle)*r,py=CY+Math.sin(angle)*r;
    const lt=timeField(px,py),dir=Math.sin(lt*0.01)>0?1:-1;
    bR[i]+=bSpeed[i]*dir*speedMult;
    bAngle[i]+=(bSpin[i]*dir+Math.sin(bR[i]*0.02+lt*0.03+bPhase[i])*0.05)*spinMult;
    const x2=CX+Math.cos(bAngle[i])*bR[i],y2=CY+Math.sin(bAngle[i])*bR[i];
    const[wx,wy]=warp(x2,y2,lt);bX[i]=wx;bY[i]=wy;
    if(bR[i]<0||bR[i]>CMAX)resetBullet(i);
  }
}
function drawBullets() {
  ctx.globalCompositeOperation="lighter";
  for(let i=0;i<N;i++){
    const depth=bR[i]/CMAX,lt=timeField(bX[i],bY[i]);
    const hue=(bR[i]*0.4+lt*2+bPhase[i]*80+sMid*80)%360;
    const sat=60+sEnergy*30,lgt=40+(1-depth)*35+sBass*15;
    ctx.globalAlpha=Math.min((0.05+(1-depth)*0.25)*(1+sEnergy*0.5),0.9);
    ctx.fillStyle=`hsl(${hue|0},${sat|0}%,${lgt|0}%)`;
    const sz=(0.5+(1-depth)*1.2)*(1+sBass*0.5);
    ctx.beginPath();ctx.arc(bX[i],bY[i],sz,0,TWO_PI);ctx.fill();
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 2 — Clusters
// ════════════════════════════════════════════════════════════════
class Cluster {
  constructor(){this.reset();this.age=Math.random()*this.life;}
  reset(){
    const a=Math.random()*TWO_PI,r=80+Math.random()*(CMAX*0.5);
    this.x=CX+Math.cos(a)*r;this.y=CY+Math.sin(a)*r;
    this.vx=(Math.random()-0.5)*0.3;this.vy=(Math.random()-0.5)*0.3;
    this.r=20+Math.random()*60;this.hue=Math.random()*360;
    this.age=0;this.life=180+Math.random()*240;
    this.n=Math.floor(40+Math.random()*60);
    this.pts=Array.from({length:this.n},()=>({ox:(Math.random()-0.5)*this.r*2,oy:(Math.random()-0.5)*this.r*2,ph:Math.random()*TWO_PI}));
  }
  update(){this.age++;const mm=1+sMid*2.5;this.x+=this.vx*mm;this.y+=this.vy*mm;if(this.age>this.life)this.reset();}
  draw(){
    const fade=Math.min(this.age/40,1)*Math.min((this.life-this.age)/40,1);
    ctx.globalCompositeOperation="screen";
    for(const p of this.pts){
      const jx=p.ox*(1+sMid*0.4)+Math.sin(t*0.02+p.ph)*4;
      const jy=p.oy*(1+sMid*0.4)+Math.cos(t*0.02+p.ph)*4;
      const hue=(this.hue+t*0.05+sHigh*60)%360;
      ctx.globalAlpha=(0.04+sEnergy*0.06)*fade;
      ctx.fillStyle=`hsl(${hue|0},${(50+sEnergy*30)|0}%,${(40+sHigh*20)|0}%)`;
      const sz=(0.8+Math.random()*0.4)*(1+sHigh*0.6);
      ctx.beginPath();ctx.arc(this.x+jx,this.y+jy,sz,0,TWO_PI);ctx.fill();
    }
  }
}
const clusters=Array.from({length:12},()=>new Cluster());

// ════════════════════════════════════════════════════════════════
// CAPA 3 — Fluido SPH-lite
// ════════════════════════════════════════════════════════════════
const NF=280;
const fX=new Float32Array(NF),fY=new Float32Array(NF),fVX=new Float32Array(NF),fVY=new Float32Array(NF),fPh=new Float32Array(NF),fHue=new Float32Array(NF);
for(let i=0;i<NF;i++){const a=Math.random()*TWO_PI,r=30+Math.random()*300;fX[i]=CX+Math.cos(a)*r;fY[i]=CY+Math.sin(a)*r;fVX[i]=(Math.random()-0.5)*0.4;fVY[i]=(Math.random()-0.5)*0.4;fPh[i]=Math.random()*TWO_PI;fHue[i]=180+Math.random()*180;}
function updateFluid() {
  const flowStr=0.006+sBass*0.01,speedCap=3.5+sBass*3.0;
  for(let i=0;i<NF;i++){
    const lt=timeField(fX[i],fY[i]),ang=lt*0.03+fPh[i]*0.5+sMid*1.2;
    fVX[i]+=Math.cos(ang)*flowStr;fVY[i]+=Math.sin(ang)*flowStr;
    const dx=CX-fX[i],dy=CY-fY[i],r=Math.sqrt(dx*dx+dy*dy)+1;
    const pull=(0.00008+sBass*0.00015)*r;
    fVX[i]+=(dx/r)*pull;fVY[i]+=(dy/r)*pull;
    const spd=Math.sqrt(fVX[i]*fVX[i]+fVY[i]*fVY[i]);
    if(spd>speedCap){fVX[i]*=speedCap/spd;fVY[i]*=speedCap/spd;}
    fVX[i]*=0.985;fVY[i]*=0.985;fX[i]+=fVX[i];fY[i]+=fVY[i];
    if(fX[i]<0||fX[i]>canvas.width)fVX[i]*=-0.5;
    if(fY[i]<0||fY[i]>canvas.height)fVY[i]*=-0.5;
    fX[i]=Math.max(0,Math.min(canvas.width,fX[i]));
    fY[i]=Math.max(0,Math.min(canvas.height,fY[i]));
  }
}
function drawFluid() {
  ctx.globalCompositeOperation="screen";
  for(let i=0;i<NF;i++){
    const spd=Math.sqrt(fVX[i]*fVX[i]+fVY[i]*fVY[i]),norm=Math.min(spd/4,1);
    const hue=(fHue[i]+t*0.04+sMid*50+sHigh*30)%360;
    ctx.globalAlpha=0.08+norm*0.18+sEnergy*0.12;
    ctx.fillStyle=`hsl(${hue|0},${(55+norm*30+sBass*20)|0}%,${(35+norm*30+sEnergy*20)|0}%)`;
    const sz=(0.9+norm*1.6)*(1+sBass*0.4);
    ctx.beginPath();ctx.arc(fX[i],fY[i],sz,0,TWO_PI);ctx.fill();
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 4 — Singularidad + Shockwaves
// ════════════════════════════════════════════════════════════════
const SG_FLOW=0,SG_CHARGE=1,SG_EXPLODE=2,SG_SCATTER=3,SG_RETURN=4;
let sgState=SG_FLOW,sgTimer=0,sgRadius=0,sgMaxR=0;
function sgDur(base){return Math.max(Math.round(base*(1-sEnergy*0.45)),40);}
const NS=220;
const sX=new Float32Array(NS),sY=new Float32Array(NS),sVX=new Float32Array(NS),sVY=new Float32Array(NS);
const sPh=new Float32Array(NS),sHue=new Float32Array(NS);
const sHomeX=new Float32Array(NS),sHomeY=new Float32Array(NS);
const sExplVX=new Float32Array(NS),sExplVY=new Float32Array(NS);
for(let i=0;i<NS;i++){const a=(i/NS)*TWO_PI*7+Math.random()*0.3,r=20+Math.random()*260;sX[i]=CX+Math.cos(a)*r;sY[i]=CY+Math.sin(a)*r;sVX[i]=0;sVY[i]=0;sPh[i]=Math.random()*TWO_PI;sHue[i]=240+Math.random()*120;}
const shockwaves=[];
function emitShockwave(){shockwaves.push({r:sgRadius*0.5,maxR:CMAX*0.85,alpha:1.0,hue:(t*0.3)%360});}
function updateDrawShockwaves() {
  ctx.globalCompositeOperation="screen";
  for(let i=shockwaves.length-1;i>=0;i--){
    const sw=shockwaves[i];
    sw.r+=18+(CMAX-sw.r)*0.04;sw.alpha*=0.88;
    if(sw.alpha<0.01){shockwaves.splice(i,1);continue;}
    ctx.globalAlpha=sw.alpha*0.6;ctx.strokeStyle=`hsl(${sw.hue|0},100%,88%)`;ctx.lineWidth=2.5*sw.alpha;
    ctx.beginPath();ctx.arc(CX,CY,sw.r,0,TWO_PI);ctx.stroke();
    ctx.globalAlpha=sw.alpha*0.2;ctx.strokeStyle=`hsl(${(sw.hue+40)|0},80%,70%)`;ctx.lineWidth=8*sw.alpha;
    ctx.beginPath();ctx.arc(CX,CY,sw.r*1.04,0,TWO_PI);ctx.stroke();
  }
}
function applyShockForce() {
  if(!shockwaves.length)return;
  const sw=shockwaves[0],force=sw.alpha*6.5;
  for(let i=0;i<N;i++){const dx=bX[i]-CX,dy=bY[i]-CY,r=Math.sqrt(dx*dx+dy*dy)+1,dist=Math.abs(r-sw.r);if(dist<80){const push=force*(1-dist/80);bR[i]+=push*1.8;}}
  for(let i=0;i<NF;i++){const dx=fX[i]-CX,dy=fY[i]-CY,r=Math.sqrt(dx*dx+dy*dy)+1,dist=Math.abs(r-sw.r);if(dist<100){const push=force*(1-dist/100);fVX[i]+=(dx/r)*push;fVY[i]+=(dy/r)*push;}}
}
function updateSingularity() {
  sgTimer++;
  const flowDur=sgDur(320),chargeDur=sgDur(80);
  if(sgState===SG_FLOW&&sgTimer>=flowDur){sgState=SG_CHARGE;sgTimer=0;sgMaxR=sgRadius;}
  if(sgState===SG_CHARGE&&sgTimer>=chargeDur){
    sgState=SG_EXPLODE;sgTimer=0;emitShockwave();emitShockwave();
    for(let i=0;i<NS;i++){
      sHomeX[i]=sX[i];sHomeY[i]=sY[i];
      const dx=sX[i]-CX,dy=sY[i]-CY,r=Math.sqrt(dx*dx+dy*dy)+0.001;
      const spd=(8+Math.random()*18)*(1+sBass*1.5);
      const tang=Math.random()>0.5?1:-1;
      sExplVX[i]=(dx/r)*spd+(-dy/r)*tang*spd*0.35+(Math.random()-0.5)*5;
      sExplVY[i]=(dy/r)*spd+(dx/r)*tang*spd*0.35+(Math.random()-0.5)*5;
    }
  }
  if(sgState===SG_EXPLODE&&sgTimer>=30){sgState=SG_SCATTER;sgTimer=0;}
  if(sgState===SG_SCATTER&&sgTimer>=90){sgState=SG_RETURN;sgTimer=0;}
  if(sgState===SG_RETURN&&sgTimer>=150){
    sgState=SG_FLOW;sgTimer=0;sgRadius=0;
    for(let i=0;i<NS;i++){
      const bi=(i*11)%N;
      sX[i]=bX[bi]+(Math.random()-0.5)*20;sY[i]=bY[bi]+(Math.random()-0.5)*20;
      sVX[i]=(Math.random()-0.5)*0.5;sVY[i]=(Math.random()-0.5)*0.5;
    }
  }
  if(sgState===SG_FLOW){const p=sgTimer/flowDur;sgRadius=p*p*(55+sBass*35);}
  else if(sgState===SG_CHARGE){const p=sgTimer/chargeDur;const bb=SY.beat?sgMaxR*0.4:0;sgRadius=sgMaxR*(1+0.2*Math.sin(p*Math.PI*6))+bb;}
  else if(sgState===SG_EXPLODE){sgRadius=sgMaxR*(1-sgTimer/30);}
  else{sgRadius=0;}
  for(let i=0;i<NS;i++){
    const dx=CX-sX[i],dy=CY-sY[i],r=Math.sqrt(dx*dx+dy*dy)+0.1;
    if(sgState===SG_FLOW||sgState===SG_CHARGE){
      const p=sgState===SG_CHARGE?1.0:sgTimer/flowDur;
      const pull=(0.012+p*p*0.055)*(1+sBass*0.8),swirl=(0.018+p*0.012)*(1+sMid*0.5);
      const nx=dx/r,ny=dy/r,tx=-ny,ty=nx;
      sVX[i]+=nx*pull*r*0.018+tx*swirl;sVY[i]+=ny*pull*r*0.018+ty*swirl;
      const lt=timeField(sX[i],sY[i]);
      sVX[i]+=Math.cos(lt*0.03+sPh[i])*0.015;sVY[i]+=Math.sin(lt*0.03+sPh[i])*0.015;
      sVX[i]*=0.93;sVY[i]*=0.93;sX[i]+=sVX[i];sY[i]+=sVY[i];
      if(r<4){const a=Math.random()*TWO_PI,nr=80+Math.random()*200;sX[i]=CX+Math.cos(a)*nr;sY[i]=CY+Math.sin(a)*nr;sVX[i]=0;sVY[i]=0;}
    }else if(sgState===SG_EXPLODE){
      const p=sgTimer/30;sVX[i]=sExplVX[i]*(1-p*0.3);sVY[i]=sExplVY[i]*(1-p*0.3);sX[i]+=sVX[i];sY[i]+=sVY[i];
    }else if(sgState===SG_SCATTER){
      const lt=timeField(sX[i],sY[i]);
      sVX[i]+=Math.cos(lt*0.025+sPh[i])*0.04;sVY[i]+=Math.sin(lt*0.025+sPh[i])*0.04;
      sVX[i]*=0.91;sVY[i]*=0.91;sX[i]+=sVX[i];sY[i]+=sVY[i];
      if(sX[i]<0||sX[i]>canvas.width)sVX[i]*=-0.6;if(sY[i]<0||sY[i]>canvas.height)sVY[i]*=-0.6;
    }else if(sgState===SG_RETURN){
      const p=sgTimer/150,targetR=60+(i/NS)*220,curR=Math.sqrt((sX[i]-CX)**2+(sY[i]-CY)**2);
      const pull=(targetR-curR)*0.002*p;
      sVX[i]+=dx/r*pull*(-1);sVY[i]+=dy/r*pull*(-1);
      const tx2=-dy/r,ty2=dx/r;sVX[i]+=tx2*0.025*p;sVY[i]+=ty2*0.025*p;
      sVX[i]*=0.92;sVY[i]*=0.92;sX[i]+=sVX[i];sY[i]+=sVY[i];
    }
  }
}
function drawSingularity() {
  if(sgRadius>1){
    const pulse=sgState===SG_CHARGE?0.6+0.4*Math.sin(sgTimer*0.5):1.0;
    ctx.globalCompositeOperation="screen";
    const hc=(t*0.3+sMid*120)%360;
    const haloPulse=pulse*(1+sBass*0.6);
    const grad=ctx.createRadialGradient(CX,CY,0,CX,CY,sgRadius*2.5);
    grad.addColorStop(0,`hsla(${hc|0},80%,90%,${0.18*haloPulse})`);
    grad.addColorStop(0.3,`hsla(${(hc+40)|0},90%,70%,${0.10*haloPulse})`);
    grad.addColorStop(1,"transparent");
    ctx.fillStyle=grad;ctx.globalAlpha=1;
    ctx.beginPath();ctx.arc(CX,CY,sgRadius*2.5,0,TWO_PI);ctx.fill();
    if(SY.beat&&sgRadius>5){
      const shockR=sgRadius*3.5;
      const sg2=ctx.createRadialGradient(CX,CY,sgRadius*2,CX,CY,shockR);
      sg2.addColorStop(0,`hsla(${(hc+60)|0},100%,90%,0.35)`);sg2.addColorStop(1,"transparent");
      ctx.fillStyle=sg2;ctx.globalAlpha=0.7;ctx.beginPath();ctx.arc(CX,CY,shockR,0,TWO_PI);ctx.fill();
    }
    const grad2=ctx.createRadialGradient(CX,CY,0,CX,CY,sgRadius);
    grad2.addColorStop(0,`hsla(${(hc+20)|0},100%,99%,${0.9*pulse})`);
    grad2.addColorStop(0.5,`hsla(${(hc+60)|0},95%,75%,${0.5*pulse})`);
    grad2.addColorStop(1,"transparent");
    ctx.fillStyle=grad2;ctx.beginPath();ctx.arc(CX,CY,sgRadius,0,TWO_PI);ctx.fill();
    if(sgState===SG_CHARGE){
      ctx.globalAlpha=0.3*pulse+sBass*0.2;ctx.strokeStyle=`hsl(${hc|0},100%,85%)`;
      ctx.lineWidth=1.5+sBass*2;ctx.beginPath();ctx.arc(CX,CY,sgRadius*1.8,0,TWO_PI);ctx.stroke();
    }
  }
  ctx.globalCompositeOperation="screen";
  for(let i=0;i<NS;i++){
    const dx=sX[i]-CX,dy=sY[i]-CY,r=Math.sqrt(dx*dx+dy*dy),norm=Math.min(r/280,1);
    const hue=(sHue[i]+t*0.08+norm*50+sMid*40)%360;
    const spd=Math.sqrt(sVX[i]*sVX[i]+sVY[i]*sVY[i]),spdN=Math.min(spd/6,1);
    let alpha=0.15+(1-norm)*0.25+spdN*0.4+sEnergy*0.15;
    if(sgState===SG_CHARGE)alpha*=1.4;
    ctx.globalAlpha=Math.min(alpha,0.9);
    ctx.fillStyle=`hsl(${hue|0},${(60+spdN*35+sBass*20)|0}%,${(50+(1-norm)*25+sEnergy*15)|0}%)`;
    const sz=(0.5+(1-norm)*0.8+spdN*0.7)*(1+sBass*0.3);
    ctx.beginPath();ctx.arc(sX[i],sY[i],sz,0,TWO_PI);ctx.fill();
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 5 — Corona espectral
// ════════════════════════════════════════════════════════════════
let coronaAlpha=0;
function drawCorona() {
  const target=SY.active?1:0;coronaAlpha+=(target-coronaAlpha)*0.04;
  if(coronaAlpha<0.01)return;
  const BARS=128,R_INNER=60+sgRadius*0.3,R_OUTER=R_INNER+40+sEnergy*80;
  ctx.globalCompositeOperation="screen";
  for(let i=0;i<BARS;i++){
    const theta=(i/BARS)*TWO_PI-Math.PI/2;
    const band=i/BARS;
    const val=band<0.33?sBass:band<0.66?sMid:sHigh;
    const barH=val*60*coronaAlpha;
    const hue=(270+band*180+sMid*60+t*0.15)%360;
    ctx.globalAlpha=(0.35+val*0.4)*coronaAlpha;
    ctx.strokeStyle=`hsl(${hue|0},${(70+sEnergy*25)|0}%,${(50+band*20)|0}%)`;
    ctx.lineWidth=(TWO_PI*R_INNER/BARS)*0.72;ctx.lineCap="round";
    ctx.beginPath();
    ctx.moveTo(CX+Math.cos(theta)*R_INNER,CY+Math.sin(theta)*R_INNER);
    ctx.lineTo(CX+Math.cos(theta)*(R_INNER+barH),CY+Math.sin(theta)*(R_INNER+barH));
    ctx.stroke();
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 6 — Nebulosa
// ════════════════════════════════════════════════════════════════
const offNeb=document.createElement("canvas");
offNeb.width=canvas.width;offNeb.height=canvas.height;
const nctx=offNeb.getContext("2d",{alpha:true});
let lastNebT=-9999;
const NEB_NODES=Array.from({length:6},(_,i)=>({x:CX+(Math.random()-0.5)*CMAX*0.6,y:CY+(Math.random()-0.5)*CMAX*0.6,r:CMAX*(0.15+Math.random()*0.2),hue:[270,290,200,180,260,300][i],vx:(Math.random()-0.5)*0.3,vy:(Math.random()-0.5)*0.3}));
function rebuildNebula(tt) {
  lastNebT=tt;offNeb.width=canvas.width;offNeb.height=canvas.height;
  nctx.clearRect(0,0,offNeb.width,offNeb.height);
  for(const n of NEB_NODES){
    n.x+=n.vx*240;n.y+=n.vy*240;
    if(n.x<0||n.x>canvas.width)n.vx*=-1;if(n.y<0||n.y>canvas.height)n.vy*=-1;
    n.x=Math.max(0,Math.min(canvas.width,n.x));n.y=Math.max(0,Math.min(canvas.height,n.y));
    const grad=nctx.createRadialGradient(n.x,n.y,0,n.x,n.y,n.r);
    grad.addColorStop(0,`hsla(${n.hue},70%,35%,0.055)`);
    grad.addColorStop(0.5,`hsla(${n.hue},60%,25%,0.025)`);
    grad.addColorStop(1,`hsla(${n.hue},50%,15%,0)`);
    nctx.fillStyle=grad;nctx.beginPath();nctx.arc(n.x,n.y,n.r,0,TWO_PI);nctx.fill();
  }
}
function drawNebula() {
  if(t-lastNebT>=240)rebuildNebula(t);
  ctx.globalCompositeOperation="screen";ctx.globalAlpha=0.07+sEnergy*0.04;ctx.drawImage(offNeb,0,0);
}

// ════════════════════════════════════════════════════════════════
// CAPA 7 — Aurora
// ════════════════════════════════════════════════════════════════
const AURORA_BANDS=[
  {hue:170,speed:0.0008,amp:0.06,yBase:0.08,width:0.12},
  {hue:200,speed:0.0006,amp:0.05,yBase:0.13,width:0.09},
  {hue:260,speed:0.0010,amp:0.04,yBase:0.18,width:0.07},
];
function drawAurora() {
  const H=canvas.height,W=canvas.width;
  ctx.globalCompositeOperation="screen";
  for(const band of AURORA_BANDS){
    const yCenter=H*band.yBase+Math.sin(t*band.speed*1000+band.hue)*H*band.amp;
    const bandH=H*band.width;
    const hue2=(band.hue+sMid*30+t*0.02)%360;
    const grad=ctx.createLinearGradient(0,yCenter-bandH,0,yCenter+bandH);
    grad.addColorStop(0,`hsla(${hue2|0},80%,60%,0)`);
    grad.addColorStop(0.4,`hsla(${hue2|0},85%,55%,0.045)`);
    grad.addColorStop(0.5,`hsla(${hue2|0},90%,65%,0.05)`);
    grad.addColorStop(0.6,`hsla(${hue2|0},85%,55%,0.045)`);
    grad.addColorStop(1,`hsla(${hue2|0},80%,60%,0)`);
    ctx.globalAlpha=1;ctx.fillStyle=grad;
    ctx.beginPath();ctx.moveTo(0,yCenter-bandH);
    const STEPS=60;
    for(let s=0;s<=STEPS;s++){const x=(s/STEPS)*W,wb=Math.sin(s*0.18+t*band.speed*800+band.hue*0.05)*bandH*0.4;ctx.lineTo(x,yCenter-bandH+wb);}
    for(let s=STEPS;s>=0;s--){const x=(s/STEPS)*W,wb=Math.sin(s*0.18+t*band.speed*800+band.hue*0.05+1.2)*bandH*0.4;ctx.lineTo(x,yCenter+bandH+wb);}
    ctx.closePath();ctx.fill();
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 8 — Filamentos
// ════════════════════════════════════════════════════════════════
const FIL_DIST2=90*90,FIL_STEP=Math.floor(N/300);
function drawFilaments() {
  ctx.globalCompositeOperation="screen";
  for(let i=0;i<N;i+=FIL_STEP){
    for(let j=i+FIL_STEP;j<N;j+=FIL_STEP){
      const dx=bX[i]-bX[j],dy=bY[i]-bY[j],d2=dx*dx+dy*dy;
      if(d2>FIL_DIST2)continue;
      const norm=1-Math.sqrt(d2)/90;
      const hue=(bR[i]*0.4+bPhase[i]*80+sMid*60)%360;
      ctx.globalAlpha=(0.025+norm*0.025)*(1+sEnergy*0.4);
      ctx.strokeStyle=`hsl(${hue|0},60%,55%)`;ctx.lineWidth=0.4+norm*0.4;
      ctx.beginPath();ctx.moveTo(bX[i],bY[i]);ctx.lineTo(bX[j],bY[j]);ctx.stroke();
    }
  }
}

// ════════════════════════════════════════════════════════════════
// CAPA 9 — Kaleidoscopio
// ════════════════════════════════════════════════════════════════
let kaleiSegs=6,kaleiSegsTarget=6;
function drawKaleidoscope() {
  kaleiSegsTarget=SY.beat?8:6;kaleiSegs+=(kaleiSegsTarget-kaleiSegs)*0.08;
  const segs=Math.round(kaleiSegs),R=Math.min(canvas.width,canvas.height)*0.38;
  const alpha=0.042+sEnergy*0.025;
  ctx.globalCompositeOperation="screen";ctx.globalAlpha=alpha;
  ctx.save();ctx.translate(CX,CY);
  const angleStep=TWO_PI/segs;
  for(let s=0;s<segs;s++){
    ctx.save();ctx.rotate(s*angleStep);
    ctx.beginPath();ctx.moveTo(0,0);ctx.arc(0,0,R,0,angleStep);ctx.closePath();ctx.clip();
    if(s%2===0){ctx.drawImage(canvas,-CX,-CY);}else{ctx.scale(-1,1);ctx.drawImage(canvas,-CX,-CY);}
    ctx.restore();
  }
  ctx.restore();
}

// ════════════════════════════════════════════════════════════════
// CAPA 10 — Bounded Field (Yukari spellcard)
// ════════════════════════════════════════════════════════════════
let bfRotation=0,bfAlpha=0,bfScale=0;
const BF_SPIRALS=Array.from({length:3},(_,i)=>({
  bullets:Array.from({length:48},(_,j)=>({angle:(j/48)*TWO_PI,r:0,maxR:180+Math.random()*80,speed:0.6+Math.random()*0.4,hue:[200,270,45][i],size:2+Math.random()*2,arm:i})),
  rotOffset:(i/3)*TWO_PI,
}));
function drawHexGrid(cx2,cy2,hexR,levels,rot,alpha,hue) {
  ctx.strokeStyle=`hsl(${hue},70%,55%)`;ctx.lineWidth=0.6;
  for(let level=1;level<=levels;level++){
    const r=hexR*level;
    ctx.globalAlpha=alpha*(1-level/(levels+2))*0.8;
    ctx.beginPath();
    for(let v=0;v<=6;v++){const a=rot+(v/6)*TWO_PI;const x=cx2+Math.cos(a)*r,y=cy2+Math.sin(a)*r;if(v===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);}
    ctx.stroke();
    ctx.globalAlpha=alpha*0.2*(1-level/(levels+2));
    for(let v=0;v<6;v++){const a=rot+(v/6)*TWO_PI;ctx.beginPath();ctx.moveTo(cx2,cy2);ctx.lineTo(cx2+Math.cos(a)*r,cy2+Math.sin(a)*r);ctx.stroke();}
  }
}
function drawBoundedField() {
  const isCharge=sgState===SG_CHARGE,isExplode=sgState===SG_EXPLODE||sgState===SG_SCATTER;
  if(isCharge)bfAlpha+=(0.85-bfAlpha)*0.04;
  else if(isExplode)bfAlpha+=(0.0-bfAlpha)*0.06;
  else bfAlpha+=(0.0-bfAlpha)*0.02;
  if(isCharge)bfScale+=(1.0-bfScale)*0.04;
  else if(isExplode)bfScale+=(2.2-bfScale)*0.12;
  else bfScale+=(0.0-bfScale)*0.03;
  if(bfAlpha<0.01&&!isCharge)return;
  bfRotation+=(isExplode?0.08+sBass*0.05:0.004+sMid*0.002);
  ctx.save();ctx.translate(CX,CY);ctx.scale(bfScale,bfScale);
  const hexHue=(270+sMid*40+t*0.05)%360;
  ctx.globalCompositeOperation="screen";
  drawHexGrid(0,0,38,5,bfRotation,bfAlpha*0.7,hexHue);
  drawHexGrid(0,0,38,4,bfRotation+Math.PI/6,bfAlpha*0.4,(hexHue+60)%360);
  for(let ring=1;ring<=3;ring++){
    const rr=38*1.8*ring;
    ctx.globalAlpha=bfAlpha*0.25/ring;ctx.strokeStyle=`hsl(${(hexHue+ring*30)%360},80%,60%)`;ctx.lineWidth=1.2/ring;
    ctx.beginPath();ctx.arc(0,0,rr,0,TWO_PI);ctx.stroke();
    ctx.globalAlpha=bfAlpha*0.4/ring;
    for(let v=0;v<6;v++){const a=bfRotation+(v/6)*TWO_PI;ctx.beginPath();ctx.arc(Math.cos(a)*rr,Math.sin(a)*rr,3/ring,0,TWO_PI);ctx.fill();}
  }
  for(const spiral of BF_SPIRALS){
    for(const b of spiral.bullets){
      b.r+=b.speed*(isExplode?3.5:1);if(b.r>b.maxR)b.r=0;
      const ang=b.angle+spiral.rotOffset+bfRotation*(b.arm%2===0?1:-1);
      const bx2=Math.cos(ang)*b.r,by2=Math.sin(ang)*b.r;
      const hue2=(b.hue+sMid*30+t*0.1)%360;
      ctx.globalAlpha=bfAlpha*(0.4+(b.r/b.maxR)*0.4);
      ctx.fillStyle=`hsl(${hue2|0},85%,65%)`;ctx.globalCompositeOperation="screen";
      const sz=b.size*(1+sBass*0.5)*(isExplode?1.8:1);
      ctx.beginPath();ctx.arc(bx2,by2,sz,0,TWO_PI);ctx.fill();
      ctx.globalAlpha=bfAlpha*0.12;ctx.beginPath();ctx.arc(bx2,by2,sz*3,0,TWO_PI);ctx.fill();
    }
  }
  if(bfAlpha>0.1){
    ctx.globalCompositeOperation="screen";ctx.globalAlpha=bfAlpha*0.6;
    ctx.strokeStyle=`hsl(${(hexHue+20)%360},90%,70%)`;ctx.lineWidth=0.8;
    for(let v=0;v<8;v++){const a=bfRotation*0.5+(v/8)*TWO_PI;ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(Math.cos(a)*34,Math.sin(a)*34);ctx.stroke();}
    ctx.globalAlpha=bfAlpha*(0.3+0.2*Math.sin(t*0.06));ctx.strokeStyle=`hsl(45,90%,70%)`;ctx.lineWidth=1;
    ctx.beginPath();ctx.arc(0,0,19+Math.sin(t*0.04)*4,0,TWO_PI);ctx.stroke();
  }
  ctx.restore();
}

// ════════════════════════════════════════════════════════════════
// LOOP PRINCIPAL
// ════════════════════════════════════════════════════════════════
function loop() {
  if(document.hidden){raf=null;return;}
  raf=requestAnimationFrame(loop);t++;
  updateSynth();
  const fadeAlpha=Math.max(0.025,0.055-sBass*0.022);
  ctx.globalCompositeOperation="source-over";ctx.globalAlpha=fadeAlpha;
  ctx.fillStyle="#000";ctx.fillRect(0,0,canvas.width,canvas.height);
  drawOrbits();
  updateBullets();drawBullets();
  clusters.forEach(c=>{c.update();c.draw();});
  updateFluid();drawFluid();
  drawCorona();
  updateSingularity();drawSingularity();
  applyShockForce();updateDrawShockwaves();
  drawNebula();
  drawAurora();
  drawFilaments();
  drawKaleidoscope();
  drawBoundedField();
}
loop();

document.addEventListener("astro:before-swap",()=>{
  cancelAnimationFrame(raf);
  window.removeEventListener("resize",onResize);
  if(synthRaf){cancelAnimationFrame(synthRaf);synthRaf=null;}
  window.__radioSynth={active:false,bass:0,mid:0,high:0,energy:0,beat:false};
},{once:true});

});
</script>

