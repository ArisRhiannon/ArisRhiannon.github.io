---
/**
 * MediaViewer — lightbox full-screen para imagenes y videos.
 * Se activa via client-side JS.
 */
---

<div class="media-viewer" id="media-viewer" aria-hidden="true">
  <div class="viewer-backdrop"></div>
  <div class="viewer-content">
    <button class="viewer-close" aria-label="Cerrar">✕</button>
    <div class="viewer-media" id="viewer-media"></div>
  </div>
</div>

<style>
  .media-viewer {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s var(--ease-out);
  }

  .media-viewer.active {
    opacity: 1;
    pointer-events: all;
  }

  .viewer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 21, 32, 0.90);
    backdrop-filter: blur(20px);
  }

  .viewer-content {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 90vh;
  }

  .viewer-close {
    position: fixed;
    top: var(--space-6);
    right: var(--space-6);
    background: rgba(255,245,250,0.05);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: var(--color-ink-soft);
    cursor: pointer;
    backdrop-filter: blur(12px);
    transition: all var(--duration) var(--ease-out);
    z-index: 2;
  }

  .viewer-close:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .viewer-media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .viewer-media img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .viewer-media video {
    max-width: 90vw;
    max-height: 85vh;
    border-radius: var(--radius-md);
  }
</style>

<script>
  function initMediaViewer() {
    const viewer = document.getElementById('media-viewer');
    const mediaContainer = document.getElementById('viewer-media');
    if (!viewer || !mediaContainer) return;

    function open(media: { url: string; type: string; thumb?: string | null }) {
      mediaContainer.innerHTML = '';
      if (media.type === 'image') {
        const img = document.createElement('img');
        img.src = media.url;
        img.alt = '';
        mediaContainer.appendChild(img);
      } else if (media.type === 'video') {
        const video = document.createElement('video');
        video.src = media.url;
        video.controls = true;
        video.autoplay = true;
        mediaContainer.appendChild(video);
      }
      viewer.classList.add('active');
      viewer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      viewer.classList.remove('active');
      viewer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Stop any playing video
      const video = mediaContainer.querySelector('video');
      if (video) video.pause();
    }

    // Close on backdrop click
    viewer.querySelector('.viewer-backdrop')?.addEventListener('click', close);
    viewer.querySelector('.viewer-close')?.addEventListener('click', close);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    // Expose open function globally
    (window as any).__openMediaViewer = open;
  }

  document.addEventListener('astro:page-load', initMediaViewer);
</script>
