---
import Base from '../../layouts/Base.astro';
import nowData from '../../../data/now.json';
const { updated, location, items } = nowData;
const fecha = new Date(updated).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title="ahora · aris" description="Qué estoy haciendo en este momento">
  <section class="now-page">
    <header class="now-header">
      <div class="now-meta">
        <span class="now-label">ahora</span>
        <span class="now-dot">·</span>
        <span class="now-location">{location}</span>
      </div>
      <h1 class="now-title">qué estoy haciendo</h1>
      <p class="now-updated">actualizado el {fecha}</p>
    </header>
    <ul class="now-grid" role="list">
      {items.map((item) => (
        <li class="now-card">
          <span class="now-icon" aria-hidden="true">{item.icon}</span>
          <div class="now-card-body">
            <span class="now-category">{item.category}</span>
            <p class="now-text">{item.text}</p>
          </div>
        </li>
      ))}
    </ul>
    <p class="now-credit">Inspirado por <a href="https://nownownow.com" target="_blank" rel="noopener">nownownow.com</a></p>
  </section>
</Base>
<style>
.now-page { max-width: 42rem; margin: 0 auto; padding: var(--space-12) var(--space-4); }
.now-header { margin-bottom: var(--space-10); }
.now-meta { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-4); }
.now-label { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: .12em; text-transform: uppercase; color: var(--color-accent); background: var(--color-surface); padding: var(--space-1) var(--space-3); border-radius: var(--radius-full); }
.now-dot { color: var(--color-muted); }
.now-location { font-size: var(--text-sm); color: var(--color-muted); }
.now-title { font-family: var(--font-display); font-size: var(--text-4xl); color: var(--color-ink); line-height: 1.1; letter-spacing: -.02em; margin-bottom: var(--space-3); }
.now-updated { font-size: var(--text-sm); color: var(--color-muted); }
.now-grid { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); margin-bottom: var(--space-12); }
.now-card { display: flex; align-items: flex-start; gap: var(--space-4); padding: var(--space-5) var(--space-6); background: var(--color-surface); border-radius: var(--radius-lg); border: 1px solid var(--color-surface-2); transition: transform var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out); }
.now-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.now-icon { font-size: var(--text-2xl); line-height: 1; flex-shrink: 0; margin-top: 2px; }
.now-card-body { display: flex; flex-direction: column; gap: var(--space-1); }
.now-category { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: .08em; color: var(--color-accent); }
.now-text { font-size: var(--text-base); color: var(--color-ink); line-height: 1.5; }
.now-credit { font-size: var(--text-sm); color: var(--color-muted); text-align: center; }
.now-credit a { color: var(--color-accent); text-decoration: none; border-bottom: 1px solid var(--color-surface-2); transition: border-color var(--duration); }
.now-credit a:hover { border-color: var(--color-accent); }
@media (max-width: 640px) { .now-title { font-size: var(--text-3xl); } }
</style>
