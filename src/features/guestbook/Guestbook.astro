---
import { isAdmin } from '../../lib/auth';
import { ADMIN_JWT_SECRET } from '../../lib/env';

const authenticated = await isAdmin(Astro.request, ADMIN_JWT_SECRET());
---

<div class="gb-widget">
  <div class="gb-widget-header">
    <div class="gb-widget-title">
      <span class="icon">✦</span> libro de visitas
    </div>
    <div class="gb-widget-count" id="gb-widget-count">0 mensajes</div>
  </div>

  <div class="gb-widget-scrollbox" id="gb-widget-entries">
    <div class="gb-widget-empty" id="gb-widget-empty">
      <span class="empty-icon">✨</span>
      <span>escribe algo lindo...</span>
    </div>
  </div>

  <form class="gb-widget-form" id="gb-widget-form">
    <div class="gb-widget-row">
      <input
        type="text"
        id="gb-widget-name"
        placeholder="tu nombre..."
        maxlength="25"
        autocomplete="off"
      />
      <div class="gb-widget-emojis" id="gb-widget-emojis">
        <button type="button" class="gb-widget-emoji-btn active" data-emoji="✨">✨</button>
        <button type="button" class="gb-widget-emoji-btn" data-emoji="💭">💭</button>
        <button type="button" class="gb-widget-emoji-btn" data-emoji="🌸">🌸</button>
        <button type="button" class="gb-widget-emoji-btn" data-emoji="🎮">🎮</button>
        <button type="button" class="gb-widget-emoji-btn" data-emoji="♪">♪</button>
      </div>
    </div>
    <div class="gb-widget-row">
      <input
        type="text"
        id="gb-widget-message"
        placeholder="deja un mensaje..."
        maxlength="250"
        required
        autocomplete="off"
      />
      <button type="submit" id="gb-widget-submit" title="Enviar">
        <span class="submit-arrow">→</span>
      </button>
    </div>
  </form>
</div>

<span data-authenticated={String(authenticated)} style="display:none" aria-hidden="true" id="gb-auth-flag"></span>

<style>
  .gb-widget {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 260px;
    box-sizing: border-box;
  }

  .gb-widget-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .gb-widget-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-lavender);
    text-shadow: var(--glow-lavender);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .gb-widget-title .icon {
    color: var(--color-accent);
  }

  .gb-widget-count {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--color-muted-2);
    letter-spacing: 0.04em;
  }

  /* Scrollbox entries list */
  .gb-widget-scrollbox {
    flex: 1;
    overflow-y: auto;
    margin-bottom: var(--space-3);
    padding-right: 6px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    scrollbar-width: thin;
    scrollbar-color: rgba(207, 162, 64, 0.2) rgba(255, 255, 255, 0.02);
  }

  .gb-widget-scrollbox::-webkit-scrollbar {
    width: 3px;
  }
  .gb-widget-scrollbox::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.01);
  }
  .gb-widget-scrollbox::-webkit-scrollbar-thumb {
    background: rgba(207, 162, 64, 0.2);
    border-radius: var(--radius-full);
  }
  .gb-widget-scrollbox::-webkit-scrollbar-thumb:hover {
    background: rgba(207, 162, 64, 0.4);
  }

  .gb-widget-empty {
    text-align: center;
    padding: var(--space-6) 0;
    color: var(--color-muted-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .gb-widget-empty .empty-icon {
    font-size: 16px;
    opacity: 0.6;
  }

  .gb-widget-empty.hidden {
    display: none;
  }

  /* Single Entry Item */
  .gb-widget-entry {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out), border-color 0.2s var(--ease-out);
  }

  .gb-widget-entry.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .gb-widget-entry:hover {
    border-color: rgba(207, 162, 64, 0.15);
  }

  .gb-widget-entry-top {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .gb-widget-entry-emoji {
    font-size: 11px;
    flex-shrink: 0;
  }

  .gb-widget-entry-name {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-lavender);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gb-widget-entry-time {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--color-muted-2);
    opacity: 0.7;
  }

  .gb-widget-entry-delete {
    background: none;
    border: none;
    font-size: 10px;
    color: var(--color-muted-2);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--duration), color var(--duration);
    padding: 0 2px;
  }

  .gb-widget-entry:hover .gb-widget-entry-delete {
    opacity: 0.5;
  }

  .gb-widget-entry-delete:hover {
    opacity: 1 !important;
    color: var(--color-accent);
  }

  .gb-widget-entry-message {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    line-height: 1.4;
    word-break: break-word;
  }

  /* Form and inputs */
  .gb-widget-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-3);
  }

  .gb-widget-row {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }

  .gb-widget-form input[type="text"] {
    background: rgba(255, 245, 250, 0.02);
    border: 1px solid rgba(196, 181, 253, 0.08);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    padding: 5px 8px;
    outline: none;
    width: 100%;
    transition: border-color var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
  }

  .gb-widget-form input[type="text"]:focus {
    border-color: rgba(196, 181, 253, 0.25);
    box-shadow: var(--glow-lavender);
  }

  .gb-widget-form input::placeholder {
    color: var(--color-muted-2);
    font-size: 10px;
  }

  #gb-widget-name {
    flex: 1;
    min-width: 0;
  }

  #gb-widget-message {
    flex: 1;
    min-width: 0;
  }

  /* Emojis selection row */
  .gb-widget-emojis {
    display: flex;
    gap: 2px;
    flex-shrink: 0;
  }

  .gb-widget-emoji-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: 3px;
    padding: 1px 3px;
    font-size: 11px;
    cursor: pointer;
    opacity: 0.4;
    transition: all var(--duration) var(--ease-out);
    line-height: 1;
  }

  .gb-widget-emoji-btn:hover {
    opacity: 0.8;
    transform: scale(1.15);
  }

  .gb-widget-emoji-btn.active {
    opacity: 1;
    border-color: rgba(196,181,253,0.20);
    background: rgba(196,181,253,0.08);
  }

  /* Submit button */
  #gb-widget-submit {
    background: rgba(196,181,253,0.06);
    border: 1px solid rgba(196,181,253,0.15);
    border-radius: var(--radius-sm);
    color: var(--color-lavender);
    cursor: pointer;
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    transition: all var(--duration) var(--ease-out);
  }

  #gb-widget-submit:hover {
    background: rgba(196,181,253,0.15);
    border-color: rgba(196,181,253,0.3);
    box-shadow: var(--glow-lavender);
  }

  #gb-widget-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

<script>
  function initWidgetGuestbook() {
    const form = document.getElementById('gb-widget-form');
    const nameInput = document.getElementById('gb-widget-name') as HTMLInputElement;
    const messageInput = document.getElementById('gb-widget-message') as HTMLInputElement;
    const submitBtn = document.getElementById('gb-widget-submit') as HTMLButtonElement;
    const scrollbox = document.getElementById('gb-widget-entries')!;
    const emptyMsg = document.getElementById('gb-widget-empty')!;
    const emojiRow = document.getElementById('gb-widget-emojis')!;
    const countEl = document.getElementById('gb-widget-count')!;
    const authFlag = document.getElementById('gb-auth-flag')!;

    if (!form || !scrollbox) return;

    let selectedEmoji = '✨';
    let lastPostTime = 0;

    // Restore name from localStorage
    const savedName = localStorage.getItem('gb-name') ?? '';
    if (nameInput && savedName) nameInput.value = savedName;

    // Emoji picker logic
    emojiRow?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.gb-widget-emoji-btn');
      if (!btn) return;
      selectedEmoji = (btn as HTMLElement).dataset.emoji ?? '✨';
      emojiRow.querySelectorAll('.gb-widget-emoji-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });

    // Time elapsed formatter
    function relativeTime(dateStr: string): string {
      const d = new Date(dateStr + 'Z');
      const diff = Date.now() - d.getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'ahora';
      if (mins < 60) return `${mins}m`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}h`;
      const days = Math.floor(hrs / 24);
      if (days < 30) return `${days}d`;
      return `${Math.floor(days / 30)}m`;
    }

    function escHtml(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function renderEntries(entries: any[]) {
      // Remove old entries
      scrollbox.querySelectorAll('.gb-widget-entry').forEach(el => el.remove());

      if (entries.length === 0) {
        emptyMsg.classList.remove('hidden');
        countEl.textContent = '0 mensajes';
        return;
      }

      emptyMsg.classList.add('hidden');
      countEl.textContent = `${entries.length} mensajes`;

      const isAuth = authFlag?.getAttribute('data-authenticated') === 'true';

      entries.forEach((entry, i) => {
        const time = relativeTime(entry.created_at);
        const html = `
          <div class="gb-widget-entry" style="transition-delay: ${i * 40}ms" id="gb-entry-${entry.id}">
            <div class="gb-widget-entry-top">
              <span class="gb-widget-entry-emoji">${entry.emoji ?? '✨'}</span>
              <span class="gb-widget-entry-name">${escHtml(entry.name ?? 'anon')}</span>
              <span class="gb-widget-entry-time">${time}</span>
              ${isAuth ? `<button type="button" class="gb-widget-entry-delete" data-id="${entry.id}" title="Eliminar">✕</button>` : ''}
            </div>
            <div class="gb-widget-entry-message">${escHtml(entry.message)}</div>
          </div>
        `;
        scrollbox.insertAdjacentHTML('beforeend', html);
      });

      // Smooth reveal animation
      requestAnimationFrame(() => {
        scrollbox.querySelectorAll('.gb-widget-entry').forEach(el => el.classList.add('revealed'));
      });

      // Delete buttons event listeners
      scrollbox.querySelectorAll('.gb-widget-entry-delete').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          const id = (btn as HTMLElement).dataset.id;
          if (!id) return;

          const entryEl = document.getElementById(`gb-entry-${id}`);
          if (entryEl) {
            entryEl.style.opacity = '0';
            entryEl.style.transform = 'scale(0.9)';
          }

          try {
            const res = await fetch('/api/guestbook', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: Number(id) }),
            });
            if (res.ok) {
              setTimeout(() => {
                entryEl?.remove();
                // Refresh list count
                const remaining = scrollbox.querySelectorAll('.gb-widget-entry').length;
                countEl.textContent = `${remaining} mensajes`;
                if (remaining === 0) emptyMsg.classList.remove('hidden');
              }, 300);
            } else {
              // Revert animation on fail
              if (entryEl) {
                entryEl.style.opacity = '1';
                entryEl.style.transform = 'scale(1)';
              }
            }
          } catch {
            if (entryEl) {
              entryEl.style.opacity = '1';
              entryEl.style.transform = 'scale(1)';
            }
          }
        });
      });
    }

    async function loadEntries() {
      try {
        const res = await fetch('/api/guestbook');
        const data = await res.json();
        renderEntries(data.entries ?? []);
      } catch { /* silent */ }
    }

    // Cooldown handler
    function triggerCooldown() {
      let cooldown = 8;
      submitBtn.disabled = true;
      const timer = setInterval(() => {
        cooldown--;
        if (cooldown <= 0) {
          clearInterval(timer);
          submitBtn.disabled = false;
          submitBtn.innerHTML = "<span class='submit-arrow'>→</span>";
        } else {
          submitBtn.innerHTML = `<span style="font-size: 8px;">${cooldown}s</span>`;
        }
      }, 1000);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const now = Date.now();
      if (now - lastPostTime < 8000) return; // rate limit fallback

      const name = nameInput?.value?.trim() || 'anon';
      const message = messageInput?.value?.trim();
      if (!message) return;

      if (name !== 'anon') localStorage.setItem('gb-name', name);

      lastPostTime = now;
      triggerCooldown();

      try {
        const res = await fetch('/api/guestbook', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, message, emoji: selectedEmoji }),
        });
        if (res.ok) {
          messageInput.value = '';
          const newEntry = await res.json();
          
          // Prepend the new entry with a beautiful smooth animation
          emptyMsg.classList.add('hidden');
          const isAuth = authFlag?.getAttribute('data-authenticated') === 'true';
          const html = `
            <div class="gb-widget-entry" id="gb-entry-${newEntry.id}" style="transition-delay: 0ms">
              <div class="gb-widget-entry-top">
                <span class="gb-widget-entry-emoji">${newEntry.emoji ?? '✨'}</span>
                <span class="gb-widget-entry-name">${escHtml(newEntry.name ?? 'anon')}</span>
                <span class="gb-widget-entry-time">ahora</span>
                ${isAuth ? `<button type="button" class="gb-widget-entry-delete" data-id="${newEntry.id}" title="Eliminar">✕</button>` : ''}
              </div>
              <div class="gb-widget-entry-message">${escHtml(newEntry.message)}</div>
            </div>
          `;
          
          scrollbox.insertAdjacentHTML('afterbegin', html);
          const newEl = document.getElementById(`gb-entry-${newEntry.id}`)!;
          requestAnimationFrame(() => {
            newEl.classList.add('revealed');
          });

          // Re-bind delete listener for the new element if admin
          if (isAuth) {
            newEl.querySelector('.gb-widget-entry-delete')?.addEventListener('click', async () => {
              newEl.style.opacity = '0';
              newEl.style.transform = 'scale(0.9)';
              try {
                const deleteRes = await fetch('/api/guestbook', {
                  method: 'DELETE',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id: newEntry.id }),
                });
                if (deleteRes.ok) {
                  setTimeout(() => {
                    newEl.remove();
                    const remaining = scrollbox.querySelectorAll('.gb-widget-entry').length;
                    countEl.textContent = `${remaining} mensajes`;
                    if (remaining === 0) emptyMsg.classList.remove('hidden');
                  }, 300);
                } else {
                  newEl.style.opacity = '1';
                  newEl.style.transform = 'scale(1)';
                }
              } catch {
                newEl.style.opacity = '1';
                newEl.style.transform = 'scale(1)';
              }
            });
          }

          // Recalculate message counts
          const total = scrollbox.querySelectorAll('.gb-widget-entry').length;
          countEl.textContent = `${total} mensajes`;
          
          // Scroll to top
          scrollbox.scrollTop = 0;
        }
      } catch {
        // Cooldown reset if failed
        lastPostTime = 0;
      }
    });

    loadEntries();
  }

  document.addEventListener('astro:page-load', initWidgetGuestbook);
</script>
