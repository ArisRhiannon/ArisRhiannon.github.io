---
/**
 * Guestbook — sticky sidebar widget (left margin) + mobile FAB/modal.
 * Props: authenticated (boolean)
 */
interface Props {
  authenticated: boolean;
}

const { authenticated } = Astro.props;
---

<!-- ═══ DESKTOP SIDEBAR WIDGET ═══ -->
<aside class="gb-sidebar" id="gb-sidebar" data-authenticated={String(authenticated)}>
  <div class="gb-widget">
    <!-- Header -->
    <header class="gb-header">
      <div class="gb-badge">✎ guestbook</div>
      <h2 class="gb-title">deja tu visita</h2>
      <p class="gb-sub">un mensaje, un emoji, lo que quieras</p>
    </header>

    <!-- Collapsible Form -->
    <div class="gb-form-wrapper" id="gb-form-wrapper">
      <button class="gb-form-toggle" id="gb-form-toggle" type="button">
        <span class="gb-toggle-icon" id="gb-toggle-icon">✦</span>
        <span class="gb-toggle-text" id="gb-toggle-text">escribir mensaje</span>
      </button>
      <div class="gb-form-collapse" id="gb-form-collapse">
        <form class="gb-form" id="gb-form">
          <input class="gb-input gb-name" id="gb-name" type="text" placeholder="tu nombre..." maxlength="50" autocomplete="off" />
          <div class="gb-emoji-picker" id="gb-emoji-picker">
            <button type="button" class="gb-emoji-btn active" data-emoji="✨">✨</button>
            <button type="button" class="gb-emoji-btn" data-emoji="💭">💭</button>
            <button type="button" class="gb-emoji-btn" data-emoji="🎮">🎮</button>
            <button type="button" class="gb-emoji-btn" data-emoji="😭">😭</button>
            <button type="button" class="gb-emoji-btn" data-emoji="📖">📖</button>
            <button type="button" class="gb-emoji-btn" data-emoji="♪">♪</button>
            <button type="button" class="gb-emoji-btn" data-emoji="💖">💖</button>
            <button type="button" class="gb-emoji-btn" data-emoji="🌸">🌸</button>
          </div>
          <textarea class="gb-input gb-message" id="gb-message" rows="2" maxlength="500" required></textarea>
          <div class="gb-form-actions">
            <span class="gb-char-count" id="gb-char-count">0/500</span>
            <button type="submit" class="gb-submit" id="gb-submit">enviar</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Entries -->
    <div class="gb-entries" id="gb-entries"></div>
  </div>
</aside>

<!-- ═══ MOBILE FAB + MODAL ═══ -->
<button class="gb-mobile-fab" id="gb-mobile-fab" type="button" aria-label="Abrir guestbook">
  <span class="gb-fab-icon">✎</span>
  <span class="gb-fab-label">guestbook</span>
</button>

<div class="gb-modal" id="gb-modal" aria-hidden="true">
  <div class="gb-modal-backdrop" id="gb-modal-backdrop"></div>
  <div class="gb-modal-panel">
    <div class="gb-modal-header">
      <div class="gb-badge">✎ guestbook</div>
      <h2 class="gb-title">deja tu visita</h2>
      <button class="gb-modal-close" id="gb-modal-close" type="button" aria-label="Cerrar">✕</button>
    </div>
    <div class="gb-modal-body">
      <!-- Form (always expanded in modal) -->
      <form class="gb-form gb-form-modal" id="gb-form-modal">
        <input class="gb-input gb-name" id="gb-name-modal" type="text" placeholder="tu nombre..." maxlength="50" autocomplete="off" />
        <div class="gb-emoji-picker" id="gb-emoji-picker-modal">
          <button type="button" class="gb-emoji-btn active" data-emoji="✨">✨</button>
          <button type="button" class="gb-emoji-btn" data-emoji="💭">💭</button>
          <button type="button" class="gb-emoji-btn" data-emoji="🎮">🎮</button>
          <button type="button" class="gb-emoji-btn" data-emoji="😭">😭</button>
          <button type="button" class="gb-emoji-btn" data-emoji="📖">📖</button>
          <button type="button" class="gb-emoji-btn" data-emoji="♪">♪</button>
          <button type="button" class="gb-emoji-btn" data-emoji="💖">💖</button>
          <button type="button" class="gb-emoji-btn" data-emoji="🌸">🌸</button>
        </div>
        <textarea class="gb-input gb-message" id="gb-message-modal" rows="2" maxlength="500" required></textarea>
        <div class="gb-form-actions">
          <span class="gb-char-count" id="gb-char-count-modal">0/500</span>
          <button type="submit" class="gb-submit" id="gb-submit-modal">enviar</button>
        </div>
      </form>
      <div class="gb-entries gb-entries-modal" id="gb-entries-modal"></div>
    </div>
  </div>
</div>

<style>
/* ═══════════════════════════════════════
   DESKTOP SIDEBAR (fixed, left margin)
   ═══════════════════════════════════════ */
.gb-sidebar {
  position: fixed;
  top: var(--space-20);
  left: max(1rem, calc(50% - 28rem - 296px));
  width: 280px;
  max-height: calc(100vh - var(--space-24));
  z-index: 100;
  display: block;
}

.gb-widget {
  background: rgba(26, 21, 32, 0.75);
  backdrop-filter: blur(24px) saturate(1.2);
  -webkit-backdrop-filter: blur(24px) saturate(1.2);
  border: 1px solid rgba(255, 107, 157, 0.12);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  box-shadow:
    var(--shadow-card),
    inset 0 1px 0 rgba(255, 245, 250, 0.04);
  overflow-y: auto;
  max-height: calc(100vh - var(--space-24));
  scrollbar-width: thin;
  scrollbar-color: rgba(255,107,157,0.15) transparent;
}

.gb-widget::-webkit-scrollbar { width: 4px; }
.gb-widget::-webkit-scrollbar-track { background: transparent; }
.gb-widget::-webkit-scrollbar-thumb {
  background: rgba(255,107,157,0.15);
  border-radius: 4px;
}

/* ── Header ── */
.gb-header {
  text-align: center;
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid rgba(255, 107, 157, 0.08);
}

.gb-badge {
  font-family: var(--font-mono);
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-accent);
  background: rgba(255,107,157,0.08);
  border: 1px solid rgba(255,107,157,0.12);
  padding: 2px 10px;
  border-radius: var(--radius-full);
  display: inline-block;
  margin-bottom: var(--space-2);
}

.gb-title {
  font-family: var(--font-deco);
  font-size: var(--text-xl);
  color: var(--color-ink);
  margin: 0 0 var(--space-1);
  font-weight: 700;
  line-height: 1.2;
}

.gb-sub {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted-2);
  margin: 0;
  letter-spacing: 0.02em;
}

/* ── Collapsible Form ── */
.gb-form-wrapper {
  margin-bottom: var(--space-4);
}

.gb-form-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: rgba(255,107,157,0.06);
  border: 1px solid rgba(255,107,157,0.12);
  border-radius: var(--radius-md);
  padding: var(--space-2) var(--space-3);
  cursor: pointer;
  transition: all var(--duration) var(--ease-out);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted);
  letter-spacing: 0.04em;
}

.gb-form-toggle:hover {
  background: rgba(255,107,157,0.10);
  border-color: rgba(255,107,157,0.20);
  color: var(--color-ink-soft);
}

.gb-toggle-icon {
  font-size: 10px;
  color: var(--color-accent);
  transition: transform var(--duration) var(--ease-out);
}

.gb-form-wrapper.open .gb-toggle-icon {
  transform: rotate(45deg);
}

.gb-form-collapse {
  display: none;
  margin-top: var(--space-3);
}

.gb-form-wrapper.open .gb-form-collapse {
  display: block;
  animation: gb-slide-down 0.25s var(--ease-out) both;
}

@keyframes gb-slide-down {
  from { opacity: 0; transform: translateY(-6px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Form ── */
.gb-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.gb-input {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-ink);
  background: rgba(255, 245, 250, 0.04);
  border: 1px solid rgba(255, 107, 157, 0.08);
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-3);
  outline: none;
  width: 100%;
  transition: border-color var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
}

.gb-input:focus {
  border-color: var(--color-border-accent);
  box-shadow: var(--glow-sm);
}

.gb-input::placeholder {
  color: var(--color-muted-2);
  font-size: var(--text-xs);
}

.gb-name { max-width: 100%; }

.gb-message {
  resize: vertical;
  min-height: 48px;
  font-size: var(--text-xs);
  line-height: 1.5;
}

.gb-emoji-picker {
  display: flex;
  gap: 1px;
  flex-wrap: wrap;
  align-items: center;
}

.gb-emoji-btn {
  background: none;
  border: 1px solid transparent;
  border-radius: 4px;
  padding: 2px 4px;
  font-size: 13px;
  cursor: pointer;
  transition: all var(--duration) var(--ease-out);
  opacity: 0.45;
  line-height: 1;
}

.gb-emoji-btn:hover { opacity: 0.8; transform: scale(1.15); }

.gb-emoji-btn.active {
  opacity: 1;
  border-color: rgba(255,107,157,0.25);
  background: rgba(255,107,157,0.08);
  box-shadow: 0 0 6px rgba(255,107,157,0.15);
}

.gb-form-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gb-char-count {
  font-family: var(--font-mono);
  font-size: 8px;
  color: var(--color-muted-2);
  letter-spacing: 0.04em;
}

.gb-submit {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-accent);
  background: rgba(255,107,157,0.08);
  border: 1px solid rgba(255,107,157,0.20);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-5);
  cursor: pointer;
  transition: all var(--duration) var(--ease-out);
  letter-spacing: 0.04em;
}

.gb-submit:hover {
  background: rgba(255,107,157,0.15);
  box-shadow: var(--glow-sm);
}

/* ── Entries ── */
.gb-entries {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

/* ── Entry Card ── */
.gb-entry {
  background: var(--color-bg-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-4);
  transition: border-color var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
  animation: gb-reveal 0.4s var(--ease-out) both;
  position: relative;
}

.gb-entry:hover {
  border-color: var(--color-border-accent);
  box-shadow: 0 2px 16px rgba(232, 64, 96, 0.06);
}

.gb-entry-top {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-2);
}

.gb-entry-emoji {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  flex-shrink: 0;
  line-height: 1;
}

.gb-entry-name {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.2;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gb-entry-delete {
  background: none;
  border: none;
  font-size: 9px;
  color: var(--color-muted-2);
  cursor: pointer;
  opacity: 0;
  transition: opacity var(--duration), color var(--duration);
  flex-shrink: 0;
  padding: 2px 4px;
  line-height: 1;
}

.gb-entry:hover .gb-entry-delete { opacity: 0.5; }
.gb-entry-delete:hover { opacity: 1 !important; color: var(--color-accent); }

.gb-entry-msg {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-ink-soft);
  line-height: 1.55;
  word-break: break-word;
}

/* ── Timestamp (clearly metadata) ── */
.gb-entry-meta {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: var(--space-1);
  padding-top: var(--space-1);
  border-top: 1px solid rgba(255, 107, 157, 0.04);
}

.gb-meta-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--color-muted-2);
  opacity: 0.5;
  flex-shrink: 0;
}

.gb-entry-time {
  font-family: var(--font-mono);
  font-size: 8px;
  color: var(--color-muted-2);
  letter-spacing: 0.06em;
  opacity: 0.7;
}

.gb-empty {
  text-align: center;
  color: var(--color-muted-2);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  padding: var(--space-4) 0;
  opacity: 0.7;
}

/* ═══════════════════════════════════════
   MOBILE FAB
   ═══════════════════════════════════════ */
.gb-mobile-fab {
  display: none;
  position: fixed;
  bottom: var(--space-8);
  left: var(--space-4);
  z-index: 800;
  background: rgba(26, 21, 32, 0.90);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--color-border-accent);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4);
  cursor: pointer;
  align-items: center;
  gap: var(--space-2);
  box-shadow: var(--glow-sm);
  transition: all var(--duration) var(--ease-out);
}

.gb-mobile-fab:hover {
  background: rgba(255,107,157,0.10);
  box-shadow: var(--glow-md);
  transform: scale(1.04);
}

.gb-fab-icon {
  font-size: 13px;
  color: var(--color-accent);
  line-height: 1;
}

.gb-fab-label {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 600;
  color: var(--color-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ═══════════════════════════════════════
   MOBILE MODAL
   ═══════════════════════════════════════ */
.gb-modal {
  position: fixed;
  inset: 0;
  z-index: 9100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s var(--ease-out);
}

.gb-modal.active {
  opacity: 1;
  pointer-events: all;
}

.gb-modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(26, 21, 32, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.gb-modal-panel {
  position: relative;
  z-index: 1;
  width: min(340px, 90vw);
  max-height: 80vh;
  background: rgba(34, 27, 42, 0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 107, 157, 0.12);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  overflow-y: auto;
  transform: translateY(20px) scale(0.96);
  transition: transform 0.3s var(--ease-out);
  box-shadow: var(--shadow-card);
}

.gb-modal.active .gb-modal-panel {
  transform: translateY(0) scale(1);
}

.gb-modal-header {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 1px solid rgba(255, 107, 157, 0.08);
}

.gb-modal-header .gb-badge {
  margin-bottom: 0;
}

.gb-modal-header .gb-title {
  flex: 1;
  margin: 0;
}

.gb-modal-close {
  background: none;
  border: none;
  color: var(--color-muted);
  font-size: 14px;
  cursor: pointer;
  padding: 4px;
  transition: color var(--duration);
}

.gb-modal-close:hover {
  color: var(--color-accent);
}

.gb-modal-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.gb-form-modal {
  margin-bottom: 0;
}

.gb-entries-modal {
  max-height: 40vh;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,107,157,0.15) transparent;
}

/* ═══════════════════════════════════════
   RESPONSIVE — hide sidebar on < 1024px, show FAB
   ═══════════════════════════════════════ */
@media (max-width: 1023px) {
  .gb-sidebar {
    display: none !important;
  }
  .gb-mobile-fab {
    display: flex;
  }
}

@media (min-width: 1024px) {
  .gb-mobile-fab {
    display: none !important;
  }
  .gb-modal {
    display: none !important;
  }
}

/* ── Also hide at very narrow viewports even if technically 1024+ ── */
@media (max-width: 1100px) and (min-width: 1024px) {
  .gb-sidebar {
    left: 0.5rem;
  }
}
</style>

<script>
function initGuestbook() {
  const isAdmin = document.querySelector('[data-authenticated="true"]') !== null;

  let selectedEmoji = '✨';
  let allEntries: any[] = [];

  // ── DOM refs — sidebar ──
  const form = document.getElementById('gb-form') as HTMLFormElement;
  const entries = document.getElementById('gb-entries');
  const messageInput = document.getElementById('gb-message') as HTMLTextAreaElement;
  const nameInput = document.getElementById('gb-name') as HTMLInputElement;
  const charCount = document.getElementById('gb-char-count');
  const emojiPicker = document.getElementById('gb-emoji-picker');

  // ── DOM refs — modal ──
  const formModal = document.getElementById('gb-form-modal') as HTMLFormElement;
  const entriesModal = document.getElementById('gb-entries-modal');
  const messageInputModal = document.getElementById('gb-message-modal') as HTMLTextAreaElement;
  const nameInputModal = document.getElementById('gb-name-modal') as HTMLInputElement;
  const charCountModal = document.getElementById('gb-char-count-modal');
  const emojiPickerModal = document.getElementById('gb-emoji-picker-modal');

  // ── Collapsible form toggle ──
  const formWrapper = document.getElementById('gb-form-wrapper');
  const formToggle = document.getElementById('gb-form-toggle');
  formToggle?.addEventListener('click', () => {
    formWrapper?.classList.toggle('open');
    if (formWrapper?.classList.contains('open')) {
      setTimeout(() => nameInput?.focus(), 150);
    }
  });

  // ── Mobile modal ──
  const mobileFab = document.getElementById('gb-mobile-fab');
  const gbModal = document.getElementById('gb-modal');
  const modalClose = document.getElementById('gb-modal-close');
  const modalBackdrop = document.getElementById('gb-modal-backdrop');

  mobileFab?.addEventListener('click', () => {
    gbModal?.classList.add('active');
    gbModal?.setAttribute('aria-hidden', 'false');
  });

  function closeGbModal() {
    gbModal?.classList.remove('active');
    gbModal?.setAttribute('aria-hidden', 'true');
  }

  modalClose?.addEventListener('click', closeGbModal);
  modalBackdrop?.addEventListener('click', closeGbModal);

  // ── Typing animation for placeholders ──
  const placeholders = [
    'deja tu mensaje...',
    'hola aris! ...',
    'me encanta tu sitio...',
    'bonito guestbook...',
    'kawaii desu ne~...',
  ];
  let phIndex = 0;
  let phCharIndex = 0;
  let phDeleting = false;
  let phPaused = false;

  function typePlaceholder() {
    const activeMsg = document.activeElement === messageInput || document.activeElement === messageInputModal
      ? null
      : (messageInputModal && getComputedStyle(gbModal!).opacity !== '0' ? messageInputModal : messageInput);

    if (!activeMsg) {
      setTimeout(typePlaceholder, 100);
      return;
    }

    if (document.activeElement === activeMsg) {
      setTimeout(typePlaceholder, 100);
      return;
    }

    const current = placeholders[phIndex];
    if (!phDeleting) {
      phCharIndex++;
      activeMsg.placeholder = current.slice(0, phCharIndex);
      if (phCharIndex === current.length) {
        phPaused = true;
        setTimeout(() => { phDeleting = true; phPaused = false; typePlaceholder(); }, 2000);
        return;
      }
      setTimeout(typePlaceholder, 60 + Math.random() * 40);
    } else {
      phCharIndex--;
      activeMsg.placeholder = current.slice(0, phCharIndex);
      if (phCharIndex === 0) {
        phDeleting = false;
        phIndex = (phIndex + 1) % placeholders.length;
        setTimeout(typePlaceholder, 300);
        return;
      }
      setTimeout(typePlaceholder, 30);
    }
  }
  typePlaceholder();

  // ── Emoji pickers ──
  function setupEmojiPicker(picker: HTMLElement | null, onSelect: (emoji: string) => void) {
    picker?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.gb-emoji-btn') as HTMLElement;
      if (!btn) return;
      picker.querySelectorAll('.gb-emoji-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      onSelect(btn.dataset.emoji ?? '✨');
    });
  }

  setupEmojiPicker(emojiPicker, (emoji) => {
    selectedEmoji = emoji;
    // Sync modal picker
    emojiPickerModal?.querySelectorAll('.gb-emoji-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.emoji === emoji);
    });
  });

  setupEmojiPicker(emojiPickerModal, (emoji) => {
    selectedEmoji = emoji;
    // Sync sidebar picker
    emojiPicker?.querySelectorAll('.gb-emoji-btn').forEach(b => {
      b.classList.toggle('active', b.dataset.emoji === emoji);
    });
  });

  // ── Char counts ──
  messageInput?.addEventListener('input', () => {
    if (charCount) charCount.textContent = `${messageInput.value.length}/500`;
  });
  messageInputModal?.addEventListener('input', () => {
    if (charCountModal) charCountModal.textContent = `${messageInputModal.value.length}/500`;
  });

  // ── Render entries ──
  function relativeTime(dateStr: string): string {
    const d = new Date(dateStr + 'Z');
    const diff = Date.now() - d.getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'ahora';
    if (mins < 60) return `hace ${mins}m`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `hace ${hrs}h`;
    const days = Math.floor(hrs / 24);
    if (days < 30) return `hace ${days}d`;
    return `hace ${Math.floor(days / 30)}mes`;
  }

  function escHtml(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function buildEntryHTML(entry: any, index: number): string {
    const time = relativeTime(entry.created_at);
    return `
      <div class="gb-entry" style="animation-delay: ${index * 40}ms">
        <div class="gb-entry-top">
          <span class="gb-entry-emoji">${entry.emoji ?? '✨'}</span>
          <span class="gb-entry-name">${escHtml(entry.name ?? 'anon')}</span>
          ${isAdmin ? `<button class="gb-entry-delete" data-id="${entry.id}" title="Eliminar">✕</button>` : ''}
        </div>
        <div class="gb-entry-msg">${escHtml(entry.message)}</div>
        <div class="gb-entry-meta">
          <span class="gb-meta-dot"></span>
          <span class="gb-entry-time">${time}</span>
        </div>
      </div>
    `;
  }

  function renderEntries(container: HTMLElement | null, items: any[], append = false) {
    if (!container) return;
    if (!append) container.innerHTML = '';
    if (items.length === 0 && !append) {
      container.innerHTML = '<p class="gb-empty">sin visitas todavia — se la primera!</p>';
      return;
    }
    items.forEach((entry, i) => {
      container.insertAdjacentHTML('beforeend', buildEntryHTML(entry, i));
    });

    // Delete handlers
    container.querySelectorAll('.gb-entry-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        if (!id) return;
        await fetch('/api/guestbook', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: Number(id) }),
        });
        loadEntries();
      });
    });
  }

  // ── Load entries ──
  async function loadEntries() {
    try {
      const res = await fetch('/api/guestbook');
      const data = await res.json();
      allEntries = data.entries ?? [];
      renderEntries(entries, allEntries);
      renderEntries(entriesModal, allEntries);
    } catch { /* ok */ }
  }

  // ── Submit helper ──
  async function handleSubmit(
    msgInput: HTMLTextAreaElement | null,
    nmInput: HTMLInputElement | null,
    submitBtn: HTMLElement | null,
  ) {
    const message = msgInput?.value?.trim();
    if (!message) return;

    const name = nmInput?.value?.trim() || 'anon';
    if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch('/api/guestbook', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, message, emoji: selectedEmoji }),
      });

      if (res.ok) {
        if (msgInput) msgInput.value = '';
        if (charCount) charCount.textContent = '0/500';
        if (charCountModal) charCountModal.textContent = '0/500';
        loadEntries();
      }
    } finally {
      if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
    }
  }

  // ── Form submit — sidebar ──
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('gb-submit');
    await handleSubmit(messageInput, nameInput, submitBtn);
  });

  // ── Form submit — modal ──
  formModal?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('gb-submit-modal');
    await handleSubmit(messageInputModal, nameInputModal, submitBtn);
  });

  loadEntries();
}

document.addEventListener('astro:page-load', initGuestbook);
</script>
