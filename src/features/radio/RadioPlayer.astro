---
// RadioPlayer.astro — Full-featured audio player
// Position: left bottom, playlist, upload for admin, volume normalizer, manual play only, multi-format
import { existsSync, readdirSync, statSync } from 'fs';
import { join } from 'path';

const hasLocalSong = existsSync(join(process.cwd(), 'public', 'aris_song.mp3'));

// Scan for local audio tracks in public/music/
const musicDir = join(process.cwd(), 'public', 'music');
let localTracks: { name: string; url: string }[] = [];
if (existsSync(musicDir)) {
  try {
    const files = readdirSync(musicDir).filter(f =>
      /\.(mp3|ogg|opus|flac|wav|m4a|aac|webm)$/i.test(f)
    );
    localTracks = files.map(f => ({
      name: f.replace(/\.[^.]+$/, ''),
      url: `/music/${f}`,
    }));
  } catch { /* ok */ }
}

// If there's a legacy aris_song.mp3, include it
if (hasLocalSong && !localTracks.some(t => t.url === '/aris_song.mp3')) {
  localTracks.unshift({ name: 'aris · song', url: '/aris_song.mp3' });
}

const FALLBACK_STREAMS = [
  'https://streams.ilovemusic.de/iloveradio17.mp3',
  'https://radio.plaza.one/mp3',
  'https://listen.moe/stream',
];
const STATION_NAME = localTracks.length > 0 ? localTracks[0].name : 'lo-fi · aris fm';
---

<div id="radio-player" class="rp" transition:persist>
  <!-- Mini bar (collapsed) -->
  <div class="rp-mini" id="rp-mini">
    <button class="rp-toggle" id="rp-toggle" aria-label="Abrir radio" aria-pressed="false">
      <span class="rp-play-icon" aria-hidden="true">&#9654;</span>
      <span class="rp-bars" aria-hidden="true">
        <span class="bar"></span><span class="bar"></span><span class="bar"></span>
      </span>
    </button>
    <span class="rp-mini-name" id="rp-mini-name">{STATION_NAME}</span>
    <span class="rp-mini-status" id="rp-mini-status">pausado</span>
  </div>

  <!-- Expanded panel -->
  <div class="rp-panel" id="rp-panel" aria-hidden="true">
    <!-- Header -->
    <div class="rp-header">
      <div class="rp-station">
        <span class="rp-icon-live" aria-hidden="true">&#9834;</span>
        <div class="rp-station-info">
          <span class="rp-name" id="rp-name">{STATION_NAME}</span>
          <span class="rp-status" id="rp-status">pausado</span>
        </div>
      </div>
      <button class="rp-collapse" id="rp-collapse" aria-label="Minimizar radio">&#9660;</button>
    </div>

    <!-- Progress bar (for local files) -->
    <div class="rp-progress-wrap" id="rp-progress-wrap">
      <div class="rp-progress-bar" id="rp-progress-bar">
        <div class="rp-progress-fill" id="rp-progress-fill"></div>
      </div>
      <div class="rp-time-row">
        <span class="rp-time-current" id="rp-time-current">0:00</span>
        <span class="rp-time-total" id="rp-time-total">0:00</span>
      </div>
    </div>

    <!-- Visualizer bars -->
    <div class="rp-visualizer" id="rp-visualizer" aria-hidden="true">
      <span class="viz-bar"></span><span class="viz-bar"></span><span class="viz-bar"></span>
      <span class="viz-bar"></span><span class="viz-bar"></span><span class="viz-bar"></span>
      <span class="viz-bar"></span><span class="viz-bar"></span><span class="viz-bar"></span>
      <span class="viz-bar"></span><span class="viz-bar"></span><span class="viz-bar"></span>
      <span class="viz-bar"></span><span class="viz-bar"></span><span class="viz-bar"></span>
      <span class="viz-bar"></span><span class="viz-bar"></span><span class="viz-bar"></span>
    </div>

    <!-- Controls -->
    <div class="rp-controls">
      <button class="rp-btn rp-prev" id="rp-prev" aria-label="Anterior" title="Anterior">&#9664;&#9664;</button>
      <button class="rp-btn rp-play" id="rp-play" aria-label="Reproducir">
        <span class="rp-pause-icon" aria-hidden="true">&#9208;</span>
        <span class="rp-play-icon2" aria-hidden="true">&#9654;</span>
      </button>
      <button class="rp-btn rp-next" id="rp-next" aria-label="Siguiente" title="Siguiente">&#9654;&#9654;</button>
    </div>

    <!-- Volume + Normalize toggle -->
    <div class="rp-volume-row">
      <span class="rp-vol-icon" aria-hidden="true">&#128264;</span>
      <input type="range" id="rp-volume" class="rp-volume" min="0" max="1" step="0.05" value="0.6" aria-label="Volumen" />
      <span class="rp-vol-icon" aria-hidden="true">&#128266;</span>
      <button class="rp-norm-btn" id="rp-norm-btn" title="Normalizador de volumen" aria-label="Normalizador de volumen">
        <span class="rp-norm-icon">N</span>
      </button>
    </div>

    <!-- Playlist -->
    <div class="rp-playlist" id="rp-playlist">
      <div class="rp-pl-head">playlist</div>
      <div class="rp-pl-list" id="rp-pl-list">
        {localTracks.map((track, i) => (
          <button class={`rp-pl-item ${i === 0 ? 'active' : ''}`} data-src={track.url} data-idx={String(i)} data-local="true">
            <span class="pl-idx">{String(i + 1).padStart(2, '0')}</span>
            <span class="pl-name">{track.name}</span>
            <span class="pl-live"></span>
          </button>
        ))}
        {!localTracks.length && FALLBACK_STREAMS.map((url, i) => (
          <button class={`rp-pl-item ${i === 0 ? 'active' : ''}`} data-src={url} data-idx={String(i)}>
            <span class="pl-idx">{String(i + 1).padStart(2, '0')}</span>
            <span class="pl-name">{i === 0 ? 'lo-fi · aris fm' : `stream ${i + 1}`}</span>
            <span class="pl-live">live</span>
          </button>
        ))}
        {localTracks.length > 0 && FALLBACK_STREAMS.map((url, i) => (
          <button class="rp-pl-item" data-src={url} data-idx={String(localTracks.length + i)}>
            <span class="pl-idx">{String(localTracks.length + i + 1).padStart(2, '0')}</span>
            <span class="pl-name">stream {i + 1}</span>
            <span class="pl-live">live</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Upload (admin only, hidden by default, shown via JS) -->
    <div class="rp-upload" id="rp-upload" style="display:none">
      <div class="rp-upload-row">
        <input type="file" id="rp-file-input" accept="audio/*,.mp3,.ogg,.opus,.flac,.wav,.aac,.m4a,.webm" style="display:none" multiple />
        <button class="rp-upload-btn" id="rp-upload-btn" title="Subir archivos de audio">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v8M4 4l3-3 3 3M2 10v2a1 1 0 001 1h8a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>subir audio</span>
        </button>
      </div>
      <div class="rp-upload-progress" id="rp-upload-progress" style="display:none">
        <div class="rp-upload-track"><div class="rp-upload-fill" id="rp-upload-fill"></div></div>
        <span class="rp-upload-label" id="rp-upload-label">subiendo...</span>
      </div>
      <div class="rp-upload-done" id="rp-upload-done" style="display:none"></div>
    </div>
  </div>
</div>

<script define:vars={{ FALLBACK_STREAMS, STATION_NAME }}>
if (!window.__rpInit) {
  window.__rpInit = true;

  let audio = null;
  let playing = false;
  let currentIdx = 0;
  let normalizerEnabled = false;
  let gainNode = null;
  let audioCtx = null;
  let sourceNode = null;
  let currentGain = 1.0;

  // Build sources from server-rendered playlist
  function buildSources() {
    const items = document.querySelectorAll('#rp-pl-list .rp-pl-item');
    const srcs = [];
    items.forEach(el => {
      srcs.push({
        url: el.dataset.src,
        name: el.querySelector('.pl-name')?.textContent ?? 'unknown',
        isLocal: el.dataset.local === 'true',
        isLive: el.querySelector('.pl-live')?.textContent?.trim() === 'live',
      });
    });
    return srcs;
  }

  let sources = buildSources();
  if (sources.length === 0) {
    sources = FALLBACK_STREAMS.map((url, i) => ({
      url,
      name: i === 0 ? STATION_NAME : `stream ${i + 1}`,
      isLocal: false,
      isLive: true,
    }));
  }

  function $(id) { return document.getElementById(id); }

  function formatTime(sec) {
    if (!sec || !isFinite(sec)) return '0:00';
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s < 10 ? '0' : ''}${s}`;
  }

  function setUI(isPlaying, statusText) {
    playing = isPlaying;
    const panel = $('rp-panel');
    const mini = $('rp-mini');
    const status = $('rp-status');
    const miniStatus = $('rp-mini-status');
    const miniName = $('rp-mini-name');
    const name = $('rp-name');
    const playBtn = $('rp-play');
    const toggleBtn = $('rp-toggle');

    if (panel) panel.classList.toggle('is-playing', isPlaying);
    if (mini) mini.classList.toggle('is-playing', isPlaying);
    if (playBtn) playBtn.classList.toggle('is-playing', isPlaying);
    if (toggleBtn) toggleBtn.setAttribute('aria-pressed', String(isPlaying));

    const src = sources[currentIdx];
    const st = statusText ?? (isPlaying ? (src?.isLive ? 'en vivo' : 'reproduciendo') : 'pausado');
    if (status) status.textContent = st;
    if (miniStatus) miniStatus.textContent = st;
    if (name && !statusText) name.textContent = src?.name ?? STATION_NAME;
    if (miniName) miniName.textContent = name?.textContent ?? STATION_NAME;

    // Show/hide progress bar based on local/live
    const progWrap = $('rp-progress-wrap');
    if (progWrap) {
      progWrap.style.display = (src?.isLocal || (src && !src.isLive)) ? '' : 'none';
    }

    // Highlight playlist item
    document.querySelectorAll('.rp-pl-item').forEach((el, i) => {
      el.classList.toggle('active', i === currentIdx);
    });
  }

  function initAudioCtx() {
    if (audioCtx) return;
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    gainNode = audioCtx.createGain();
    gainNode.gain.value = 1.0;
    gainNode.connect(audioCtx.destination);
  }

  function hookAudioToCtx(el) {
    if (!normalizerEnabled) return;
    initAudioCtx();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    if (sourceNode) { try { sourceNode.disconnect(); } catch(e){} }
    try {
      sourceNode = audioCtx.createMediaElementSource(el);
      sourceNode.connect(gainNode);
    } catch(e) {
      // Already connected — this is fine for autoplay
    }
  }

  // ── Volume Normalizer (simple RMS-based loudness normalization) ──
  // Uses Web Audio API GainNode to adjust volume per-track
  function analyzeAndNormalize(el) {
    if (!normalizerEnabled || !gainNode) return;
    // Use AnalyserNode to measure RMS, then adjust gain
    initAudioCtx();
    const analyser = audioCtx.createAnalyser();
    analyser.fftSize = 2048;
    analyser.smoothingTimeConstant = 0.95;

    // We need to reconnect: source -> analyser -> gainNode -> dest
    if (sourceNode) { try { sourceNode.disconnect(); } catch(e){} }
    try {
      sourceNode.connect(analyser);
      analyser.connect(gainNode);
    } catch(e) {}

    const data = new Float32Array(analyser.fftSize);
    let samples = 0;
    let rmsAccum = 0;

    function measure() {
      if (!playing) {
        // Reset gain to neutral when paused
        if (gainNode) gainNode.gain.value = 1.0;
        return;
      }
      analyser.getFloatTimeDomainData(data);
      let rms = 0;
      for (let i = 0; i < data.length; i++) rms += data[i] * data[i];
      rms = Math.sqrt(rms / data.length);

      // Target RMS ~0.15 (comfortable listening)
      const target = 0.15;
      if (rms > 0.001) {
        // Smoothly adjust gain
        const desired = Math.min(3.0, Math.max(0.2, target / rms));
        currentGain += (desired - currentGain) * 0.05; // smooth
        gainNode.gain.value = currentGain;
      }

      samples++;
      if (samples < 600) { // measure for ~10 seconds at 60fps
        requestAnimationFrame(measure);
      } else {
        // After initial measurement, check every 5 seconds
        setTimeout(() => { samples = 0; measure(); }, 5000);
      }
    }

    // Start measuring after a short delay
    setTimeout(measure, 500);
  }

  function initAudio() {
    if (audio) return;
    const src = sources[currentIdx];
    audio = new Audio(src?.url ?? sources[0]?.url);
    if (src?.isLocal) audio.loop = false; // We'll handle playlist progression
    audio.volume = parseFloat($('rp-volume')?.value ?? '0.6');
    audio.preload = 'metadata';

    audio.addEventListener('playing', () => {
      setUI(true);
      if (normalizerEnabled) hookAudioToCtx(audio);
      if (normalizerEnabled) analyzeAndNormalize(audio);
    });
    audio.addEventListener('pause', () => setUI(false));
    audio.addEventListener('ended', () => {
      // Auto-advance to next track
      currentIdx = (currentIdx + 1) % sources.length;
      loadAndPlay();
    });
    audio.addEventListener('error', () => {
      // Skip to next on error
      if (sources.length > 1) {
        currentIdx = (currentIdx + 1) % sources.length;
        loadAndPlay();
      } else {
        setUI(false, 'error');
      }
    });

    // Time update for progress bar
    audio.addEventListener('timeupdate', () => {
      const fill = $('rp-progress-fill');
      const cur = $('rp-time-current');
      const tot = $('rp-time-total');
      if (audio.duration && isFinite(audio.duration)) {
        const pct = (audio.currentTime / audio.duration) * 100;
        if (fill) fill.style.width = pct + '%';
        if (cur) cur.textContent = formatTime(audio.currentTime);
        if (tot) tot.textContent = formatTime(audio.duration);
      }
    });

    // Loaded metadata
    audio.addEventListener('loadedmetadata', () => {
      const tot = $('rp-time-total');
      if (tot && audio.duration && isFinite(audio.duration)) {
        tot.textContent = formatTime(audio.duration);
      }
    });
  }

  function loadAndPlay() {
    if (!audio) initAudio();
    const src = sources[currentIdx];
    if (!src) return;

    audio.loop = false; // Never loop — playlist handles progression
    audio.src = src.url;

    // Reset progress
    const fill = $('rp-progress-fill');
    if (fill) fill.style.width = '0%';
    const cur = $('rp-time-current');
    if (cur) cur.textContent = '0:00';
    const tot = $('rp-time-total');
    if (tot) tot.textContent = src.isLive ? 'live' : '0:00';

    // Reset normalizer gain
    currentGain = 1.0;
    if (gainNode) gainNode.gain.value = 1.0;

    setUI(false, 'cargando...');
    audio.play().catch(() => setUI(false, 'click para activar'));
  }

  function toggle() {
    initAudio();
    if (playing) {
      audio.pause();
    } else {
      if (audio.src && audio.readyState >= 2) {
        audio.play().catch(() => setUI(false, 'click para activar'));
      } else {
        loadAndPlay();
      }
    }
  }

  function next() { currentIdx = (currentIdx + 1) % sources.length; loadAndPlay(); }
  function prev() { currentIdx = (currentIdx - 1 + sources.length) % sources.length; loadAndPlay(); }

  function bindEvents() {
    const toggle = $('rp-toggle');
    const play = $('rp-play');
    const prevBtn = $('rp-prev');
    const nextBtn = $('rp-next');
    const vol = $('rp-volume');
    const collapse = $('rp-collapse');
    const mini = $('rp-mini');
    const panel = $('rp-panel');
    const normBtn = $('rp-norm-btn');
    const progressBar = $('rp-progress-bar');

    toggle?.removeEventListener('click', toggleClick);
    toggle?.addEventListener('click', toggleClick);
    play?.removeEventListener('click', toggle);
    play?.addEventListener('click', toggle);
    prevBtn?.removeEventListener('click', prev);
    prevBtn?.addEventListener('click', prev);
    nextBtn?.removeEventListener('click', next);
    nextBtn?.addEventListener('click', next);

    vol?.addEventListener('input', e => { if (audio) audio.volume = parseFloat(e.target.value); });

    collapse?.addEventListener('click', () => {
      panel?.setAttribute('aria-hidden', 'true');
      mini?.setAttribute('aria-hidden', 'false');
    });

    // ── Progress bar seek ──
    progressBar?.addEventListener('click', (e) => {
      if (!audio || !audio.duration || !isFinite(audio.duration)) return;
      const rect = progressBar.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pct * audio.duration;
    });

    // ── Normalizer toggle ──
    normBtn?.removeEventListener('click', toggleNorm);
    normBtn?.addEventListener('click', toggleNorm);

    // Playlist click
    document.querySelectorAll('.rp-pl-item').forEach(el => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.dataset.idx ?? '0');
        currentIdx = idx;
        loadAndPlay();
      });
    });

    // Show upload for admin
    const authFlag = document.querySelector('[data-authenticated="true"]');
    if (authFlag && $('rp-upload')) $('rp-upload').style.display = '';

    // ── File upload (proper server upload) ──
    const uploadBtn = $('rp-upload-btn');
    const fileInput = $('rp-file-input');
    const uploadProgress = $('rp-upload-progress');
    const uploadFill = $('rp-upload-fill');
    const uploadLabel = $('rp-upload-label');
    const uploadDone = $('rp-upload-done');

    uploadBtn?.removeEventListener('click', uploadClickHandler);
    uploadBtn?.addEventListener('click', uploadClickHandler);

    function uploadClickHandler() {
      fileInput?.click();
    }

    fileInput?.removeEventListener('change', uploadChangeHandler);
    fileInput?.addEventListener('change', uploadChangeHandler);

    async function uploadChangeHandler() {
      const files = fileInput?.files;
      if (!files || files.length === 0) return;

      for (const file of files) {
        // Validate format
        const validExts = ['.mp3','.ogg','.opus','.flac','.wav','.aac','.m4a','.webm'];
        const ext = '.' + file.name.split('.').pop().toLowerCase();
        if (!validExts.includes(ext)) {
          if (uploadDone) {
            uploadDone.style.display = '';
            uploadDone.textContent = `formato no soportado: ${ext}`;
            setTimeout(() => { uploadDone.style.display = 'none'; }, 3000);
          }
          continue;
        }

        // Show progress
        if (uploadProgress) uploadProgress.style.display = '';
        if (uploadFill) uploadFill.style.width = '0%';
        if (uploadLabel) uploadLabel.textContent = `subiendo ${file.name}...`;

        try {
          const formData = new FormData();
          formData.append('file', file);
          formData.append('purpose', 'audio');

          const xhr = new XMLHttpRequest();
          xhr.open('POST', '/api/radio/upload');

          xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
              const pct = Math.round((e.loaded / e.total) * 100);
              if (uploadFill) uploadFill.style.width = pct + '%';
              if (uploadLabel) uploadLabel.textContent = `${pct}% — ${file.name}`;
            }
          };

          const result = await new Promise((resolve, reject) => {
            xhr.onload = () => {
              if (xhr.status >= 200 && xhr.status < 300) {
                try { resolve(JSON.parse(xhr.responseText)); }
                catch { resolve({ ok: true }); }
              } else {
                reject(new Error(`upload failed: ${xhr.status}`));
              }
            };
            xhr.onerror = () => reject(new Error('network error'));
            xhr.send(formData);
          });

          if (result.ok && result.url) {
            // Add to sources and playlist
            const newIdx = sources.length;
            sources.push({
              url: result.url,
              name: file.name.replace(/\.[^.]+$/, ''),
              isLocal: true,
              isLive: false,
            });

            // Add to playlist DOM
            const plList = $('rp-pl-list');
            if (plList) {
              const btn = document.createElement('button');
              btn.className = 'rp-pl-item';
              btn.dataset.src = result.url;
              btn.dataset.idx = String(newIdx);
              btn.dataset.local = 'true';
              btn.innerHTML = `<span class="pl-idx">${String(newIdx + 1).padStart(2, '0')}</span><span class="pl-name">${file.name.replace(/\.[^.]+$/, '')}</span><span class="pl-live"></span>`;
              btn.addEventListener('click', () => {
                currentIdx = newIdx;
                loadAndPlay();
              });
              plList.appendChild(btn);
            }

            if (uploadDone) {
              uploadDone.style.display = '';
              uploadDone.textContent = `${file.name} subido`;
              setTimeout(() => { uploadDone.style.display = 'none'; }, 3000);
            }

            // Auto-play the uploaded track
            currentIdx = newIdx;
            loadAndPlay();
          } else {
            throw new Error(result.error || 'upload failed');
          }
        } catch(err) {
          if (uploadDone) {
            uploadDone.style.display = '';
            uploadDone.textContent = `error: ${err.message}`;
            setTimeout(() => { uploadDone.style.display = 'none'; }, 4000);
          }
        }

        if (uploadProgress) uploadProgress.style.display = 'none';
      }

      // Reset file input
      if (fileInput) fileInput.value = '';
    }

    if (playing) setUI(true);
  }

  function toggleNorm() {
    normalizerEnabled = !normalizerEnabled;
    const btn = $('rp-norm-btn');
    if (btn) btn.classList.toggle('active', normalizerEnabled);

    if (normalizerEnabled && audio) {
      hookAudioToCtx(audio);
      analyzeAndNormalize(audio);
    } else if (!normalizerEnabled && gainNode) {
      gainNode.gain.value = 1.0;
      currentGain = 1.0;
    }
  }

  function toggleClick() {
    const panel = $('rp-panel');
    const mini = $('rp-mini');
    const isExpanded = panel?.getAttribute('aria-hidden') === 'false';
    if (isExpanded) {
      panel?.setAttribute('aria-hidden', 'true');
      mini?.setAttribute('aria-hidden', 'false');
    } else {
      panel?.setAttribute('aria-hidden', 'false');
      mini?.setAttribute('aria-hidden', 'true');
    }
  }

// ── Autoplay on first interaction (DESHABILITADO - reproducción manual) ──
// let hasAutoplayed = false;
// function tryAutoplay() {
//   if (hasAutoplayed) return;
//   hasAutoplayed = true;
//   initAudio();
//   if (audio) {
//     audio.play().then(() => {
//       setUI(true);
//     }).catch(() => {
//       // Browser blocked autoplay — user needs to click
//       setUI(false, 'click para activar');
//     });
//   }
//   document.removeEventListener('click', tryAutoplay);
//   document.removeEventListener('keydown', tryAutoplay);
// }

// Try autoplay after a small delay (COMENTADO - autoplay manual)
// setTimeout(() => {
//   tryAutoplay();
// }, 1500);

// If autoplay blocked, try on first user interaction (COMENTADO)
// document.addEventListener('click', tryAutoplay, { once: true });
// document.addEventListener('keydown', tryAutoplay, { once: true });

  bindEvents();
  document.addEventListener('astro:page-load', () => {
    sources = buildSources();
    bindEvents();
  });
}
</script>

<script>
// Visualizer bars — same as before
document.addEventListener('astro:page-load', () => {
  const vizBars = document.querySelectorAll('#rp-visualizer .viz-bar');
  if (!vizBars.length) return;

  let audioCtxViz = null, analyserViz = null, sourceNodeViz = null;

  function ensureCtx() {
    if (audioCtxViz) return;
    audioCtxViz = new (window.AudioContext || window.webkitAudioContext)();
    analyserViz = audioCtxViz.createAnalyser();
    analyserViz.fftSize = 64;
    analyserViz.smoothingTimeConstant = 0.8;
    analyserViz.connect(audioCtxViz.destination);
  }

  function hookAudio(el) {
    ensureCtx();
    if (audioCtxViz.state === 'suspended') audioCtxViz.resume();
    if (sourceNodeViz) { try { sourceNodeViz.disconnect(); } catch(e){} }
    try {
      sourceNodeViz = audioCtxViz.createMediaElementSource(el);
      sourceNodeViz.connect(analyserViz);
    } catch(e) {}

    const freqData = new Uint8Array(analyserViz.frequencyBinCount);

    function tick() {
      requestAnimationFrame(tick);
      analyserViz.getByteFrequencyData(freqData);
      const bars = document.querySelectorAll('#rp-visualizer .viz-bar');
      bars.forEach((bar, i) => {
        const val = freqData[i] ?? 0;
        const pct = Math.max(4, (val / 255) * 100);
        bar.style.height = pct + '%';
      });
    }
    tick();
  }

  // Hook audio after a delay
  setTimeout(() => {
    const el = document.querySelector('#radio-player audio, audio');
    if (el && !el.__vizHooked) { el.__vizHooked = true; hookAudio(el); }
  }, 2000);

  // Try again on play
  document.addEventListener('play', (e) => {
    const el = e.target;
    if (el instanceof HTMLAudioElement && !el.__vizHooked) {
      el.__vizHooked = true;
      hookAudio(el);
    }
  }, true);
});
</script>

