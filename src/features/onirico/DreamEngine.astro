---
// /src/features/onirico/DreamEngine.astro
---
<div id="focus-fractal-canvas" class="fixed inset-0 z-0 bg-[#05050a] overflow-hidden" transition:persist="focus-fractal-canvas"></div>

<div class="fixed inset-0 z-10 flex flex-col items-center justify-center pointer-events-none">
  <div class="pointer-events-auto p-10 rounded-3xl border" 
       style="background: var(--color-surface); border: var(--glass-border); box-shadow: var(--shadow-lg); backdrop-filter: var(--glass-blur);">
    <h2 class="text-3xl font-display mb-1 text-center" style="color: var(--color-ink); text-shadow: var(--glow-md);">Locus Coeruleus</h2>
    <p class="font-mono text-xs text-center mb-8 uppercase tracking-widest" style="color: var(--color-muted);">Sincronía Pluvial v17.0</p>
    
    <div class="flex gap-4 justify-center">
        <button id="btn-focus-start" class="px-8 py-3 rounded-full font-mono text-sm transition-all hover:scale-105 active:scale-95" 
                style="color: var(--color-cyan); border: 1px solid var(--color-cyan); box-shadow: var(--glow-cyan); background: rgba(34, 211, 238, 0.05);">
            Sincronizar
        </button>
        <button id="btn-focus-stop" class="px-8 py-3 rounded-full font-mono text-sm transition-all hover:opacity-50" 
                style="color: var(--color-muted); border: 1px solid var(--color-border);">
            Pausar
        </button>
    </div>
  </div>
</div>

<script is:inline src="/scripts/p5.min.js"></script>

<script>
  class OniricoAudioEngine {
    constructor() {
      this.ctx = null; this.initialized = false; this.isPlaying = false;
      this.nodes = []; this.startTime = 0; this.pulseFreq = 0.1;
      this.nextGroupTime = 0; this.whiteBuffer = null;
    }

    getPulseValue() {
      if (!this.isPlaying || !this.ctx) return 0;
      return Math.sin(2 * Math.PI * this.pulseFreq * (this.ctx.currentTime - this.startTime));
    }

    async setup() {
      if (this.initialized) return;
      this.ctx = new (window.AudioContext || window.webkitAudioContext)();
      this.masterGain = this.ctx.createGain();
      this.masterGain.connect(this.ctx.destination);
      this.masterGain.gain.setValueAtTime(0, this.ctx.currentTime);
      
      const bufferSize = this.ctx.sampleRate * 2;
      this.whiteBuffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
      const data = this.whiteBuffer.getChannelData(0);
      for(let i=0; i<bufferSize; i++) data[i] = Math.random() * 2 - 1;
      
      this.initialized = true;
    }

    scheduler() {
      if (!this.isPlaying) return;
      const now = this.ctx.currentTime;
      if (this.nextGroupTime < now) this.nextGroupTime = now;

      while (this.nextGroupTime < now + 0.15) {
        const pulse = this.getPulseValue();
        const dropCount = Math.floor(3 + Math.random() * 5); 
        let burstOffset = 0;

        for (let i = 0; i < dropCount; i++) {
            this.triggerSatisfyingDrop(this.nextGroupTime + burstOffset);
            burstOffset += (0.015 + Math.random() * 0.035) * (pulse + 1.2); 
        }
        
        const groupLambda = 0.4 + (pulse + 1) * 0.6; 
        this.nextGroupTime += -Math.log(Math.random()) / groupLambda;
      }
      requestAnimationFrame(() => this.scheduler());
    }

    triggerSatisfyingDrop(time) {
      const source = this.ctx.createBufferSource();
      source.buffer = this.whiteBuffer;
      
      const impactFilter = this.ctx.createBiquadFilter();
      impactFilter.type = 'lowpass';
      impactFilter.frequency.setValueAtTime(1200, time);
      
      const panner = this.ctx.createStereoPanner();
      panner.pan.setValueAtTime(Math.random() * 1.6 - 0.8, time);

      const excitatorGain = this.ctx.createGain();
      // FIX V17: Eliminación de sufijos "s" en constantes de tiempo
      excitatorGain.gain.setValueAtTime(0, time);
      excitatorGain.gain.setTargetAtTime(0.08 + Math.random() * 0.05, time, 0.01); 
      excitatorGain.gain.setTargetAtTime(0, time + 0.02, 0.04); 
      
      const delayTime = 0.0015 + Math.random() * 0.003; 
      const feedbackGainValue = 0.65 + Math.random() * 0.15; 

      const delayNode = this.ctx.createDelay();
      delayNode.delayTime.setValueAtTime(delayTime, time);
      
      const feedbackGain = this.ctx.createGain();
      feedbackGain.gain.setValueAtTime(feedbackGainValue, time);
      
      const combMix = this.ctx.createGain();
      
      excitatorGain.connect(combMix);
      excitatorGain.connect(delayNode);
      delayNode.connect(feedbackGain);
      feedbackGain.connect(excitatorGain); 

      const dampingFilter = this.ctx.createBiquadFilter();
      dampingFilter.type = 'lowpass';
      dampingFilter.frequency.setValueAtTime(feedbackGainValue > 0.75 ? 1600 : 2200, time);

      combMix.connect(panner);
      panner.connect(dampingFilter);
      dampingFilter.connect(this.masterGain);
      
      source.connect(excitatorGain);
      source.start(time);
      source.stop(time + 0.8);
    }

    async start() {
      if (this.isPlaying) return;
      if (!this.initialized) await this.setup();
      if (this.ctx.state === 'suspended') await this.ctx.resume();
      this.isPlaying = true;
      this.startTime = this.ctx.currentTime;
      this.nextGroupTime = this.ctx.currentTime;
      this.masterGain.gain.setValueAtTime(0, this.ctx.currentTime);
      this.masterGain.gain.linearRampToValueAtTime(0.85, this.ctx.currentTime + 5);
      this.startBaseLayers();
      this.scheduler();
    }

    startBaseLayers() {
      const brown = this.ctx.createBufferSource();
      const buffer = this.ctx.createBuffer(1, this.ctx.sampleRate * 4, this.ctx.sampleRate);
      const data = buffer.getChannelData(0);
      let lastOut = 0;
      for (let i = 0; i < data.length; i++) {
        const white = Math.random() * 2 - 1;
        data[i] = (lastOut + (0.02 * white)) / 1.02; lastOut = data[i];
        data[i] *= 1.1; 
      }
      brown.buffer = buffer; brown.loop = true;
      const bGain = this.ctx.createGain(); bGain.gain.value = 0.2;
      brown.connect(bGain); bGain.connect(this.masterGain);
      brown.start();
      this.nodes.push(brown);
    }

    async stop() {
      this.isPlaying = false;
      if (this.ctx) this.masterGain.gain.setTargetAtTime(0, this.ctx.currentTime, 1);
      setTimeout(() => { 
        this.nodes.forEach(n => {try{n.stop();n.disconnect();}catch(e){}});
        if(this.ctx) this.ctx.close().then(()=>this.initialized=false);
      }, 3000);
    }
  }

  let audioEngine = null;
  document.addEventListener("astro:page-load", () => {
    const container = document.getElementById("focus-fractal-canvas");
    if (!container || window.oniricoVisualEngine) return;
    audioEngine = new OniricoAudioEngine();
    const sketch = (p) => {
      let active = false; let globalTime = 0; let rain = [];
      p.setup = () => {
        // Garantizar centrado absoluto usando innerWidth/Height
        p.createCanvas(window.innerWidth, window.innerHeight).style('display', 'block').parent("focus-fractal-canvas");
        p.colorMode(p.HSB, 360, 100, 100, 1); p.angleMode(p.DEGREES);
        document.getElementById("btn-focus-start")?.addEventListener("click", async () => { active = true; await audioEngine.start(); });
        document.getElementById("btn-focus-stop")?.addEventListener("click", async () => { active = false; await audioEngine.stop(); });
      };
      p.draw = () => {
        p.background(245, 50, 4, 0.22); if (!active) return;
        const pulse = (audioEngine && audioEngine.isPlaying) ? audioEngine.getPulseValue() : 0;
        globalTime += p.map(pulse, -1, 1, 0.003, 0.012);
        p.push(); p.translate(p.width / 2, p.height / 2);
        p.noFill(); p.strokeWeight(2.5); p.stroke(p.map(pulse, -1, 1, 180, 210), 80, 90, 0.4);
        p.beginShape();
        for (let a = 0; a <= 360; a += 5) {
          let nv = p.noise(p.cos(a)+1.5, p.sin(a)+1.5, globalTime);
          let r = (130 + pulse * 45) + p.map(nv, 0, 1, -20, 20);
          p.vertex(r * p.cos(a), r * p.sin(a));
        }
        p.endShape(p.CLOSE);
        p.stroke(p.map(pulse, -1, 1, 260, 295), 60, p.map(pulse, -1, 1, 35, 75), 0.45);
        for(let i=0; i<4; i++) { p.push(); p.rotate(i * 90 + globalTime * 5); grow(p, 105, 0, pulse, globalTime); p.pop(); }
        if (p.random() < 0.5) rain.push({x: p.random(-p.width/2, p.width/2), y: -p.height/2, h: p.random(15, 25), s: p.random(10, 20)});
        for(let i=rain.length-1; i>=0; i--) {
          rain[i].y += rain[i].s * (pulse + 1.3); p.stroke(200, 40, 90, 0.25);
          p.line(rain[i].x, rain[i].y, rain[i].x, rain[i].y + rain[i].h);
          if (rain[i].y > p.height/2) rain.splice(i, 1);
        }
        p.pop();
      };
      function grow(p, len, depth, pulse, gt) {
        p.strokeWeight(p.map(depth, 0, 6, 3, 0.6)); p.line(0, 0, 0, -len); p.translate(0, -len);
        if (depth < 6) {
          let ang = p.map(p.noise(gt + depth, 42), 0, 1, 22, 38) + (pulse * 7);
          p.push(); p.rotate(ang); grow(p, len * 0.67, depth + 1, pulse, gt); p.pop();
          p.push(); p.rotate(-ang); grow(p, len * 0.67, depth + 1, pulse, gt); p.pop();
        }
      }
      p.windowResized = () => p.resizeCanvas(window.innerWidth, window.innerHeight);
    };
    window.oniricoVisualEngine = new p5(sketch);
  });
  document.addEventListener("astro:before-swap", async () => {
    if (audioEngine) await audioEngine.stop();
    if (window.oniricoVisualEngine) { window.oniricoVisualEngine.remove(); window.oniricoVisualEngine = null; }
  });
</script>
