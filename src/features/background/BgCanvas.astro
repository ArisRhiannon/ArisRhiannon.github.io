---
---
<canvas id="bg-canvas" aria-hidden="true"></canvas>
<style is:global>
  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
<script>
document.addEventListener('astro:page-load', () => {
  const canvas = document.getElementById('bg-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, raf;
  let mouseX = -999, mouseY = -999;

  function resize() {
    const r = window.devicePixelRatio || 1;
    canvas.width = window.innerWidth * r;
    canvas.height = window.innerHeight * r;
    ctx.scale(r, r);
    W = window.innerWidth;
    H = window.innerHeight;
  }

  // Palette — yume dark: rose, lavender, cyan, gold
  const COLORS = [
    [255, 107, 157], // accent rosa neon
    [255, 160, 196], // accent-2
    [196, 181, 253], // lavender
    [103, 232, 249], // cyan
    [134, 239, 172], // sage
    [251, 191, 36],  // gold
  ];

  const COUNT = window.matchMedia('(max-width: 768px)').matches ? 15 : 40;

  type Shape = 0 | 1 | 2 | 3;

  interface Particle {
    x: number; y: number;
    ax: number; ay: number;
    fx: number; fy: number;
    phase: number;
    shape: Shape;
    size: number;
    opacity: number;
    color: number[];
    rotation: number;
    rotSpeed: number;
  }

  const particles: Particle[] = [];

  function createParticle(i: number): Particle {
    const ci = i % COLORS.length;
    return {
      x: Math.random() * (W || 800),
      y: Math.random() * (H || 600),
      ax: 0, ay: 0,
      fx: (Math.random() - 0.5) * 0.3,
      fy: Math.random() * -0.15 - 0.05,
      phase: Math.random() * Math.PI * 2,
      shape: (Math.floor(Math.random() * 4)) as Shape,
      size: Math.random() * 3 + 1.5,
      opacity: Math.random() * 0.3 + 0.08,
      color: COLORS[ci],
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.01,
    };
  }

  for (let i = 0; i < COUNT; i++) particles.push(createParticle(i));

  function drawShape(p: Particle) {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.rotation);
    ctx.globalAlpha = p.opacity;
    const [r, g, b] = p.color;

    switch (p.shape) {
      case 0: // circle
        ctx.beginPath();
        ctx.arc(0, 0, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${b},1)`;
        ctx.shadowColor = `rgba(${r},${g},${b},0.5)`;
        ctx.shadowBlur = p.size * 3;
        ctx.fill();
        break;
      case 1: // 4-point star
        ctx.beginPath();
        for (let i = 0; i < 4; i++) {
          const a = (Math.PI / 2) * i;
          ctx.moveTo(0, 0);
          ctx.lineTo(Math.cos(a - 0.3) * p.size * 0.5, Math.sin(a - 0.3) * p.size * 0.5);
          ctx.lineTo(Math.cos(a) * p.size * 1.5, Math.sin(a) * p.size * 1.5);
          ctx.lineTo(Math.cos(a + 0.3) * p.size * 0.5, Math.sin(a + 0.3) * p.size * 0.5);
        }
        ctx.closePath();
        ctx.fillStyle = `rgba(${r},${g},${b},1)`;
        ctx.shadowColor = `rgba(${r},${g},${b},0.4)`;
        ctx.shadowBlur = p.size * 4;
        ctx.fill();
        break;
      case 2: // diamond
        ctx.beginPath();
        ctx.moveTo(0, -p.size);
        ctx.lineTo(p.size * 0.6, 0);
        ctx.lineTo(0, p.size);
        ctx.lineTo(-p.size * 0.6, 0);
        ctx.closePath();
        ctx.fillStyle = `rgba(${r},${g},${b},1)`;
        ctx.shadowColor = `rgba(${r},${g},${b},0.4)`;
        ctx.shadowBlur = p.size * 3;
        ctx.fill();
        break;
      case 3: // small line
        ctx.beginPath();
        ctx.moveTo(-p.size, 0);
        ctx.lineTo(p.size, 0);
        ctx.strokeStyle = `rgba(${r},${g},${b},1)`;
        ctx.shadowColor = `rgba(${r},${g},${b},0.4)`;
        ctx.shadowBlur = p.size * 2;
        ctx.lineWidth = 0.8;
        ctx.stroke();
        break;
    }
    ctx.restore();
  }

  document.addEventListener('mousemove', e => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  function loop() {
    ctx.clearRect(0, 0, W, H);

    for (const p of particles) {
      p.phase += 0.008;
      p.ax = Math.sin(p.phase) * 0.4;
      p.ay = Math.cos(p.phase * 0.7) * 0.2;

      // Mouse attraction (subtle)
      const dx = mouseX - p.x;
      const dy = mouseY - p.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 200 && dist > 1) {
        p.ax += (dx / dist) * 0.05;
        p.ay += (dy / dist) * 0.05;
      }

      p.x += p.fx + p.ax;
      p.y += p.fy + p.ay;
      p.rotation += p.rotSpeed;

      // Wrap around
      if (p.y < -20) { p.y = H + 20; p.x = Math.random() * W; }
      if (p.x < -20) p.x = W + 20;
      if (p.x > W + 20) p.x = -20;
    }

    for (const p of particles) drawShape(p);

    raf = requestAnimationFrame(loop);
  }

  resize();
  window.addEventListener('resize', resize);
  loop();

  // Cleanup on page transition
  document.addEventListener('astro:before-swap', () => {
    if (raf) cancelAnimationFrame(raf);
  });
});
</script>
