---
import GachaCard from "./GachaCard.astro";

interface GameConfig {
  id: string;
  name: string;
  color: string;
  icon: string;
  apiEndpoint: string;
}

interface Props {
  games: GameConfig[];
}

const { games } = Astro.props;
---

<div class="gacha-wrapper" id="gacha-wrapper">
  <!-- Game tabs -->
  <div class="gacha-tabs">
    {games.map((game, i) => (
      <button
        class:gacha-tab=true
        class:gacha-tab--active={i === 0}
        data-game={game.id}
        data-endpoint={game.apiEndpoint}
      >
        {game.name}
      </button>
    ))}
  </div>

  <!-- Loading state -->
  <div class="gacha-loading" id="gacha-loading">Cargando...</div>

  <!-- Character grid -->
  <div class="gacha-grid" id="gacha-grid" style="display:none;"></div>
</div>

<script>
function initGacha() {
  const wrapper = document.getElementById('gacha-wrapper');
  if (!wrapper) return;

  const tabs = wrapper.querySelectorAll<HTMLButtonElement>('.gacha-tab');
  const grid = wrapper.getElementById('gacha-grid') as HTMLElement;
  const loading = wrapper.getElementById('gacha-loading') as HTMLElement;

  async function loadGame(btn: HTMLButtonElement) {
    tabs.forEach(t => t.classList.remove('gacha-tab--active'));
    btn.classList.add('gacha-tab--active');

    const endpoint = btn.dataset.endpoint;
    if (!endpoint) return;

    grid.style.display = 'none';
    loading.style.display = 'block';

    try {
      const res = await fetch(endpoint);
      const data = await res.json();
      const chars: any[] = data.characters ?? data;

      grid.innerHTML = '';

      for (const c of chars) {
        const card = document.createElement('div');
        card.className = 'gacha-card';

        const imgWrap = document.createElement('div');
        imgWrap.className = 'gacha-card-img';
        if (c.imageUrl) {
          const img = document.createElement('img');
          img.src = c.imageUrl;
          img.alt = c.name || '';
          img.loading = 'lazy';
          imgWrap.appendChild(img);
        }

        const body = document.createElement('div');
        body.className = 'gacha-card-body';

        const name = document.createElement('span');
        name.className = 'gacha-card-name';
        name.textContent = c.name || '';

        const meta = document.createElement('span');
        meta.className = 'gacha-card-meta';
        const parts: string[] = [];
        if (c.element) parts.push(c.element);
        if (c.rarity) parts.push(c.rarity + ' stars');
        if (c.constellation) parts.push(c.constellation);
        meta.textContent = parts.join(' · ');

        body.appendChild(name);
        if (meta.textContent) body.appendChild(meta);
        card.appendChild(imgWrap);
        card.appendChild(body);
        grid.appendChild(card);
      }

      loading.style.display = 'none';
      grid.style.display = '';
    } catch (e) {
      loading.textContent = 'Error al cargar';
    }
  }

  tabs.forEach(btn => {
    btn.addEventListener('click', () => loadGame(btn));
  });

  // Load first tab
  if (tabs[0]) loadGame(tabs[0]);
}

document.addEventListener('DOMContentLoaded', initGacha);
document.addEventListener('astro:page-load', initGacha);
</script>

<style>
  .gacha-wrapper { max-width: 56rem; }

  .gacha-tabs {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .gacha-tab {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 5px 16px;
    cursor: pointer;
    transition: background var(--duration), color var(--duration), border-color var(--duration);
  }

  .gacha-tab:hover {
    background: var(--color-surface-2);
    color: var(--color-ink-soft);
    border-color: var(--color-border-accent);
  }

  .gacha-tab--active {
    background: var(--color-accent);
    color: var(--color-surface);
    border-color: var(--color-accent);
  }

  .gacha-loading {
    color: var(--color-muted);
    font-size: var(--text-sm);
    padding: var(--space-8);
    text-align: center;
  }

  .gacha-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-4);
  }

  .gacha-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
  }

  .gacha-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .gacha-card-img {
    aspect-ratio: 1;
    background: var(--color-surface-2);
    overflow: hidden;
  }

  .gacha-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gacha-card-body {
    padding: var(--space-2) var(--space-3);
  }

  .gacha-card-name {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gacha-card-meta {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.03em;
  }
</style>
