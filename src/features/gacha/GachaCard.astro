---
interface Props {
  name?: string;
  element?: string;
  rarity?: number;
  imageUrl?: string;
  constellation?: string;
}

const { name = '', element = '', rarity = 0, imageUrl = '', constellation = '' } = Astro.props;
---

<div class="gacha-card">
  <div class="gacha-card-img">
    {imageUrl && <img src={imageUrl} alt={name} loading="lazy" />}
  </div>
  <div class="gacha-card-body">
    <span class="gacha-card-name">{name}</span>
    {element && <span class="gacha-card-element">{element}</span>}
    {rarity > 0 && (
      <span class="gacha-card-rarity">
        {Array.from({ length: rarity }).map(() => '*').join('')}
      </span>
    )}
    {constellation && (
      <span class="gacha-card-const">{constellation}</span>
    )}
  </div>
</div>

<style>
  .gacha-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
  }
  .gacha-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }
  .gacha-card-img {
    aspect-ratio: 1;
    background: var(--color-surface-2);
    overflow: hidden;
  }
  .gacha-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .gacha-card-body { padding: var(--space-2) var(--space-3); }
  .gacha-card-name {
    display: block; font-size: var(--text-sm); font-weight: 600;
    color: var(--color-ink); line-height: 1.3;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .gacha-card-element { font-size: var(--text-xs); color: var(--color-muted); }
  .gacha-card-rarity {
    font-size: var(--text-xs); color: var(--color-accent-hi);
    letter-spacing: 0.05em;
  }
  .gacha-card-const {
    display: inline-block; font-size: var(--text-xs);
    color: var(--color-ink-soft); background: var(--color-lavender);
    padding: 1px 6px; border-radius: var(--radius-sm);
    margin-top: 2px;
  }
</style>
